# ============================================================
# Clown Zauberer LIAR – Apache .htaccess für IONOS Hosting
# ============================================================

# ── Fehlerseiten ────────────────────────────────────────────
ErrorDocument 404 /404.html

# ── HTTPS erzwingen ─────────────────────────────────────────
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ── non-www erzwingen (Google indexiert non-www als kanonisch) ──
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# ── Trailing Slash (Astro output) ───────────────────────────
# Wenn URL ohne trailing slash, auf /index.html weiterleiten
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^(.+)$ /$1/ [R=301,L]

# ── WordPress → Astro Weiterleitungen ──────────────────────
# Alle alten WP-URLs, die Google ggf. noch indexiert hat

# -- WordPress Backend & System-URLs --
RedirectMatch 301 ^/wp-admin(.*)$ /
RedirectMatch 301 ^/wp-login\.php(.*)$ /
RedirectMatch 301 ^/wp-signup\.php(.*)$ /
RedirectMatch 301 ^/wp-register\.php(.*)$ /
RedirectMatch 301 ^/wp-cron\.php(.*)$ /
RedirectMatch 301 ^/xmlrpc\.php(.*)$ /
RedirectMatch 301 ^/wp-json(.*)$ /
RedirectMatch 301 ^/wp-includes(.*)$ /
RedirectMatch 301 ^/wp-trackback\.php(.*)$ /
RedirectMatch 301 ^/wp-comments-post\.php(.*)$ /

# -- RSS/Atom Feeds → Blog --
RedirectMatch 301 ^/feed/?$ /blog/
RedirectMatch 301 ^/rss/?$ /blog/
RedirectMatch 301 ^/atom/?$ /blog/
RedirectMatch 301 ^/comments/feed/?$ /blog/
RedirectMatch 301 ^/(.*)/feed/?$ /$1/
RedirectMatch 301 ^/(.*)/comments/?$ /$1/

# -- WordPress Sitemaps (alte Yoast/RankMath Sitemaps) --
RedirectMatch 301 ^/sitemap_index\.xml$ /sitemap.xml
RedirectMatch 301 ^/post-sitemap\.xml$ /sitemap.xml
RedirectMatch 301 ^/page-sitemap\.xml$ /sitemap.xml
RedirectMatch 301 ^/category-sitemap\.xml$ /sitemap.xml
RedirectMatch 301 ^/author-sitemap\.xml$ /sitemap.xml

# -- Autor-Seiten → Startseite --
RedirectMatch 301 ^/author/(.*)$ /

# -- Kategorie- und Tag-Seiten → passende Hauptseiten --
RedirectMatch 301 ^/category/kindergeburtstag(.*)$ /kindergeburtstag/
RedirectMatch 301 ^/category/zaubershow(.*)$ /zauberer/zaubershow/
RedirectMatch 301 ^/category/clown(.*)$ /clown/clown-zauberer/
RedirectMatch 301 ^/category/(.*)$ /blog/
RedirectMatch 301 ^/tag/(.*)$ /blog/
RedirectMatch 301 ^/schlagwort/(.*)$ /blog/

# -- WordPress-Suche → Startseite --
RewriteCond %{QUERY_STRING} ^s=(.*)$
RewriteRule ^$ /? [R=301,L]

# -- WordPress Pagination (z.B. /blog/page/2/) → Hauptseite --
RedirectMatch 301 ^/(.*)/page/[0-9]+/?$ /$1/

# -- WordPress ?p=ID und ?page_id=ID Query-Parameter --
RewriteCond %{QUERY_STRING} ^p=[0-9]+$
RewriteRule ^$ /? [R=301,L]
RewriteCond %{QUERY_STRING} ^page_id=[0-9]+$
RewriteRule ^$ /? [R=301,L]

# -- WordPress-Anhang-Seiten (attachment pages) → 410 Gone --
# Attachment pages have no content value; 410 tells Google to drop them faster than 301
RewriteRule ^attachment/.* - [G,L]

# -- Alte Attachment-URLs mit Bild-Slug (z.B. /kinderzauberer-bild-1/) --
# Diese geben 410 Gone zurück, damit Google sie aus dem Index entfernt
RewriteRule ^.*-attachment/.*$ - [G,L]

# -- Karneval Doppel-URL (WP hatte beides) → neuer Pfad --
RedirectMatch 301 ^/zauberer/zaubershow/karneval/?$ /clown/karneval/

# -- Alte WP-Seiten die nicht mehr existieren → nächste passende --
RedirectMatch 301 ^/sample-page/?$ /
RedirectMatch 301 ^/hello-world/?$ /blog/

# -- Elternseiten-Weiterleitungen (haben keine eigene index.html) --
RedirectMatch 301 ^/clown/?$ /clown/clown-zauberer/

# -- Sicherheit: wp-content/uploads weiterhin erreichbar (Bilder) --
# Bilder liegen noch auf dem alten Server, daher kein Redirect nötig
# Falls Bilder lokal gehostet werden, hier Redirect einrichten

# ============================================================
# ALTE WORDPRESS URL-STRUKTUREN → NEUE ASTRO-URLS (301)
# Basierend auf Google Search Console 404-Analyse
# ============================================================

# --- MUSTER 1: /content/... → Entferne /content/ Prefix ---
RewriteRule ^content/kinderzauberer/?$ /kinderzauberer/ [R=301,L]
RewriteRule ^content/zauberer/tisch-zauberer/?$ /zauberer/tisch-zauberer/ [R=301,L]
RewriteRule ^content/zauberer/kinderzauberer/?$ /kinderzauberer/ [R=301,L]
RewriteRule ^content/zauberer/kinderzauberer/kinderzauberer-in-(.*)$ /kinderzauberer/kinderzauberer-in-$1 [R=301,L]
RewriteRule ^content/clown/clown-in-(.*)$ /clown/clownshow/clown-in-$1 [R=301,L]
RewriteRule ^content/glitzer-tattoos/?$ /clown/glitzer-tattoo/ [R=301,L]
RewriteRule ^content/preise-fuer-clown-oder-kinderzauberer/?$ /preise/ [R=301,L]
RewriteRule ^content/index\.php$ / [R=301,L]
RewriteRule ^content/(.+)$ /blog/ [R=301,L]

# --- MUSTER 2: /clown/kindergeburtstag/... → /kindergeburtstag/... ---
RewriteRule ^clown/kindergeburtstag/?$ /kindergeburtstag/ [R=301,L]
RewriteRule ^clown/kindergeburtstag/(.+)$ /kindergeburtstag/$1 [R=301,L]

# --- MUSTER 3: /clown/geburtstag/... → /kindergeburtstag/... ---
RewriteRule ^clown/geburtstag/?$ /kindergeburtstag/ [R=301,L]
RewriteRule ^clown/geburtstag/(.+)$ /kindergeburtstag/$1 [R=301,L]

# --- MUSTER 4: /clown/zauberer/kinderzauberer/... → /kinderzauberer/... ---
RewriteRule ^clown/zauberer/kinderzauberer/?$ /kinderzauberer/ [R=301,L]
RewriteRule ^clown/zauberer/kinderzauberer/kinderzauberer-in-([^/]+)/?$ /kinderzauberer/kinderzauberer-in-$1/ [R=301,L]
RewriteRule ^clown/zauberer/kinderzauberer/kinderzauberer-in-([^/]+)/.*$ /kinderzauberer/kinderzauberer-in-$1/ [R=301,L]
RewriteRule ^clown/zauberer/(.+)$ /zauberer/$1 [R=301,L]

# --- MUSTER 5: /clown-zauberer/... ---
RewriteRule ^clown-zauberer/clown/glitzer-tattoos/?$ /clown/glitzer-tattoo/ [R=301,L]
RewriteRule ^clown-zauberer/clown/geburtstag/(.+)$ /kindergeburtstag/$1 [R=301,L]
RewriteRule ^clown-zauberer/?$ /clown/clownshow/ [R=301,L]
RewriteRule ^clown-zauberer/(.+)$ /clown/clownshow/ [R=301,L]

# --- MUSTER 6: /clown-nrw/... ---
RewriteRule ^clown-nrw/clown-mieten-und-buchen-in-ihrer-stadt/clown-in-(.+)$ /clown/clownshow/clown-in-$1 [R=301,L]
RewriteRule ^clown-nrw/clown-kinderzauberer-kindergeburtstag/?$ /kindergeburtstag/ [R=301,L]
RewriteRule ^clown-nrw/?$ /clown/clownshow/ [R=301,L]
RewriteRule ^clown-nrw/(.+)$ /clown/clownshow/ [R=301,L]

# --- MUSTER 7: Glitzer-Tattoo Varianten ---
RewriteRule ^clown/glitzer-tattoos/?$ /clown/glitzer-tattoo/ [R=301,L]
RewriteRule ^clown-kindergeburtstag-extras/glitzer-tattoos/?$ /clown/glitzer-tattoo/ [R=301,L]
RewriteRule ^glitzer-tattoos/?$ /clown/glitzer-tattoo/ [R=301,L]
RewriteRule ^glitzer-tattoos-den-kindergeburtstag/?$ /clown/glitzer-tattoo/ [R=301,L]

# --- MUSTER 8: Alte Blog-Posts auf Root-Level ---
