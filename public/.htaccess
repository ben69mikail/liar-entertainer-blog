RewriteRule ^clown-zauberer/kinderzauberer/?$ /kinderzauberer/ [R=301,L]
RewriteRule ^clown-zauberer/kindergeburtstag/?$ /kindergeburtstag/ [R=301,L]
RewriteRule ^clown-zauberer/preise/?$ /preise/ [R=301,L]
RewriteRule ^clown-zauberer/galerie/?$ /galerie/ [R=301,L]
RewriteRule ^clown-zauberer/kontakt/?$ /kontakt/ [R=301,L]
RewriteRule ^clown-zauberer/blog/?$ /blog/ [R=301,L]

# /clown/clown-zauberer/ Varianten (alt → neu)
RewriteRule ^clown/clown-zauberer/?$ /clown/clownshow/ [R=301,L]
RewriteRule ^clown/clown-zauberer/(.+)$ /clown/clownshow/ [R=301,L]

# --- MUSTER 10: /category/ spezifische Mappings ---
RewriteRule ^category/kinderzauberer/?$ /kinderzauberer/ [R=301,L]
RewriteRule ^category/kinderzauberer-und-clown-aus-nrw-aktuell/?$ /blog/ [R=301,L]
RewriteRule ^category/kinderzauberer-und-clown-aus-nrw-aktuell/(.+)$ /blog/ [R=301,L]
RewriteRule ^category/entertainer/?$ /blog/ [R=301,L]
RewriteRule ^category/entertainer/(.+)$ /blog/ [R=301,L]
RewriteRule ^category/kultur-nrw/?$ /blog/ [R=301,L]
RewriteRule ^category/kultur-nrw/(.+)$ /blog/ [R=301,L]
RewriteRule ^category/zaubershow/?$ /zauberer/zaubershow/ [R=301,L]
RewriteRule ^category/zaubershow/(.+)$ /zauberer/zaubershow/ [R=301,L]
RewriteRule ^category/zauberer-2/?$ /zauberer/ [R=301,L]
RewriteRule ^category/zauberer-2/(.+)$ /zauberer/ [R=301,L]
RewriteRule ^category/clown-im-herzen/?$ /blog/ [R=301,L]
RewriteRule ^category/clown-im-herzen/(.+)$ /blog/ [R=301,L]
RewriteRule ^category/besondere-clowns/?$ /blog/ [R=301,L]
RewriteRule ^category/nette-locations/?$ /blog/ [R=301,L]
RewriteRule ^category/nette-locations/(.+)$ /blog/ [R=301,L]
RewriteRule ^category/presse/?$ /blog/ [R=301,L]
RewriteRule ^category/marketing/?$ /blog/ [R=301,L]
RewriteRule ^category/tolle-selbstandige/?$ /blog/ [R=301,L]
RewriteRule ^category/videos/?$ /galerie/ [R=301,L]
RewriteRule ^category/anleitung-fur-kinderspass/?$ /blog/ [R=301,L]
RewriteRule ^category/anleitung-fur-kinderspass/(.+)$ /blog/ [R=301,L]
RewriteRule ^category/kinder-geburtstag-anleitung-fur-kinderspass/?$ /blog/ [R=301,L]
RewriteRule ^category/gelsenkirchen-.*$ /blog/ [R=301,L]
RewriteRule ^category/wetter/?$ /blog/ [R=301,L]

# --- MUSTER 11: GSC 414-URLs Restmenge (Stand 10.04.2026) ---

# /zauberer/kinderzauberer* → /kinderzauberer/* (3 URLs)
RewriteRule ^zauberer/kinderzauberer/?$ /kinderzauberer/ [R=301,L]
RewriteRule ^zauberer/kinderzauberer/kinderzauberer-in-([^/]+)/?$ /kinderzauberer/kinderzauberer-in-$1/ [R=301,L]
RewriteRule ^zauberer/kinderzauberer/(.+)$ /kinderzauberer/ [R=301,L]

# Attachment-URLs global (nicht nur /blog/): */attachment/* → Parent-Seite
RewriteRule ^(.+)/attachment/[^/]+/?$ /$1/ [R=301,L]

# Einzelfälle — alte WP-Paths ohne Entsprechung
RewriteRule ^kinderschminken/?$ /clown/glitzer-tattoo/ [R=301,L]
RewriteRule ^ballonkuenstler/?$ /clown/ballonmodellage/ [R=301,L]
RewriteRule ^index\.html/?$ / [R=301,L]
RewriteRule ^clown-kindergeburtstag/?$ /kindergeburtstag/ [R=301,L]
RewriteRule ^zauberer-kindergeburtstag/?$ /kindergeburtstag/ [R=301,L]
RewriteRule ^clown/20230628_155823/?$ /galerie/ [R=301,L]

# /clown/* alte Blog-Slugs (7 URLs die unter /clown/ statt root liegen)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^clown/([a-z0-9-]{20,})/?$ /blog/ [R=301,L]

# Catch-All für ~157 alte WordPress-Blog-Slugs auf Root-Ebene
# Safe durch !-f !-d (existierende Astro-Seiten werden nicht matched)
# und Mindestlänge 20 Zeichen (verhindert Match auf /kontakt/, /galerie/ etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/(blog|kindergeburtstag|kinderzauberer|zauberer|clown|preise|galerie|kontakt|ueber-mich|impressum|datenschutz|agb|sitemap) [NC]
RewriteRule ^([a-z0-9-]{20,})/?$ /blog/ [R=301,L]

# ── Reviews API Cache-Schutz ──────────────────────────────
<Files "reviews-cache.json">
  Order Allow,Deny
  Deny from all
</Files>
<Files "config.php">
  Order Allow,Deny
  Deny from all
</Files>

# ── MIME Types ──────────────────────────────────────────────
AddType text/html .html
AddType text/css .css
AddType application/javascript .js
AddType application/json .json
AddType image/webp .webp
AddType image/avif .avif
AddType image/svg+xml .svg
AddType font/woff2 .woff2

# ── Gzip Kompression ────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml
  AddOutputFilterByType DEFLATE text/css application/javascript
  AddOutputFilterByType DEFLATE application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff font/woff2
  AddOutputFilterByType DEFLATE application/x-font-ttf application/x-font-opentype
</IfModule>

# Vary Header für korrektes Caching bei Kompression
<IfModule mod_headers.c>
  <FilesMatch "\.(html|css|js|json|xml|svg)$">
    Header append Vary Accept-Encoding
  </FilesMatch>
</IfModule>

# ── Browser Caching ─────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML – kurz cachen (SEO-freundlich)
  ExpiresByType text/html "access plus 1 hour"

  # CSS & JS – lang cachen (Versionierung über Build-Hash)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"

  # Bilder
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Fonts
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"

  # JSON / XML
  ExpiresByType application/json "access plus 1 hour"
  ExpiresByType application/xml "access plus 1 hour"
</IfModule>

# ── Cache-Control Headers ───────────────────────────────────
<IfModule mod_headers.c>
  # Immutable für Astro-Assets (mit Hash im Dateinamen)
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Bilder lang cachen
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|avif|ico|svg)$">
    Header set Cache-Control "public, max-age=31536000"
  </FilesMatch>

  # Fonts
  <FilesMatch "\.(woff|woff2|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000"
  </FilesMatch>

  # HTML kurz cachen
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>

  # Sicherheits-Header
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  # HSTS — Browser merkt sich HTTPS für 1 Jahr, spart HTTP→HTTPS-Redirect
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ── ETags deaktivieren (besser Cache-Control nutzen) ───────
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None
