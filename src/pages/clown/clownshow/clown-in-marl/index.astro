          <p class="text-[#374151] mb-4 leading-relaxed">
            <a href="/clown/clownshow/clown-in-bochum/" class="text-[#3b55d5] hover:underline">Bochum</a> | <a href="/clown/clownshow/clown-in-bottrop/" class="text-[#3b55d5] hover:underline">Bottrop</a> | <a href="/clown/clownshow/clown-in-datteln/" class="text-[#3b55d5] hover:underline">Datteln</a> | <a href="/clown/clownshow/clown-in-dinslaken/" class="text-[#3b55d5] hover:underline">Dinslaken</a> | <a href="/clown/clownshow/clown-in-dorsten/" class="text-[#3b55d5] hover:underline">Dorsten</a> | <a href="/clown/clownshow/clown-in-dortmund/" class="text-[#3b55d5] hover:underline">Dortmund</a> | <a href="/clown/clownshow/clown-in-duesseldorf/" class="text-[#3b55d5] hover:underline">Düsseldorf</a> | <a href="/clown/clownshow/clown-in-duisburg/" class="text-[#3b55d5] hover:underline">Duisburg</a> | <a href="/clown/clownshow/clown-in-essen/" class="text-[#3b55d5] hover:underline">Essen</a> | <a href="/clown/clownshow/clown-in-gelsenkirchen/" class="text-[#3b55d5] hover:underline">Gelsenkirchen</a> | <a href="/clown/clownshow/clown-in-gladbeck/" class="text-[#3b55d5] hover:underline">Gladbeck</a> | <a href="/clown/clownshow/clown-in-haltern/" class="text-[#3b55d5] hover:underline">Haltern am See</a> | <a href="/clown/clownshow/clown-in-herne/" class="text-[#3b55d5] hover:underline">Herne</a> | <a href="/clown/clownshow/clown-in-herten/" class="text-[#3b55d5] hover:underline">Herten</a> | <a href="/clown/clownshow/clown-in-muelheim/" class="text-[#3b55d5] hover:underline">Mülheim</a> | <a href="/clown/clownshow/clown-in-oberhausen/" class="text-[#3b55d5] hover:underline">Oberhausen</a> | <a href="/clown/clownshow/clown-in-recklinghausen/" class="text-[#3b55d5] hover:underline">Recklinghausen</a>
