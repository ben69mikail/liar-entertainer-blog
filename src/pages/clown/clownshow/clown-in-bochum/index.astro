const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Clown-Ruhrgebiet.jpg';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Clown in Bochum",
  "description": "Clown LIAR für Kindergeburtstag und Kinderfest in Bochum, NRW",
  "url": "https://liar-entertainer.com/clown/clownshow/clown-in-bochum/",
  "serviceType": ["Clownshow", "Kinderunterhaltung"],
  "provider": {
    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com",
    "telephone": "+491721517578"
  },
  "areaServed": { "@type": "City", "name": "Bochum" },
  "offers": { "@type": "Offer", "price": "150", "priceCurrency": "EUR" }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was kostet ein Auftritt von Clown LIAR in Bochum? 💶",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Unterschiedlich! Die Gage ist immer individuell abhängig von verschiedenen Faktoren: Art und Umfang der Veranstaltung (Kindergeburtstag, Firmenevent, großes Stadtfest)Anzahl der Zuschauer und Dauer der ShowAnfahrtsweg nach Bochum oder UmgebungZeitpunkt (Wochentag/Wochenende) und eventuell Jahreszeit (Hochsaison im Sommer)Gewünschte Programme (nur Clownshow, oder mit Zauberei, Ballons, Walk Act kombiniert)Bei KINDERGEBURTSTAGEN gibt es feste, transparente Preise! Für Veranstaltungen erstelle ich Ihnen gerne ein individuelles, faires Angebot. Fragen Sie einfach unverbindlich nach! 📞"
      }
    },
    {
      "@type": "Question",
      "name": "Wieviel Platz braucht man für die Clownshow? 📏",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ganz wenig! Ohne lange Vorbereitungszeit und mit einer Fläche von nur 2×2 Meter kann ich bereits eine vollwertige Show vorführen. Das bedeutet, ich bin extrem flexibel einsetzbar:✅ Wohnzimmer & Kinderzimmer (perfekt für Kindergeburtstage zu Hause)✅ Partykeller & Gartenhäuschen✅ Terrasse & Gartenanlage (Outdoor-Events)✅ Große und kleine Bühnen (Stadtfeste, Vereinsfeiern)✅ Bücherei, Gemeindezentrum, Pfarrheim✅ Kindergarten, Kita, Grundschule✅ Turnhalle & MehrzweckraumSie brauchen keine große Location – die Show funktioniert überall! 🎪"
      }
    },
    {
      "@type": "Question",
      "name": "Wie lange dauert eine Vorführung mit dem Clown? ⏰",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Show ist ab 25-30 Minuten zu buchen – perfekt für kürzere Events oder als Teil eines größeren Programms. Auf Wunsch kann die Show auch bis zu 45 Minuten oder länger dauern, je nach Ihren Bedürfnissen. Das Besondere?!? Die Show lässt sich flexibel in jeder Veranstaltung einbauen: Kindergeburtstag & FamilienfeierKarnevalfeier & FaschingspartyKinderfest & StraßenfestSommerfest im Kindergarten oder in der SchuleSchützenfest & VereinsjubiläumBetriebsfeier mit FamilienprogrammHochzeit (Kinderbetreuung während der Feier)Ich passe mich Ihrem Zeitplan an – unkompliziert und professionell! 👍"
      }
    }
  ]
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Clown Bochum, Clown in Bochum, Clownshow Bochum, Clown buchen Bochum, Zauberer Bochum, NRW"
  canonical="https://liar-entertainer.com/clown/clownshow/clown-in-bochum/"
  ogImage={heroImg}
  structuredData={structuredData}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImg}'); background-position: center 20%;`}></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex flex-col items-center justify-center text-center px-6" style="min-height: 600px;">
