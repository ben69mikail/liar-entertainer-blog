---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import karteImg from '../../../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import { Image } from 'astro:assets';
import GoogleReviews from '../../../../components/GoogleReviews.astro';

const seoTitle = "Clown Herne | TOP Bewertungen | Jetzt buchen";
const seoDescription = "Clown in Herne für Kindergeburtstag & Events ✓ Französischer Clown LIAR ✓ 400+ Bewertungen ✓ Lustig & magisch ✓ Auch in Bochum ✓ Jetzt buchen!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Clown-Ruhrgebiet.jpg';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Clown in Herne",
  "description": "Clown LIAR für Kindergeburtstag und Kinderfest in Herne, NRW",
  "url": "https://liar-entertainer.com/clown/clownshow/clown-in-herne/",
  "serviceType": ["Clownshow", "Kinderunterhaltung"],
  "provider": {
    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com",
    "telephone": "+491721517578"
  },
  "areaServed": { "@type": "City", "name": "Herne" },
  "offers": { "@type": "Offer", "price": "150", "priceCurrency": "EUR" }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "💰 Wie hoch ist die Gage für einen Auftritt von Clown LIAR in Herne?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Unterschiedlich! Die Gage ist immer abhängig von:🎪 Art und Umfang der Veranstaltung👥 Zuschauerzahl🚗 Anfahrt (innerhalb Hernes sehr günstig!)📅 JahreszeitBei KINDERGEBURTSTAGEN 🎂 gibt es feste Preise! Fragen Sie einfach nach! 📞"
      }
    },
    {
      "@type": "Question",
      "name": "📏 Wie viel Platz braucht man für eine Show?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ohne Vorbereitungszeit ⏱️ und mit einer Fläche von 2×2 Meter 📐 kann ich eine Show vorführen:🏠 Wohnzimmer, Kinderzimmer, Partykeller🌳 Terrasse, Gartenanlage🎭 Große und kleine Bühne📚 Bücherei, Kindergarten 🏫, Turnhalle"
      }
    },
    {
      "@type": "Question",
      "name": "⏱️ Wie lange dauert eine Vorführung mit dem Clown?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Show ist ab 30 Minuten zu buchen ⏰. Das Besondere?!? Sie lässt sich flexibel in jeder Veranstaltung einbauen:🎂 Kindergeburtstag🎉 Karnevalfeier👨\u200d👩\u200d👧\u200d👦 Kinderfest☀️ Sommerfest im Kindergarten oder Schule🎪 Schützenfest, Straßenfest🏢 Betriebsfeier"
      }
    }
  ]
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Clown Herne, Clown in Herne, Clownshow Herne, Clown buchen Herne, Zauberer Herne, NRW"
  canonical="https://liar-entertainer.com/clown/clownshow/clown-in-herne/"
  ogImage={heroImg}
  structuredData={structuredData}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImg}'); background-position: center 20%;`}></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex flex-col items-center justify-center text-center px-6" style="min-height: 600px;">
      <div class="inline-flex items-center gap-2 bg-white/20 text-white rounded-full px-4 py-1.5 text-sm font-medium mb-4 backdrop-blur-sm">
        <span>📍</span> Herne
      </div>
      <h1 class="text-white font-extrabold text-center leading-tight mb-3" style="font-size: clamp(2rem, 5vw, 3.5rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
        Clown in Herne mit TOP Bewertungen
      </h1>
      <p class="text-gray-200 text-base leading-relaxed max-w-xl mx-auto">
