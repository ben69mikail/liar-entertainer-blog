---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import karteImg from '../../../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import { Image } from 'astro:assets';
import GoogleReviews from '../../../../components/GoogleReviews.astro';

const seoTitle = "Clown Gelsenkirchen | TOP Bewertungen | Buchen";
const seoDescription = "Clown in Gelsenkirchen für Kindergeburtstag ✓ Clown LIAR ✓ 400+ Top-Bewertungen ✓ Lustig & magisch ✓ Auch in Gladbeck & Herten ✓ Jetzt buchen!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Clown-Ruhrgebiet.jpg';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Clown in Gelsenkirchen",
  "description": "Clown LIAR für Kindergeburtstag und Kinderfest in Gelsenkirchen, NRW",
  "url": "https://liar-entertainer.com/clown/clownshow/clown-in-gelsenkirchen/",
  "serviceType": ["Clownshow", "Kinderunterhaltung"],
  "provider": {
    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com",
    "telephone": "+491721517578"
  },
  "areaServed": { "@type": "City", "name": "Gelsenkirchen" },
  "offers": { "@type": "Offer", "price": "150", "priceCurrency": "EUR" }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was braucht Clown LIAR für einen Auftritt?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ohne Vorbereitungszeit und mit einer Fläche von 2×2 Meter kann ich eine Show vorführen: Wohnzimmer, Kinderzimmer, Partykeller, Terrasse, Gartenanlage, große und kleine Bühne, Kindergarten, Turnhalle… Ob drinnen oder draußen, das Programm lässt sich spontan und flexibel ausführen!"
      }
    },
    {
      "@type": "Question",
      "name": "Wieviel Platz braucht man für das Programm?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "LIAR ist ziemlich pflegeleicht: für die Show ist es wichtig, dass die Kinder gemütlich und ungestört sitzen können!!! Bei der Ballonmodellage ist nichts weiteres nötig. Bei GLITZER TATTOOS wären schon 2 Stühle und einen Tisch wichtig!"
      }
    },
    {
      "@type": "Question",
      "name": "Wie viele Kinder sollten überhaupt eingeladen werden?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Natürlich soll das Kind seine Freunde einladen. Allerdings sollte man eine feste Zahl als Limit vorgeben. Pädagogen empfehlen, maximal genauso viele Gäste einzuladen, wie das Kind alt wird. Wer kommen darf, soll das Kind selbst bestimmen. Natürlich sind auch dabei die Aufsichtspersonen (mindestens 2) nicht zu vergessen."
      }
    }
  ]
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Clown Gelsenkirchen, Clown in Gelsenkirchen, Clownshow Gelsenkirchen, Clown buchen Gelsenkirchen, Zauberer Gelsenkirchen, NRW"
  canonical="https://liar-entertainer.com/clown/clownshow/clown-in-gelsenkirchen/"
  ogImage={heroImg}
  structuredData={structuredData}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImg}'); background-position: center 20%;`}></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex flex-col items-center justify-center text-center px-6" style="min-height: 600px;">
      <div class="inline-flex items-center gap-2 bg-white/20 text-white rounded-full px-4 py-1.5 text-sm font-medium mb-4 backdrop-blur-sm">
        <span>📍</span> Gelsenkirchen
      </div>
      <h1 class="text-white font-extrabold text-center leading-tight mb-3" style="font-size: clamp(2rem, 5vw, 3.5rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
        TOP Clown in Gelsenkirchen – LIAR | Shows & Zauberkunst
      </h1>
      <p class="text-gray-200 text-base leading-relaxed max-w-xl mx-auto">
        Clownshow und Unterhaltung in Gelsenkirchen – Spaß, Lachen und gute Laune für Groß und Klein!
      </p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <section class="bg-white pt-4 pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="text-sm text-[#595959]">
        <a href="/" class="text-[#d7393e] hover:underline">Clown</a>
        <span class="mx-1">»</span>
        <a href="/clown/clownshow/" class="text-[#d7393e] hover:underline">Clownshow</a>
        <span class="mx-1">»</span>
        <span>TOP Clown in Gelsenkirchen – LIAR | Shows & Zauberkunst</span>
      </nav>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-[#d7393e] font-bold text-xl mb-4">Ihr Entertainer für Gelsenkirchen! 🎉</h2>
          <p class="text-[#374151] mb-4 leading-relaxed">Sie suchen professionelles Entertainment für Ihre Feier in Gelsenkirchen? Dann sind Sie hier richtig! Als erfahrener Clown verstehe ich es, durch authentische Mimik und spontane Gesten echte Freude zu wecken 😊.</p>
          <p class="text-[#374151] mb-4 leading-relaxed">Meine Stärke? Ich schaffe es, selbst zurückhaltende Gäste zum Mitmachen zu bewegen – ohne Druck, sondern durch sympathische Tollpatschigkeit, die verbindet statt zu distanzieren. So entsteht eine Atmosphäre, in der sich alle wohlfühlen!</p>
          <p class="text-[#374151] mb-4 leading-relaxed">Mit meiner flexiblen Clownshow gestalte ich Ereignisse, an die sich Kinder und Familien noch Jahre später gerne erinnern. Ob als beweglicher WALK-ACT zwischen den Gästen, kombiniert mit kreativer BALLONMODELLAGE oder ergänzt durch verblüffende ZAUBEREI – Ihre Veranstaltung oder private Feier (Hochzeit, Betriebsfest oder Geburtstag) erhält dadurch das gewisse Etwas! 🎭✨</p>
        </div>
        <div class="flex justify-center">
          <img
            src="https://liar-entertainer.com/wp-content/uploads/2023/08/Fotogalerie-Clown-Zauberer-16.jpg"
            alt="Clownshow in Gelsenkirchen"
            class="rounded-full object-cover object-[20%]"
            style="width: 320px; height: 320px;"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <GoogleReviews />

  <!-- Wave: white → blue -->
  <div style="overflow:hidden;line-height:0;background:white;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>
  <section class="bg-[#3b55d5] py-14 text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-[#ffb546] font-bold text-sm uppercase tracking-widest mb-4">GELSENKIRCHEN</p>
      <h2 class="text-white font-bold text-3xl sm:text-4xl mb-6">✨ Clownshow in Gelsenkirchen – mit Herz &amp; Humor</h2>
      <p class="text-white leading-relaxed mb-4">
        Meine Show ist speziell auf Kinder abgestimmt: lebendig, interaktiv und voller Überraschungen.
      </p>
      <p class="text-white leading-relaxed">
        Die Kinder dürfen mitzaubern, lachen, staunen – und manchmal selbst zur kleinen Zauberin oder zum Zauberer werden.
        Dabei achte ich besonders auf Respekt, Empathie und ein liebevolles Miteinander.
      </p>
    </div>
  </section>
  <!-- Wave: blue → white -->
  <div style="overflow:hidden;line-height:0;background:#3b55d5;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- Show-Konzept mit Herz! 💫 -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-[#1f2025] font-bold text-2xl sm:text-3xl text-center mb-6">Show-Konzept mit Herz! 💫</h2>
      <p class="text-[#374151] mb-4 leading-relaxed">Was unterscheidet meine Show von anderen? Ganz einfach: Bei mir stehen nicht die Tricks im Vordergrund, sondern die Kinder!</p>
      <p class="text-[#374151] mb-4 leading-relaxed">Natürlich sind die Zaubertricks verblüffend und die Clownerien lustig – aber das wahre Highlight ist der Moment, wenn ein schüchternes Kind plötzlich auf der „Bühne" steht und merkt: „Hey, ich kann das auch!" Diese Verwandlung von Zuschauern zu aktiven Teilnehmern geschieht schneller als gedacht.</p>
      <p class="text-[#374151] mb-4 leading-relaxed">Durch geschickte Einbindung sorge ich dafür, dass jedes Kind – egal ob mutig oder zurückhaltend – seinen Moment hat. So entstehen Erinnerungen, die bleiben. Das ist echtes Entertainment mit Mehrwert! 🎪✨</p>
    </div>
  </section>

  <!-- Wave: white → red (Stats) -->
  <div style="overflow:hidden;line-height:0;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#d7393e"/>
    </svg>
  </div>

  <!-- Stats Banner -->
  <section class="w-full bg-[#d7393e] py-10 text-center">
    <div class="max-w-4xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-transparent border border-white/30 rounded-xl p-6">
        <div class="text-3xl mb-2">🪄</div>
        <div class="text-4xl font-extrabold text-white">400</div>
        <div class="text-white text-sm mt-1">Shows im Jahr</div>
      </div>
      <div class="bg-transparent border border-white/30 rounded-xl p-6">
        <div class="text-3xl mb-2">😊</div>
        <div class="text-4xl font-extrabold text-white">110.000</div>
        <div class="text-white text-sm mt-1">Lachende Kinder</div>
      </div>
      <div class="bg-transparent border border-white/30 rounded-xl p-6">
        <div class="text-3xl mb-2">🪄</div>
        <div class="text-4xl font-extrabold text-white">15</div>
        <div class="text-white text-sm mt-1">Jahre Erfahrung</div>
