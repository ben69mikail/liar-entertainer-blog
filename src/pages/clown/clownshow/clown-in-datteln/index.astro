---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import karteImg from '../../../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import { Image } from 'astro:assets';
import GoogleReviews from '../../../../components/GoogleReviews.astro';

const seoTitle = "Clown Datteln | TOP Bewertungen | Jetzt buchen";
const seoDescription = "Clown in Datteln buchen ✓ Französischer Clown LIAR ✓ 400+ Bewertungen ✓ Für Kindergeburtstag & Events ✓ Auch in Waltrop & Recklinghausen ✓ Anfragen!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Clown-Ruhrgebiet.jpg';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Clown in Datteln",
  "description": "Clown LIAR für Kindergeburtstag und Kinderfest in Datteln, NRW",
  "url": "https://liar-entertainer.com/clown/clownshow/clown-in-datteln/",
  "serviceType": ["Clownshow", "Kinderunterhaltung"],
  "provider": {
    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com",
    "telephone": "+491721517578"
  },
  "areaServed": { "@type": "City", "name": "Datteln" },
  "offers": { "@type": "Offer", "price": "150", "priceCurrency": "EUR" }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was kostet einen Auftritt von Clown LIAR?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Unterschiedlich! Die Gage ist immer abhängig von Art und Umfang der Veranstaltung, der Zuschauerzahl, der Anfahrt und auch eventuell der Jahreszeit. Bei KINDERGEBURTSTAGE gibt es feste Preise! Fragen Sie einfach nach!"
      }
    },
    {
      "@type": "Question",
      "name": "Wieviel Platz braucht man für die Clownshow?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ohne Vorbereitungszeit und mit einer Fläche von 2×2 Meter kann ich eine Show vorführen: Wohnzimmer, Kinderzimmer, Partykeller, Terrasse, Gartenanlage, große und kleine Bühne, Bücherei, Kindergarten, Turnhalle…"
      }
    },
    {
      "@type": "Question",
      "name": "Wie lange dauert eine eine Vorführung mit dem Clown?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Show ist ab 25/30 Minuten zu buchen. Das Besondere?!? Sie lässt sich flexibel in jeder Veranstaltung einbauen: Kindergeburtstag, Karnevalfeier, Kinderfest, Sommerfest im Kindergarten oder Schule, Schützenfest, Straßenfest, Betriebsfeier…"
      }
    }
  ]
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Clown Datteln, Clown in Datteln, Clownshow Datteln, Clown buchen Datteln, Zauberer Datteln, NRW"
  canonical="https://liar-entertainer.com/clown/clownshow/clown-in-datteln/"
  ogImage={heroImg}
  structuredData={structuredData}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImg}'); background-position: center 20%;`}></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex flex-col items-center justify-center text-center px-6" style="min-height: 600px;">
      <div class="inline-flex items-center gap-2 bg-white/20 text-white rounded-full px-4 py-1.5 text-sm font-medium mb-4 backdrop-blur-sm">
        <span>📍</span> Datteln
      </div>
      <h1 class="text-white font-extrabold text-center leading-tight mb-3" style="font-size: clamp(2rem, 5vw, 3.5rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
        Clown in Datteln – Zauberspaß & gute Laune für Dein Event
      </h1>
      <p class="text-gray-200 text-base leading-relaxed max-w-xl mx-auto">
        Clownshow und Unterhaltung in Datteln – Spaß, Lachen und gute Laune für Groß und Klein!
      </p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <section class="bg-white pt-4 pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="text-sm text-[#595959]">
        <a href="/" class="text-[#d7393e] hover:underline">Clown</a>
        <span class="mx-1">»</span>
        <a href="/clown/clownshow/" class="text-[#d7393e] hover:underline">Clownshow</a>
        <span class="mx-1">»</span>
        <span>Clown in Datteln – Zauberspaß & gute Laune für Dein Event</span>
      </nav>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-[#d7393e] font-bold text-xl mb-4">Warum gerade in Datteln?</h2>
          <p class="text-[#374151] mb-4 leading-relaxed">Datteln ist nicht nur für die Schleusenanlage und den Kanal bekannt – hier gibt es zahlreiche charmante Orte für Festivitäten: vom gemütlichen Garten bis zur Aula im Kinderhaus. Meine Shows in Datteln profitieren vom kurzen Anfahrtsweg – somit bleibt der Preis fair, und ich kann flexibel auftreten. 💡Ob im Stadtteil Ö – Osten oder rund um den Kanal-Park: Deine Location wird zur Bühne für Spaß & Magie.</p>
        </div>
        <div class="flex justify-center">
          <img
            src="https://liar-entertainer.com/wp-content/uploads/2023/08/Clown.jpg"
            alt="Clownshow in Datteln"
            class="rounded-full object-cover object-[20%]"
            style="width: 320px; height: 320px;"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <GoogleReviews />

  <!-- Wave: white → blue -->
  <div style="overflow:hidden;line-height:0;background:white;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>
  <section class="bg-[#3b55d5] py-14 text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-[#ffb546] font-bold text-sm uppercase tracking-widest mb-4">DATTELN</p>
      <h2 class="text-white font-bold text-3xl sm:text-4xl mb-6">✨ Clownshow in Datteln – mit Herz &amp; Humor</h2>
      <p class="text-white leading-relaxed mb-4">
        Meine Show ist speziell auf Kinder abgestimmt: lebendig, interaktiv und voller Überraschungen.
      </p>
      <p class="text-white leading-relaxed">
        Die Kinder dürfen mitzaubern, lachen, staunen – und manchmal selbst zur kleinen Zauberin oder zum Zauberer werden.
        Dabei achte ich besonders auf Respekt, Empathie und ein liebevolles Miteinander.
      </p>
    </div>
  </section>
  <!-- Wave: blue → white -->
  <div style="overflow:hidden;line-height:0;background:#3b55d5;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- " Diese SHOW mit dem Clown in Datteln ist DAS Highlight " -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-[#1f2025] font-bold text-2xl sm:text-3xl text-center mb-10">" Diese SHOW mit dem Clown in Datteln ist DAS Highlight "</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#d7393e]">
          <h3 class="font-bold text-[#1f2025] text-lg mb-3">✨ Glitzer-Tattoos</h3>
          <p class="text-[#374151] leading-relaxed">Für den besonderen Glanz: Hautverträglich und mit Wow-Effekt – meine Glitzer-Tattoos begeistern Groß und Klein und bleiben gerne noch einige Tage sichtbar.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#3b55d5]">
          <h3 class="font-bold text-[#1f2025] text-lg mb-3">🎭 Showmix: Clown trifft Zauberer</h3>
          <p class="text-[#374151] leading-relaxed">In meiner Show erleben Kinder und Erwachsene nicht nur reine Animation, sondern werden aktiv eingebunden: Ich zaubere und dabei werden alle zu kleinen Mitwirkenden.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#ffb546]">
          <h3 class="font-bold text-[#1f2025] text-lg mb-3">🎈 Ballonmodellage</h3>
          <p class="text-[#374151] leading-relaxed">Ob Ritterhelm oder Marienkäfer: Ich forme individuelle Ballonfiguren live vor Ort – jedes Kind geht mit seinem Wunsch­tier nach Hause. Ideal als Ergänzung zur Show oder als eigenständiger Programmpunkt.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave: white → red (Stats) -->
  <div style="overflow:hidden;line-height:0;background:white;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#d7393e"/>
    </svg>
