import GoogleReviews from '../../../../components/GoogleReviews.astro';

const seoTitle = "Clown Bottrop | TOP Bewertungen | Jetzt buchen";
const seoDescription = "Clown in Bottrop für Kindergeburtstag & Feste ✓ Clown Zauberer LIAR ✓ 400+ Bewertungen ✓ Lustig & magisch ✓ Auch in Gladbeck & Oberhausen ✓ Buchen!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Clown-Ruhrgebiet.jpg';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Clown in Bottrop",
  "description": "Clown LIAR für Kindergeburtstag und Kinderfest in Bottrop, NRW",
  "url": "https://liar-entertainer.com/clown/clownshow/clown-in-bottrop/",
  "serviceType": ["Clownshow", "Kinderunterhaltung"],
  "provider": {
    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com",
    "telephone": "+491721517578"
  },
  "areaServed": { "@type": "City", "name": "Bottrop" },
  "offers": { "@type": "Offer", "price": "150", "priceCurrency": "EUR" }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was kostet ein Auftritt von Clown LIAR in Bottrop? 💶",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Kosten variieren individuell! Die Gage richtet sich immer nach verschiedenen wichtigen Faktoren:📌 Art und Umfang der Veranstaltung (privater Kindergeburtstag, großes Firmenevent, Stadtfest)📌 Zuschauerzahl (kleine Gruppe oder mehrere hundert Gäste)📌 Anfahrtsweg nach Bottrop oder in die Region📌 Zeitpunkt (Wochentag/Wochenende, Vor-/Nachmittag)📌 Jahreszeit (Hochsaison im Frühling/Sommer oder Nebensaison)📌 Gewünschte Programme (nur Clownshow oder Kombination mit Zauberei, Ballonmodellage, Walk Act)Bei KINDERGEBURTSTAGEN gibt es transparente Festpreise, die ich Ihnen gerne mitteile! Für größere Veranstaltungen, Firmenevents oder Feste erstelle ich Ihnen ein individuelles, faires Angebot. Fragen Sie einfach unverbindlich nach – ich berate Sie ehrlich und kompetent! 📞😊"
      }
    },
    {
      "@type": "Question",
      "name": "Wieviel Platz braucht man für die Clownshow? 📏",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Erstaunlich wenig! Ganz ohne lange Vorbereitungszeit und mit einer kompakten Fläche von lediglich 2×2 Meter kann ich bereits eine vollwertige, professionelle Show vorführen. Das bedeutet maximale Flexibilität für Sie:✅ Wohnzimmer & Kinderzimmer – Ideal für Kindergeburtstage zu Hause✅ Partykeller & Hobbyraum – Gemütliche Atmosphäre✅ Terrasse & Gartenanlage – Perfekt für Outdoor-Feiern✅ Große und kleine Bühnen – Für Stadtfeste und Vereinsveranstaltungen✅ Bücherei & Gemeindezentrum – Kulturelle Events✅ Kindergarten, Kita & Schule – Pädagogisch wertvolle Unterhaltung✅ Turnhalle & Mehrzweckraum – Auch für größere Gruppen✅ Restaurant & Festsaal – Bei Hochzeiten und FamilienfeiernSie benötigen keine große Location oder aufwendige Vorbereitung – die Show funktioniert praktisch überall! Das macht die Planung für Sie unkompliziert und stressfrei. 🎪👍"
      }
    },
    {
      "@type": "Question",
      "name": "Wie lange dauert eine Vorführung mit dem Clown? ⏰",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Standard-Show ist ab 30 Minuten zu buchen – perfekt als kompaktes Highlight für kürzere Events oder als Teil eines größeren Veranstaltungsprogramms. Auf Ihren Wunsch hin kann die Show auch problemlos auf bis zu 45 Minuten oder sogar länger ausgedehnt werden, ganz nach Ihren spezifischen Bedürfnissen und Ihrem Zeitplan.Das wirklich Besondere?!? Die Show lässt sich super flexibel in jeder Art von Veranstaltung perfekt einbauen:🎈 Kindergeburtstag & Familienfeier zu Hause🎭 Karnevalfeier & Faschingsparty🎪 Kinderfest & Straßenfest in Bottrop☀️ Sommerfest im Kindergarten oder in der Schule🎯 Schützenfest & Vereinsjubiläum🏢 Betriebsfeier mit Kinderprogramm💒 Hochzeit (unterhaltsame Kinderbetreuung während der Feier)🎄 Weihnachtsfeier & FirmeneventIch passe mich zeitlich flexibel Ihrem individuellen Programmablauf an – absolut unkompliziert und immer professionell! Sie sagen mir, wann es losgehen soll, und ich liefere pünktlich ab! ⏱️✅"
      }
    }
  ]
};

const structuredData = [serviceSchema, faqSchema];
