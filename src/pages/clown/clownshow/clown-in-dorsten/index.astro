---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import karteImg from '../../../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import { Image } from 'astro:assets';
import GoogleReviews from '../../../../components/GoogleReviews.astro';

const seoTitle = "Clown Dorsten | TOP Bewertungen | Jetzt buchen";
const seoDescription = "Clown in Dorsten buchen ✓ Clown Zauberer LIAR ✓ 400+ Bewertungen ✓ Lustige Show für Kindergeburtstag ✓ Auch in Marl & Haltern ✓ Jetzt anfragen!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Clown-Ruhrgebiet.jpg';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Clown in Dorsten",
  "description": "Clown LIAR für Kindergeburtstag und Kinderfest in Dorsten, NRW",
  "url": "https://liar-entertainer.com/clown/clownshow/clown-in-dorsten/",
  "serviceType": ["Clownshow", "Kinderunterhaltung"],
  "provider": {
    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com",
    "telephone": "+491721517578"
  },
  "areaServed": { "@type": "City", "name": "Dorsten" },
  "offers": { "@type": "Offer", "price": "150", "priceCurrency": "EUR" }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was braucht Clown LIAR für einen Auftritt?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ohne Vorbereitungszeit und mit einer Fläche von 2×2 Meter kann ich eine Show vorführen: Wohnzimmer, Kinderzimmer, Partykeller, Terrasse, Gartenanlage, große und kleine Bühne, Kindergarten, Turnhalle… Ob drinnen oder draußen, das Programm lässt sich spontan und flexibel ausführen!"
      }
    },
    {
      "@type": "Question",
      "name": "Wieviel Platz braucht man für das Programm?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "LIAR ist ziemlich pflegeleicht: für die Show ist es wichtig, dass die Kinder gemütlich und ungestört sitzen können!!! Bei der Ballonmodellage ist nichts weiteres nötig. Bei GLITZER TATTOOS wären schon 2 Stühle und einen Tisch wichtig!"
      }
    },
    {
      "@type": "Question",
      "name": "Wie viele Kinder sollten überhaupt eingeladen werden?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Natürlich soll das Kind seine Freunde einladen. Allerdings sollte man eine feste Zahl als Limit vorgeben. Pädagogen empfehlen, maximal genauso viele Gäste einzuladen, wie das Kind alt wird. Wer kommen darf, soll das Kind selbst bestimmen. Natürlich sind auch dabei die Aufsichtspersonen (mindestens 2) nicht zu vergessen."
      }
    }
  ]
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Clown Dorsten, Clown in Dorsten, Clownshow Dorsten, Clown buchen Dorsten, Zauberer Dorsten, NRW"
  canonical="https://liar-entertainer.com/clown/clownshow/clown-in-dorsten/"
  ogImage={heroImg}
  structuredData={structuredData}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImg}'); background-position: center 20%;`}></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex flex-col items-center justify-center text-center px-6" style="min-height: 600px;">
      <div class="inline-flex items-center gap-2 bg-white/20 text-white rounded-full px-4 py-1.5 text-sm font-medium mb-4 backdrop-blur-sm">
        <span>📍</span> Dorsten
      </div>
      <h1 class="text-white font-extrabold text-center leading-tight mb-3" style="font-size: clamp(2rem, 5vw, 3.5rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
        Clown Dorsten – LIAR | Show, Magie & Clownerie
      </h1>
      <p class="text-gray-200 text-base leading-relaxed max-w-xl mx-auto">
        Clownshow und Unterhaltung in Dorsten – Spaß, Lachen und gute Laune für Groß und Klein!
      </p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <section class="bg-white pt-4 pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="text-sm text-[#595959]">
        <a href="/" class="text-[#d7393e] hover:underline">Clown</a>
        <span class="mx-1">»</span>
        <a href="/clown/clownshow/" class="text-[#d7393e] hover:underline">Clownshow</a>
        <span class="mx-1">»</span>
        <span>Clown Dorsten – LIAR | Show, Magie & Clownerie</span>
      </nav>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-[#d7393e] font-bold text-xl mb-4">Magisch &Witzig! 🤡✨</h2>
          <p class="text-[#374151] mb-4 leading-relaxed">Kinder aus Dorsten und der ganzen Region schließen den Clown sofort ins Herz! Warum? Weil ich es verstehe, durch feine Mimik und überraschende Gesten selbst die zurückhaltendsten Gäste zum Schmunzeln zu bringen 😊. Mein Geheimnis? Authentische Tollpatschigkeit, die niemanden bloßstellt, sondern alle einbindet!</p>
          <p class="text-[#374151] mb-4 leading-relaxed">In über 4.000 Auftritten habe ich gelernt: Jede Veranstaltung ist anders. Privatfeiern haben einen anderen Rhythmus als Firmenfeste, Vereinsjubiläen brauchen andere Energie als Schulaufführungen. Diese Vielseitigkeit macht meine Shows so besonders – ich reagiere auf mein Publikum, statt einfach nur ein Programm abzuspulen! 🎭</p>
          <p class="text-[#374151] mb-4 leading-relaxed">Was passiert bei meinen Shows? Die kleinen Gäste werden zu Hauptdarstellern! Sie helfen nicht nur – sie gestalten mit. Dadurch entsteht eine Dynamik, die jede Vorstellung einzigartig macht. Genau diese Momente bleiben den Kindern in Dorsten besonders lange im Gedächtnis! 🌟</p>
        </div>
        <div class="flex justify-center">
          <img
            src="https://liar-entertainer.com/wp-content/uploads/2023/08/Fotogalerie-Clown-Zauberer-16.jpg"
            alt="Clownshow in Dorsten"
            class="rounded-full object-cover object-[20%]"
            style="width: 320px; height: 320px;"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <GoogleReviews />

  <!-- Wave: white → blue -->
  <div style="overflow:hidden;line-height:0;background:white;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
