---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import GoogleReviews from '../../../../components/GoogleReviews.astro';
import { Image } from 'astro:assets';
import heroImg from '../../../../assets/images/galerie/fotogalerie-clown-zauberer-3.jpg';
import kitaEssenImg from '../../../../assets/images/clown/kinderzauberer-kindergarten-essen.jpg';
import geburtstagKitaImg from '../../../../assets/images/zauberer/geburtstag-kita.jpg';
import galerieImg2 from '../../../../assets/images/galerie/fotogalerie-clown-zauberer-2.jpg';
import kindergartenGelsenkirchenImg from '../../../../assets/images/zauberer/kindergarten-gelsenkirchen.jpg';
import karteImg from '../../../../assets/images/kinderzauberer/clown-zauberer-gladbeck.jpg';

const seoTitle = 'Zaubershow Kindergarten & Kita NRW | LIAR';
const seoDescription = 'Zaubershow für Kindergarten & Kita in NRW ✓ Kinderzauberer LIAR ✓ Ab 150€ ✓ 400+ Top-Bewertungen ✓ Pädagogisch wertvoll ✓ Jetzt buchen!';

const anlaesse = [
  { icon: '☀️', title: 'Sommerfeste', text: 'Der Klassiker! Beim Sommerfest ist die Zaubershow oft DAS Highlight. Ob auf der Bühne oder als Walk-Act – ich sorge für strahlende Kinderaugen und zufriedene Eltern.' },
  { icon: '🎓', title: 'Abschiedsfeiern für Vorschulkinder', text: 'Die Vorschulkinder verlassen den Kindergarten – ein emotionaler Moment! Meine Show macht diesen Übergang zu einem fröhlichen, unvergesslichen Erlebnis.' },
  { icon: '🎭', title: 'Projektwochen', text: 'Projektwochen zu Themen wie „Zirkus", „Magie", „Fantasie" oder „Berufe"? Meine Show passt perfekt!' },
  { icon: '🎄', title: 'Weihnachtsfeiern & Winterfeste', text: 'Auch in der kalten Jahreszeit sorge ich für warme Kinderherzen. Die Show lässt sich wunderbar in Weihnachtsfeiern integrieren.' },
  { icon: '🎈', title: 'Faschings-/Karnevalsfeiern', text: 'Wenn es bunt und lustig wird, bin ich in meinem Element! Die Clown-Elemente meiner Show passen perfekt zur Karnevalszeit.' },
  { icon: '🎊', title: 'Jubiläen & besondere Anlässe', text: '10 Jahre Kindergarten? Neues Gebäude? Tag der offenen Tür? Für besondere Anlässe biete ich besondere Shows!' },
];

const paedagogisch = [
  { icon: '✨', title: 'Fantasie & Kreativität', text: 'Zaubergeschichten regen die Vorstellungskraft an' },
  { icon: '💪', title: 'Selbstbewusstsein', text: 'Als Zauberassistent auf der „Bühne" zu stehen stärkt das Selbstwertgefühl' },
  { icon: '👂', title: 'Konzentration', text: '30–45 Min. aufmerksam dabei bleiben – eine beachtliche Leistung für Kindergartenkinder!' },
  { icon: '🗣️', title: 'Sprachförderung', text: 'Zaubersprüche sprechen, Dinge benennen, Fragen beantworten' },
  { icon: '🤝', title: 'Soziale Kompetenz', text: 'Zusammen helfen, abwechseln, gemeinsam Erfolge feiern' },
  { icon: '🎭', title: 'Emotionale Entwicklung', text: 'Freude, Überraschung, Staunen – ein emotionales Feuerwerk!' },
];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Zaubershow Kindergarten, Zauberer Kita, Zaubershow Kita NRW, Kindergarten Programm, Sommerfest Kindergarten"
  canonical="https://liar-entertainer.com/zauberer/zaubershow/kindergarten-kita/"
>

  <!-- Page Title -->
  <section class="bg-white pt-8 pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <p class="text-sm text-[#595959] mb-4">
        <a href="/" class="hover:text-[#d7393e]">Clown</a> »
        <a href="/zauberer/" class="hover:text-[#d7393e]">Zauberer</a> »
        <a href="/zauberer/zaubershow/" class="hover:text-[#d7393e]">Zaubershow</a> »
        <span>Kindergarten – Kita</span>
      </p>
      <h1 class="font-black text-[#1f2025] text-3xl sm:text-5xl mb-6">Kindergarten – Kita</h1>
    </div>
  </section>

  <!-- Hero -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <Image
      src={heroImg}
      alt="Zaubershow für Kindergarten & Kita NRW"
      class="absolute inset-0 w-full h-full object-cover object-top"
      style="object-position: 50% 30%"
      loading="eager"
      fetchpriority="high"
      widths={[600, 900, 1200]}
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex items-center justify-center" style="min-height: 600px;">
      <div class="text-center px-6">
        <h2 class="text-white font-bold leading-tight mb-4" style="font-size: clamp(1.6rem, 4vw, 3rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
          🎪 Zaubershow für Kindergarten &amp; Kita –<br />Wo Lernen auf Magie trifft!
        </h2>
        <p class="text-white/90 text-lg font-medium">Pädagogisch wertvoll. Altersgerecht. Unvergesslich.</p>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <p class="text-[#374151] leading-relaxed mb-4">
            Sie planen ein Sommerfest, eine Abschiedsfeier für die Vorschulkinder oder suchen ein besonderes Highlight für Ihre Kita? Als erfahrener Kinderzauberer bringe ich seit über 15 Jahren Magie in Kindergärten und Kitas in ganz NRW. Meine Shows sind nicht nur unterhaltsam – sie sind pädagogisch wertvoll, altersgerecht und perfekt auf die Bedürfnisse von Bildungseinrichtungen abgestimmt! ✨
          </p>
          <p class="text-[#374151] leading-relaxed mb-4">
            Das Beste? Für Sie als Erzieher bedeutet es minimalen Aufwand bei maximalem Erfolg. Ich bringe alles mit, benötige keine Vorbereitung und nur 2×2 Meter Platz. Ich biete auch spezielle Shows für <a href="/zauberer/zaubershow/schule/" class="text-[#d7393e] hover:underline">Grundschulen</a> sowie auf <a href="/zauberer/zaubershow/strassen-sommer-fest/" class="text-[#d7393e] hover:underline">Straßen- und Sommerfesten</a> an.
          </p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="font-bold text-[#1f2025] mb-4">⭐ Das macht meine Show kindergartengerecht:</h3>
          <ul class="space-y-3 text-sm">
            <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">🎯</span> <span class="text-[#374151]"><strong>Altersgerecht für 3–6 Jahre:</strong> Einfache Tricks, kurze Geschichten, viel Bewegung</span></li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">👥</span> <span class="text-[#374151]"><strong>Große Gruppen kein Problem:</strong> Erfahrung mit 20–100 Kindern</span></li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">📚</span> <span class="text-[#374151]"><strong>Pädagogischer Mehrwert:</strong> Fördert Fantasie, Kreativität und Selbstbewusstsein</span></li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">🤝</span> <span class="text-[#374151]"><strong>Inklusion:</strong> Alle Kinder werden eingebunden – schüchterne wie wilde</span></li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">⚡</span> <span class="text-[#374151]"><strong>Unkompliziert:</strong> Minimaler Vorbereitungsaufwand, nur 2×2 Meter Platz</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <GoogleReviews />

  <!-- Anlässe -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-bold text-[#1f2025] text-2xl sm:text-3xl text-center mb-10">🎉 Perfekt für diese Anlässe in Kindergarten & Kita</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {anlaesse.map((a, i) => (
          <div class={`bg-white rounded-xl p-6 shadow-sm border-t-4 ${['border-[#d7393e]','border-[#3b55d5]','border-[#ffb546]'][i % 3]}`}>
            <p class="text-3xl mb-3">{a.icon}</p>
            <h3 class="font-bold text-[#1f2025] mb-2">{a.title}</h3>
            <p class="text-[#374151] text-sm leading-relaxed">{a.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Wave: white → red (Stats) -->
  <div style="overflow:hidden;line-height:0;background:white;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#d7393e"/>
    </svg>
  </div>
  <section class="bg-[#d7393e] py-10 text-white text-center">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-transparent border border-white/30 rounded-xl p-6">
          <div class="text-3xl mb-2">🪄</div>
          <div class="text-4xl font-extrabold">400</div>
          <div class="text-sm mt-1">Shows im Jahr</div>
        </div>
        <div class="bg-transparent border border-white/30 rounded-xl p-6">
          <div class="text-3xl mb-2">😊</div>
          <div class="text-4xl font-extrabold">110.000</div>
          <div class="text-sm mt-1">Lachende Kinder</div>
        </div>
        <div class="bg-transparent border border-white/30 rounded-xl p-6">
          <div class="text-3xl mb-2">🪄</div>
          <div class="text-4xl font-extrabold">15</div>
          <div class="text-sm mt-1">Jahre Erfahrung</div>
        </div>
      </div>
    </div>
  </section>
  <div style="overflow:hidden;line-height:0;background:#d7393e;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- Pädagogischer Mehrwert -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-bold text-[#1f2025] text-2xl sm:text-3xl text-center mb-2">🎯 Pädagogischer Mehrwert</h2>
      <p class="text-center text-[#374151] mb-10">Was Kinder bei der Zaubershow lernen:</p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {paedagogisch.map(p => (
          <div class="bg-gray-50 rounded-xl p-5 text-center">
            <p class="text-3xl mb-2">{p.icon}</p>
            <p class="font-bold text-[#1f2025] text-sm mb-1">{p.title}</p>
            <p class="text-[#374151] text-xs">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery: Eindrücke -->
  <section class="bg-white py-12">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-bold text-[#1f2025] text-2xl text-center mb-8">📸 Eindrücke</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <Image src={kitaEssenImg} alt="Lachende Kinder bei Kinderzauberer Kindergarten Essen" class="w-full object-cover rounded-xl shadow-sm" style="height:280px;object-position:top" loading="lazy" widths={[300, 500]} sizes="(max-width: 768px) 50vw, 25vw" />
        <Image src={geburtstagKitaImg} alt="Kinder lachen im Kindergarten bei LIARs Zaubershow" class="w-full object-cover rounded-xl shadow-sm" style="height:280px;object-position:top" loading="lazy" widths={[300, 500]} sizes="(max-width: 768px) 50vw, 25vw" />
        <Image src={galerieImg2} alt="Zaubershow für Kindergarten" class="w-full object-cover rounded-xl shadow-sm" style="height:280px;object-position:top" loading="lazy" widths={[300, 500]} sizes="(max-width: 768px) 50vw, 25vw" />
        <Image src={kindergartenGelsenkirchenImg} alt="Kinderzauberer Kindergarten Gelsenkirchen" class="w-full object-cover rounded-xl shadow-sm" style="height:280px;object-position:top" loading="lazy" widths={[300, 500]} sizes="(max-width: 768px) 50vw, 25vw" />
      </div>
    </div>
  </section>

  <!-- Praktische Details -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-bold text-[#1f2025] text-2xl sm:text-3xl text-center mb-10">📋 Praktische Details für Kitas</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#d7393e]">
          <h3 class="font-bold text-[#1f2025] mb-4">📐 Platzbedarf & Räume</h3>
          <p class="text-[#374151] text-sm mb-3">Minimaler Platzbedarf: <strong>2×2 Meter</strong> (ideal 3×3 Meter)</p>
          <p class="font-semibold text-[#1f2025] text-sm mb-2">Geeignete Räume:</p>
          <ul class="text-[#374151] text-sm space-y-1">
            <li>✓ Turnraum / Bewegungsraum (optimal!)</li>
            <li>✓ Mehrzweckraum</li>
            <li>✓ Großer Gruppenraum</li>
            <li>✓ Außenbereich (überdacht)</li>
          </ul>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#3b55d5]">
          <h3 class="font-bold text-[#1f2025] mb-4">👶 Gruppengrößen</h3>
          <ul class="text-[#374151] text-sm space-y-2">
            <li><strong>Ideal: 20–60 Kinder</strong><br />Perfekte Größe für intensive Interaktion</li>
            <li><strong>Möglich: 60–100 Kinder</strong><br />Show bleibt effektiv</li>
            <li><strong>Auch möglich: 100+ Kinder</strong><br />Bitte anfragen</li>
            <li><strong>Kleine Gruppen: 10–20 Kinder</strong><br />Auch buchbar!</li>
          </ul>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#ffb546]">
          <h3 class="font-bold text-[#1f2025] mb-4">⏱️ Showdauer</h3>
          <ul class="text-[#374151] text-sm space-y-2">
            <li><strong>Kurze Show: 25–30 Min.</strong><br />Für jüngere Kinder (3–4 Jahre)</li>
            <li><strong>Standard-Show: 35–40 Min.</strong><br />Ideal für gemischte Altersgruppen</li>
            <li><strong>Lange Show: 45 Min.</strong><br />Für ältere Kinder oder besondere Anlässe</li>
          </ul>
          <p class="text-[#374151] text-xs mt-3 italic">Technik: Fast keine! Kein Strom, kein Mikrofon (normal), keine Bühne nötig.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Video Sektion -->
  <!-- Wave oben (weiß → blau) -->
  <div style="overflow:hidden;line-height:0;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>
  <section class="py-14 bg-[#3b55d5]">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-white font-extrabold text-xl uppercase tracking-widest mb-6">
        SCHNELLE EINDRÜCKE
      </h2>
      <div class="relative w-full max-w-2xl mx-auto mb-8" style="padding-bottom: 56.25%; position: relative;">
        <iframe
          src="https://www.youtube.com/embed/Cop0SqRIX4Y"
          title="Clown Zauberer für Geburtstag, Feier, Veranstaltung in NRW : die lustigste Zaubershow im Pott!"
          class="absolute inset-0 w-full h-full rounded-lg"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
      <h3 class="text-white font-bold text-xl mb-6">
        Mehr Fotos und Videos in der Galerie
      </h3>
      <a
        href="/galerie/"
        class="inline-block bg-[#f5a623] hover:bg-[#e69420] text-[#1f2025] font-bold px-10 py-4 rounded-full text-base transition-colors"
      >
        Zur Foto- und Videogalerie
      </a>
    </div>
  </section>
  <!-- Wave unten (blau → weiß) -->
  <div style="overflow:hidden;line-height:0;background:#3b55d5;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>



  <!-- Einsatzgebiet -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-[#d7393e] font-bold text-2xl text-center mb-8">Zaubershow für Kindergärten in ganz NRW</h2>
      <p class="text-[#374151] text-center mb-8">Als erfahrener Kinderzauberer bin ich in ganz Nordrhein-Westfalen für Kindergärten und Kitas buchbar.</p>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        <div>
          <h3 class="font-bold text-[#1f2025] mb-3">Ruhrgebiet</h3>
          <p class="text-[#374151] text-sm leading-relaxed mb-4">Oberhausen, Essen, Duisburg, Mülheim, Gelsenkirchen, Bochum, Dortmund, Bottrop, Gladbeck, Herten, Herne, Marl, Recklinghausen, Castrop-Rauxel, Waltrop</p>
          <h3 class="font-bold text-[#1f2025] mb-3">Rheinland</h3>
          <p class="text-[#374151] text-sm leading-relaxed mb-4">Düsseldorf, Krefeld, Moers, Neuss, Köln, Leverkusen, Mönchengladbach</p>
          <h3 class="font-bold text-[#1f2025] mb-3">Münsterland</h3>
          <p class="text-[#374151] text-sm leading-relaxed mb-4">Münster, Haltern am See, Dorsten, Coesfeld, Dülmen</p>
          <h3 class="font-bold text-[#1f2025] mb-3">Weitere Städte</h3>
          <p class="text-[#374151] text-sm leading-relaxed">Ahaus, Reken, Lünen, Hagen, Witten und viele mehr</p>
          <p class="text-[#374151] text-sm mt-2">🌍 Auf Anfrage auch deutschlandweit sowie in Belgien, Niederlande, Frankreich, Österreich und der Schweiz buchbar!</p>
        </div>
        <div>
          <Image
            src={karteImg}
            alt="Wohnort Clown Zauberer LIAR"
            class="rounded-xl shadow-sm w-full max-w-md"
            loading="lazy"
            widths={[400, 800]}
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#1f2025] py-14 text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-bold text-2xl sm:text-3xl mb-4">🎪 Jetzt anfragen für Ihren Kindergarten!</h2>
      <p class="text-gray-300 mb-6">Ob Sommerfest, Abschiedsfeier oder Projektwoche – lassen Sie uns gemeinsam ein unvergessliches Erlebnis für Ihre Kinder schaffen! Ich trete auch bei <a href="/zauberer/zaubershow/schule/" class="text-white hover:underline font-semibold">Schulveranstaltungen</a> und <a href="/zauberer/zaubershow/strassen-sommer-fest/" class="text-white hover:underline font-semibold">Straßen- und Sommerfesten</a> auf.</p>
      <div class="space-y-2 text-gray-300 mb-8">
        <p>📱 Telefon &amp; WhatsApp: <a href="tel:+491721517578" class="text-white hover:underline font-semibold">0172-1517578</a></p>
        <p>✉️ E-Mail: <a href="mailto:info@liar-entertainer.com" class="text-white hover:underline">info@liar-entertainer.com</a></p>
        <p>⚡ Schnelle Antwort: Meist innerhalb 24 Stunden</p>
        <p class="text-yellow-300">💡 Tipp: Sommerfest-Termine sind schnell ausgebucht – frühzeitig anfragen lohnt sich!</p>
      </div>
      <a href="/kontakt/" class="inline-block bg-[#d7393e] hover:bg-[#b62e32] text-white font-bold px-10 py-4 rounded transition-colors">
        Jetzt unverbindlich anfragen
      </a>
    </div>
  </section>

</BaseLayout>
