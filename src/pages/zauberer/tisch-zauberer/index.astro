---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GoogleReviews from '../../../components/GoogleReviews.astro';
import { Image } from 'astro:assets';
import heroImg from '../../../assets/images/zauberer/tisch-zauberei-hero.jpg';
import tischMuelheimImg from '../../../assets/images/galerie/tisch-zauberer-muelheim.jpg';
import tischNrwImg from '../../../assets/images/galerie/tisch-zauberer-nrw.jpg';
import closeUpDortmundImg from '../../../assets/images/galerie/close-up-zauberei-dortmund.jpg';
import closeUpMuelheimImg from '../../../assets/images/galerie/close-up-zauberei-muelheim.jpg';
import closeUpDuesseldorfImg from '../../../assets/images/zauberer/close-up-zauberei-duesseldorf.jpg';

const seoTitle = 'Tischzauberer NRW | Close-up Magie | LIAR';
const seoDescription = 'Tisch Zauberer LIAR in NRW ✓ Close-up Magie für Hochzeit, Firmenevent & Geburtstag ✓ 400+ Top-Bewertungen ✓ Elegant & niveauvoll ✓ Jetzt unverbindlich anfragen!';

const ablauf = [
  { step: '1', title: 'Ankommen bei der Gruppe', text: 'Mit einem charmanten „Darf ich Ihnen etwas Magisches zeigen?" stelle ich mich vor.' },
  { step: '2', title: '5-10 Minuten Zauberkunst', text: 'Eine Abfolge verblüffender Tricks – Karten, Münzen, Mentalmagie. Alles direkt vor ihren Augen.' },
  { step: '3', title: 'Persönliche Interaktion', text: 'Gäste werden einbezogen, dürfen Karten ziehen, Gegenstände prüfen. Jeder wird Teil der Magie.' },
  { step: '4', title: 'Weiter zur nächsten Gruppe', text: 'Nach 8-10 Minuten ziehe ich weiter. Die Gruppe bleibt staunend zurück – mit Gesprächsstoff für den Rest des Abends.' },
];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Tischzauberer NRW, Close-up Zauberer, Tischzauberei Hochzeit, Close-up Zauberei buchen, Tischzauberer Event"
  canonical="https://liar-entertainer.com/zauberer/tisch-zauberer/"
  breadcrumbs={[{ name: 'Startseite', url: '/' }, { name: 'Zauberer', url: '/zauberer/' }, { name: 'Tisch Zauberer', url: '/zauberer/tisch-zauberer/' }]}
>

  <!-- Page Title -->
  <section class="bg-white pt-8 pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <p class="text-sm text-[#595959] mb-4">
        <a href="/" class="hover:text-[#d7393e]">Clown</a> »
        <a href="/zauberer/" class="hover:text-[#d7393e]">Zauberer</a> »
        <span>Tisch Zauberer</span>
      </p>
      <h1 class="font-black text-[#1f2025] text-3xl sm:text-5xl mb-6">Tisch Zauberer</h1>
    </div>
  </section>

  <!-- Hero -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <Image
      src={heroImg}
      alt="Tischzauberer NRW – Close-up Zauberei für Hochzeiten & Events"
      class="absolute inset-0 w-full h-full object-cover object-top"
      style="object-position: 99% 61%"
      loading="eager"
      fetchpriority="high"
      widths={[600, 900, 1200]}
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex items-center justify-center" style="min-height: 600px;">
      <div class="text-center px-6">
        <h2 class="text-white font-bold leading-tight mb-4" style="font-size: clamp(1.6rem, 4vw, 3rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
          Tischzauberer &amp; Close-up Zauberei in NRW
        </h2>
        <p class="text-white/90 text-lg font-medium">Magie zum Greifen nah – Direkt an den Tischen Ihrer Gäste</p>
      </div>
    </div>
  </section>

  <!-- Intro / Eckdaten -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <p class="text-[#374151] leading-relaxed mb-6">
            Erleben Sie Zauberkunst in ihrer intimsten Form. Als professioneller Tischzauberer bringe ich die Magie direkt zu Ihren Gästen – verblüffend nah, persönlich und unvergesslich. Perfekt für Hochzeiten, Empfänge und Dinner-Events. Wenn Sie lieber eine Show vor großem Publikum wünschen, schauen Sie sich meine <a href="/zauberer/buehnen-zauberer/" class="text-[#d7393e] hover:underline">Bühnenzauberei</a> an.
          </p>
          <ul class="space-y-3 text-[#374151]">
            <li class="flex items-center gap-3"><span class="text-[#d7393e] font-bold">✓</span> 2–4 Stunden flexibler Einsatz</li>
            <li class="flex items-center gap-3"><span class="text-[#d7393e] font-bold">✓</span> Kleine Gruppen (3–8 Personen)</li>
            <li class="flex items-center gap-3"><span class="text-[#d7393e] font-bold">✓</span> 300+ TOP-Bewertungen ⭐⭐⭐⭐⭐</li>
            <li class="flex items-center gap-3"><span class="text-[#d7393e] font-bold">✓</span> Französischer Charme</li>
            <li class="flex items-center gap-3"><span class="text-[#d7393e] font-bold">✓</span> Kein Platzbedarf – Ich komme zu den Tischen</li>
          </ul>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="font-bold text-[#1f2025] mb-4">📊 Eckdaten</h3>
          <dl class="space-y-3 text-sm">
            {[
              ['Einsatzzeit', '2–4 Stunden (flexibel buchbar)'],
              ['Pro Gruppe', '5–10 Minuten Zauberkunst'],
              ['Gruppengröße', '3–8 Personen'],
              ['Format', 'Walk Around (zwischen Tischen)'],
              ['Platzbedarf', 'Keiner! Ich komme zu den Gästen'],
              ['Techn. Aufwand', 'Keiner (keine Bühne, kein Mikrofon)'],
            ].map(([k, v]) => (
              <div class="flex gap-4">
                <dt class="font-semibold text-[#1f2025] w-28 flex-shrink-0">{k}:</dt>
                <dd class="text-[#374151]">{v}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>
  </section>

  <GoogleReviews />

  <!-- Was ist Close-up Zauberei? -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-bold text-[#1f2025] text-2xl sm:text-3xl text-center mb-8">Was ist Close-up Zauberei?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { icon: '👁️', title: 'Zum Greifen nah', text: 'Die Magie geschieht direkt vor den Augen Ihrer Gäste – in Griffweite. Karten, Münzen, Ringe und Alltagsgegenstände werden zu Zauberwerkzeugen.' },
          { icon: '🤝', title: 'Persönlich & Intim', text: 'Keine anonyme Show vor großem Publikum. Ich trete mit jeder Gruppe in direkten Kontakt und schaffe persönliche, magische Momente.' },
          { icon: '🔄', title: 'Flexibel & Organisch', text: 'Keine feste Show zu fester Zeit. Ich bewege mich während Ihres Events zwischen den Gruppen und füge mich organisch in den Ablauf ein.' },
          { icon: '🇫🇷', title: 'Französischer Charme', text: 'Als gebürtiger Franzose bringe ich eine besondere Note – charmant, eloquent und mit einer Prise Pariser Flair.' },
        ].map((item, i) => (
          <div class={`bg-white rounded-xl p-6 shadow-sm border-t-4 ${['border-[#d7393e]','border-[#3b55d5]','border-[#ffb546]'][i % 3]}`}>
            <p class="text-3xl mb-3">{item.icon}</p>
            <h3 class="font-bold text-[#1f2025] mb-2">{item.title}</h3>
            <p class="text-[#374151] text-sm leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Ablauf -->
  <section class="bg-white py-14">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-bold text-[#1f2025] text-2xl sm:text-3xl text-center mb-10">🎭 Typischer Ablauf</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {ablauf.map(step => (
          <div class="flex gap-4 items-start bg-gray-50 rounded-xl p-6">
            <div class="w-10 h-10 rounded-full bg-[#d7393e] text-white font-bold flex items-center justify-center flex-shrink-0">
              {step.step}
            </div>
            <div>
              <h3 class="font-bold text-[#1f2025] mb-1">{step.title}</h3>
              <p class="text-[#374151] text-sm leading-relaxed">{step.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery: Schnelle Eindrücke -->
  <section class="bg-white py-12">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-bold text-[#1f2025] text-2xl text-center mb-4">📸 Schnelle Eindrücke</h2>
      <p class="text-[#374151] text-center mb-8">Noch mehr Eindrücke gibt es in der <a href="/galerie/" class="text-[#d7393e] hover:underline">Foto- und Videogalerie</a>.</p>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        <Image src={tischMuelheimImg} alt="Tisch Zauberer Mülheim – die Sparkasse empfängt Zauberkünstler LIAR" class="w-full object-cover rounded-xl shadow-sm" style="height:280px;object-position:top" loading="lazy" widths={[300, 500]} sizes="(max-width: 768px) 50vw, 20vw" />
        <Image src={tischNrwImg} alt="Tisch Zauberer NRW" class="w-full object-cover rounded-xl shadow-sm" style="height:280px;object-position:top" loading="lazy" widths={[300, 500]} sizes="(max-width: 768px) 50vw, 20vw" />
        <Image src={closeUpDortmundImg} alt="Close Up Zauberei Dortmund" class="w-full object-cover rounded-xl shadow-sm" style="height:280px;object-position:top" loading="lazy" widths={[300, 500]} sizes="(max-width: 768px) 50vw, 20vw" />
        <Image src={closeUpMuelheimImg} alt="Close Up Zauberei Mülheim" class="w-full object-cover rounded-xl shadow-sm" style="height:280px;object-position:top" loading="lazy" widths={[300, 500]} sizes="(max-width: 768px) 50vw, 20vw" />
        <Image src={closeUpDuesseldorfImg} alt="Close Up Zauberei bei Firmenevent in Düsseldorf" class="w-full object-cover rounded-xl shadow-sm" style="height:280px;object-position:top" loading="lazy" widths={[300, 500]} sizes="(max-width: 768px) 50vw, 20vw" />
      </div>
    </div>
  </section>

  <!-- Wave white → blue -->
  <div style="overflow:hidden;line-height:0;background:white;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>

  <!-- Wann Close-up? (blue) -->
  <section class="bg-[#3b55d5] py-14 text-white">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-bold text-2xl sm:text-3xl text-center mb-10">Wann Close-up wählen?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white/10 rounded-xl p-8">
          <h3 class="font-bold text-xl mb-4 text-[#ffb546]">✅ Perfekt für Close-up Zauberei:</h3>
          <ul class="space-y-2 text-white text-sm">
            {['Hochzeiten (DER Klassiker!)', 'Empfänge (Sekt, Cocktail)', 'Dinner-Events (Gala, Business)', 'Gäste sitzen/stehen in Gruppen', 'Kein fixes Showprogramm gewünscht', 'Intimate, persönliche Atmosphäre', 'Flexibilität wichtig', 'Events über mehrere Stunden'].map(i => (
              <li class="flex items-center gap-2"><span class="text-[#ffb546]">✓</span>{i}</li>
            ))}
          </ul>
        </div>
        <div class="bg-white/10 rounded-xl p-8">
          <h3 class="font-bold text-xl mb-4 text-[#ffb546]">✅ Perfekt für Bühnenshow:</h3>
          <ul class="space-y-2 text-white text-sm">
            {['Betriebsfeiern mit Programm', 'Galas mit Show-Teil', 'Große Geburtstage (50+)', 'Alle sollen gleichzeitig unterhalten werden', 'Fester Programmpunkt gewünscht', 'Show-Charakter', 'Bühne vorhanden', '10–150 Gäste'].map(i => (
              <li class="flex items-center gap-2"><span class="text-[#ffb546]">✓</span>{i}</li>
            ))}
          </ul>
          <p class="text-white text-sm mt-4 italic">💡 Tipp: Bei vielen Events ist auch eine Kombination möglich! Bühnenshow (30 Min.) + Close-up während Dinner (2h)</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave blue → white -->
  <div style="overflow:hidden;line-height:0;background:#3b55d5;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- Buchungsprozess -->
  <section class="bg-white py-14">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-bold text-[#1f2025] text-2xl text-center mb-10">So buchen Sie</h2>
      <div class="grid grid-cols-1 sm:grid-cols-5 gap-4">
        {[
          { n: '1', t: 'Kontakt', d: 'Anrufen oder E-Mail schreiben' },
          { n: '2', t: 'Beratung', d: 'Wir besprechen Ihr Event, Gäste-Anzahl & Wünsche' },
          { n: '3', t: 'Angebot', d: 'Individuelles, unverbindliches Angebot innerhalb 24h' },
          { n: '4', t: 'Bestätigung', d: 'Buchungsbestätigung mit allen Details' },
          { n: '5', t: 'Ihr Event', d: 'Ich komme pünktlich und sorge für magische Momente!' },
        ].map(step => (
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-[#d7393e] text-white font-bold text-xl flex items-center justify-center mx-auto mb-3">{step.n}</div>
            <p class="font-bold text-[#1f2025] text-sm mb-1">{step.t}</p>
            <p class="text-[#374151] text-xs">{step.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Einsatzgebiet -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-[#d7393e] font-bold text-2xl text-center mb-8">Wo bin ich als Tischzauberer buchbar?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h3 class="font-bold text-[#1f2025] mb-3">🏙️ Haupteinsatzgebiet: Nordrhein-Westfalen</h3>
          <p class="text-[#374151] text-sm leading-relaxed mb-4">
            Essen • Düsseldorf • Dortmund • Köln • Duisburg • Oberhausen • Gelsenkirchen • Bochum • Gladbeck • Mülheim an der Ruhr • Herne • Marl • Dorsten • Herten • Recklinghausen • Krefeld • Moers • Münster • Hagen • Lünen • Bottrop • Castrop-Rauxel • Wuppertal • Ahaus • Reken
          </p>
          <h3 class="font-bold text-[#1f2025] mb-2">🌍 Überregional & International</h3>
          <p class="text-[#374151] text-sm">Deutschland: Gesamtes Bundesgebiet<br />International: Frankreich, Belgien, Niederlande, Österreich, Schweiz</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#d7393e]">
          <h3 class="font-bold text-[#1f2025] mb-4">📞 Direkt anfragen</h3>
          <div class="space-y-3 text-[#374151]">
            <p>📱 Telefon & WhatsApp: <a href="tel:+491721517578" class="text-[#d7393e] hover:underline font-semibold">0172-1517578</a></p>
            <p>✉️ E-Mail: <a href="mailto:info@liar-entertainer.com" class="text-[#d7393e] hover:underline">info@liar-entertainer.com</a></p>
            <p>📍 Standort: Beethovenstr. 15, 45966 Gladbeck</p>
            <p>⚡ Reaktionszeit: Meist innerhalb 24 Stunden</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#1f2025] py-14 text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-bold text-2xl sm:text-3xl mb-4">✨ Jetzt Tischzauberer buchen!</h2>
      <p class="text-gray-300 mb-8">Zauberei zum Greifen nah – für Ihre Hochzeit, Ihr Dinner-Event oder Ihren Empfang. Kombinieren Sie die Tischzauberei mit einer <a href="/zauberer/buehnen-zauberer/" class="text-white hover:underline font-semibold">Bühnenshow</a> für das perfekte Gesamtpaket. Weitere Eindrücke finden Sie in meiner <a href="/galerie/" class="text-white hover:underline font-semibold">Galerie</a>.</p>
      <a href="/kontakt/" class="inline-block bg-[#d7393e] hover:bg-[#b62e32] text-white font-bold px-10 py-4 rounded transition-colors">
        Jetzt unverbindlich anfragen
      </a>
    </div>
  </section>

</BaseLayout>
