---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GoogleReviews from '../../components/GoogleReviews.astro';
import postsData from '../../data/posts.json';

type WPPost = {
  title: string;
  slug: string;
  type: string;
  date: string;
  link: string;
  content: string;
  excerpt: string;
  meta: Record<string, string | undefined>;
};

const posts = (postsData as WPPost[]).sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

function getFirstImage(content: string): string {
  const m = content.match(
    /https?:\/\/liar-entertainer\.com\/wp-content\/uploads\/[^\s"'<>)]+\.(jpg|jpeg|png|webp)/i
  );
  return m ? m[0] : 'https://liar-entertainer.com/wp-content/uploads/2023/08/Clown-Zauberer-mit-Zaubershow.jpg';
}

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' });
}

function getExcerpt(text: string, max = 120): string {
  const clean = text.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
  return clean.length > max ? clean.slice(0, max) + '...' : clean;
}
---

<BaseLayout
  title="Blog | Clown Zauberer LIAR — Aktuelles & Events"
  description="Neuigkeiten vom Clown Zauberer LIAR ✓ Berichte von Shows, Festen & Events in NRW ✓ Tipps für die perfekte Kinderparty ✓ Fotos & Erfahrungsberichte"
  keywords="Clown Zauberer Blog, Zauberer Tipps, Kindergeburtstag Tipps, Clown NRW News"
  canonical="https://liar-entertainer.com/blog/"
>
  <section class="py-12 bg-[#f4f4f4]">
    <div class="max-w-[960px] mx-auto px-4">
      <h1 class="text-[#1f2025] font-extrabold text-3xl text-center mb-2">Blog</h1>
      <p class="text-[#595959] text-center mb-4">Aktuelles von Clown Zauberer LIAR</p>
      <p class="text-[#374151] text-center text-sm mb-4">Hier berichte ich über meine Auftritte, Tipps und Neuigkeiten rund um Zaubershow und Kinderunterhaltung. <a href="/ueber-mich/" class="text-[#d7393e] hover:underline">Mehr über mich erfahren</a>.</p>
      <div class="flex flex-wrap justify-center gap-3 mb-10">
        <a href="/clown/clownshow/" class="bg-white px-4 py-2 rounded-full text-sm text-[#d7393e] hover:underline font-medium shadow-sm">🤡 Clownshow</a>
        <a href="/zauberer/" class="bg-white px-4 py-2 rounded-full text-sm text-[#3b55d5] hover:underline font-medium shadow-sm">🎩 Zauberer</a>
        <a href="/kinderzauberer/" class="bg-white px-4 py-2 rounded-full text-sm text-[#d7393e] hover:underline font-medium shadow-sm">✨ Kinderzauberer</a>
        <a href="/kindergeburtstag/" class="bg-white px-4 py-2 rounded-full text-sm text-[#3b55d5] hover:underline font-medium shadow-sm">🎂 Kindergeburtstag</a>
        <a href="/zauberer/zaubershow/" class="bg-white px-4 py-2 rounded-full text-sm text-[#d7393e] hover:underline font-medium shadow-sm">🪄 Zaubershow</a>
        <a href="/galerie/" class="bg-white px-4 py-2 rounded-full text-sm text-[#3b55d5] hover:underline font-medium shadow-sm">📸 Galerie</a>
      </div>

      <GoogleReviews />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post, i) => {
          const url = new URL(post.link);
          const href = url.pathname.endsWith('/') ? url.pathname : url.pathname + '/';
          const img = getFirstImage(post.content);
          const excerpt = post.excerpt
            ? getExcerpt(post.excerpt)
            : getExcerpt(post.content);
          return (
            <article class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
              <a href={href}>
                <img
                  src={img}
                  alt={post.title}
                  class="w-full object-cover object-top"
                  loading={i < 3 ? 'eager' : 'lazy'}
                  width="400"
                  height="192"
                />
              </a>
              <div class="p-5">
                <time class="text-[#595959] text-xs">{formatDate(post.date)}</time>
                <h2 class="font-bold text-[#1f2025] text-base mt-1 mb-2 leading-snug">
                  <a href={href} class="hover:text-[#d7393e] transition-colors">
                    {post.title}
                  </a>
                </h2>
                <p class="text-[#374151] text-sm leading-relaxed mb-3">{excerpt}</p>
                <a href={href} class="text-[#d7393e] text-sm font-semibold hover:underline">
                  Weiterlesen →
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
