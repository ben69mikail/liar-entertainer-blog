---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getAllBlogPosts, getAllCategories, catToSlug } from '../../../utils/allPosts';

export async function getStaticPaths() {
  const cats = await getAllCategories();
  const allPosts = await getAllBlogPosts();
  return cats.map((c) => ({
    params: { category: c.slug },
    props: {
      categoryName: c.name,
      posts: allPosts.filter((p) =>
        p.categories.some((pc) => catToSlug(pc) === c.slug),
      ),
    },
  }));
}

interface PostSummary {
  slug: string;
  href: string;
  title: string;
  date: Date;
  excerpt: string;
  image: string;
  categories: string[];
}

const { categoryName, posts } = Astro.props as {
  categoryName: string;
  posts: PostSummary[];
};

function formatDate(d: Date) {
  return d.toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' });
}

const canonicalSlug = catToSlug(categoryName);
---

<BaseLayout
  title={`${categoryName} | Blog | Clown Zauberer LIAR`}
  description={`Alle Blog-Artikel zur Kategorie ${categoryName} vom Clown Zauberer LIAR. Berichte, Tipps und Neuigkeiten rund um Kindergeburtstag, Zauberei und Events in NRW.`}
  canonical={`https://liar-entertainer.com/blog/kategorie/${canonicalSlug}/`}
>
  <section class="py-12 bg-[#f4f4f4]">
    <div class="max-w-[960px] mx-auto px-4">
      <nav class="text-sm text-[#595959] mb-4">
        <a href="/blog/" class="text-[#d7393e] hover:underline">← Blog</a>
        <span class="mx-2">/</span>
        <span>{categoryName}</span>
      </nav>

      <h1 class="text-[#1f2025] font-extrabold text-3xl text-center mb-2">{categoryName}</h1>
      <p class="text-[#595959] text-center text-sm mb-10">
        {posts.length} {posts.length === 1 ? 'Artikel' : 'Artikel'} in dieser Kategorie
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post, i) => (
          <article class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
            <a href={post.href}>
              <img
                src={post.image}
                alt={post.title}
                class="w-full object-cover object-top"
                loading={i < 3 ? 'eager' : 'lazy'}
                decoding="async"
                width="400"
                height="240"
                style="aspect-ratio: 5/3"
              />
            </a>
            <div class="p-5">
              <time class="text-[#595959] text-xs">{formatDate(post.date)}</time>
              <h2 class="font-bold text-[#1f2025] text-base mt-1 mb-2 leading-snug">
                <a href={post.href} class="hover:text-[#d7393e] transition-colors">
                  {post.title}
                </a>
              </h2>
              <p class="text-[#374151] text-sm leading-relaxed mb-3">{post.excerpt}</p>
              <a href={post.href} class="text-[#d7393e] text-sm font-semibold hover:underline">
                Weiterlesen →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
