---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GoogleReviews from '../../components/GoogleReviews.astro';
import BlogFooter from '../../components/BlogFooter.astro';
import postsData from '../../data/posts.json';
import { generateHeroWithOverlay } from '../../utils/heroOverlay';
import { catToSlug } from '../../utils/allPosts';

type WPPost = { slug: string };

export async function getStaticPaths() {
  const wpSlugs = new Set((postsData as WPPost[]).map((p) => p.slug));
  const entries = await getCollection('blog');
  return entries
    .filter((e) => !e.data.draft && !wpSlugs.has(String(e.id)))
    .map((e) => ({ params: { slug: String(e.id) }, props: { entry: e } }));
}

const { entry } = Astro.props as {
  entry: Awaited<ReturnType<typeof getCollection<'blog'>>>[number];
};
const { Content } = await render(entry);

const slug = String(entry.id);
const dateLabel = new Date(entry.data.publishDate).toLocaleDateString('de-DE', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
const isoDate = entry.data.publishDate.toISOString();
const canonical = `https://liar-entertainer.com/blog/${slug}/`;
const desc = entry.data.description ?? entry.data.title;

// Hero-Image mit Title-Overlay (build-time via sharp, OG-Image-Standard 1200x630)
const heroDisplayUrl = entry.data.heroImage
  ? await generateHeroWithOverlay(entry.data.heroImage, entry.data.title, slug)
  : undefined;
const heroAbsolute = heroDisplayUrl?.startsWith('/')
  ? `https://liar-entertainer.com${heroDisplayUrl}`
  : heroDisplayUrl;
const ogImage = heroAbsolute ?? entry.data.heroImage ?? undefined;

// Article schema.org structured data (matching style of legacy blog posts)
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: desc,
  image: ogImage,
  author: { '@type': 'Person', name: entry.data.author || 'Michaël Prescler' },
  publisher: {
    '@type': 'Organization',
    name: 'Clown Zauberer LIAR',
    url: 'https://liar-entertainer.com',
  },
  datePublished: isoDate,
  dateModified: isoDate,
};
---

<BaseLayout
  title={`${entry.data.title} | Clown Zauberer LIAR`}
  description={desc}
  canonical={canonical}
  ogImage={ogImage}
  heroPreload={heroDisplayUrl}
  structuredData={articleSchema}
>
  {/* Breadcrumb-Header — wie auf den Legacy-Blog-Artikeln */}
  <section class="bg-white pt-8 pb-2">
    <div class="max-w-[750px] mx-auto px-4">
      <nav class="text-sm text-[#595959] mb-4">
        <a href="/" class="text-[#d7393e] hover:underline">Clown</a>
        <span class="mx-1">»</span>
        <a href="/blog/" class="text-[#d7393e] hover:underline">Blog</a>
        <span class="mx-1">»</span>
        <span>{entry.data.title}</span>
      </nav>
      <h1 class="text-[#1f2025] font-extrabold text-3xl sm:text-4xl leading-tight mb-3">
        {entry.data.title}
      </h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-[#595959] mb-6 pb-4 border-b border-gray-100">
        <time datetime={isoDate}>{dateLabel}</time>
        {entry.data.author && <span>· von {entry.data.author}</span>}
        {entry.data.categories.length > 0 && (
          <span class="flex flex-wrap gap-1">
            {entry.data.categories.map((c) => (
              <a
                href={`/blog/kategorie/${catToSlug(c)}/`}
                class="bg-[#f4f4f4] hover:bg-[#d7393e] hover:text-white text-[#555] px-2 py-0.5 rounded text-xs transition-colors"
              >
                {c}
              </a>
            ))}
          </span>
        )}
      </div>
    </div>
  </section>

  {/* Service-Schnellzugriff — wie auf den Legacy-Blog-Artikeln */}
  <section class="py-10 bg-[#f9fafb]">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="text-[#595959] font-bold text-sm uppercase tracking-widest mb-4">Unsere Leistungen</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/clown/clownshow/" class="bg-white px-5 py-3 rounded-lg shadow-sm text-[#d7393e] hover:underline font-medium text-sm">🤡 Clownshow</a>
        <a href="/zauberer/" class="bg-white px-5 py-3 rounded-lg shadow-sm text-[#3b55d5] hover:underline font-medium text-sm">🎩 Zauberer</a>
        <a href="/kinderzauberer/" class="bg-white px-5 py-3 rounded-lg shadow-sm text-[#d7393e] hover:underline font-medium text-sm">✨ Kinderzauberer</a>
        <a href="/kindergeburtstag/" class="bg-white px-5 py-3 rounded-lg shadow-sm text-[#3b55d5] hover:underline font-medium text-sm">🎂 Kindergeburtstag</a>
        <a href="/zauberer/zaubershow/" class="bg-white px-5 py-3 rounded-lg shadow-sm text-[#d7393e] hover:underline font-medium text-sm">🪄 Zaubershow</a>
        <a href="/galerie/" class="bg-white px-5 py-3 rounded-lg shadow-sm text-[#3b55d5] hover:underline font-medium text-sm">📸 Galerie</a>
      </div>
    </div>
  </section>

  {/* Hero-Image (Cover mit Title-Overlay aus sharp/build-time) */}
  {heroDisplayUrl && (
    <section class="bg-white pt-6">
      <div class="max-w-[750px] mx-auto px-4">
        <img
          src={heroDisplayUrl}
          alt={entry.data.heroImageAlt ?? entry.data.title}
          class="w-full rounded-lg"
          loading="eager"
          decoding="async"
          width="1200"
          height="630"
          style="aspect-ratio: 1200/630"
        />
      </div>
    </section>
  )}

  {/* Article Body — gleiche Breite + prose-Stil wie Legacy-Blog-Artikel (max-w-[750px]) */}
  <section class="bg-white pt-6 pb-12">
    <div class="max-w-[750px] mx-auto px-4">
      <article class="prose prose-lg max-w-none [&_h2]:text-[#1f2025] [&_h2]:font-bold [&_h2]:mt-10 [&_h2]:mb-4 [&_h2]:text-2xl [&_h3]:text-[#1f2025] [&_h3]:font-semibold [&_h3]:mt-6 [&_h3]:text-xl [&_a]:text-[#d7393e] [&_a]:underline hover:[&_a]:text-[#b62e32] [&_p]:leading-relaxed [&_img]:rounded-lg [&_img]:my-6 [&_img]:w-full [&_ul]:my-4 [&_li]:my-1">
        <Content />
      </article>
    </div>
  </section>

  {/* Google Reviews — wie auf Legacy-Blog-Artikeln */}
  <GoogleReviews bgColor="bg-[#f9fafb]" />

  {/* Jetzt-Buchen CTA — wie auf Legacy-Blog-Artikeln */}
  <section class="bg-white py-10 border-t border-gray-100">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-[#1f2025] font-bold text-xl mb-3">Jetzt LIAR buchen</h2>
      <p class="text-[#595959] mb-5">Unvergessliche Unterhaltung für Ihr Event – einfach und unverbindlich anfragen!</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/kontakt/" class="inline-flex items-center justify-center gap-2 bg-[#d7393e] hover:bg-[#b62e32] text-white font-bold px-8 py-3 rounded transition-colors">Kontakt aufnehmen</a>
        <a href="tel:+491721517578" class="inline-flex items-center justify-center bg-white border border-gray-200 text-[#1f2025] font-bold px-8 py-3 rounded hover:bg-gray-50 transition-colors">+49 172 1517578</a>
      </div>
    </div>
  </section>

  {/* BlogFooter (Aufgabe 3): Verwandte Artikel + Bewertungen + zusaetzliche CTAs */}
  <BlogFooter currentSlug={slug} categories={entry.data.categories} />
</BaseLayout>
