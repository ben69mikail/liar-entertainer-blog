if (scrapedContent) {
  const openDivs = (scrapedContent.match(/<div[\s>]/gi) || []).length;
  const closeDivs = (scrapedContent.match(/<\/div>/gi) || []).length;
  const unclosed = openDivs - closeDivs;
  if (unclosed > 0) {
    scrapedContent += '</div>'.repeat(unclosed);
  }
}

