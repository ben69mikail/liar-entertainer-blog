let heroTitle = '';
let heroSubtitle = '';
let heroBreadcrumbParent = { label: '', href: '' };

// Verwende Original-H1-Titel wenn vorhanden, sonst generischen Fallback
const originalTitle = originalH1[pageSlug];

if (isGeburtstagsSeite && displayCity) {
  heroTitle = originalTitle || `Geburtstag in ${displayCity}`;
  heroSubtitle = 'Unvergessliche Kindergeburtstage mit Clown Zauberer LIAR – Lachen, Staunen und pure Magie!';
  heroBreadcrumbParent = { label: 'Kindergeburtstag', href: '/kindergeburtstag/' };
} else if (pageSlug.startsWith('kinderzauberer-in-') && displayCity) {
  heroTitle = originalTitle || `Kinderzauberer in ${displayCity}`;
  heroSubtitle = `Magische Zaubershow für Kinder in ${displayCity} – Staunen, Lachen und unvergessliche Momente!`;
  heroBreadcrumbParent = { label: 'Kinderzauberer', href: '/kinderzauberer/' };
} else if (pageSlug.startsWith('clown-in-') && displayCity) {
  heroTitle = originalTitle || `Clown in ${displayCity}`;
  heroSubtitle = `Clownshow und Unterhaltung in ${displayCity} – Spaß, Lachen und gute Laune für Groß und Klein!`;
  heroBreadcrumbParent = { label: 'Clownshow', href: '/clown/clownshow/' };
}

function buildKeywords(): string {
  const c = displayCity;
  if (isCityPage && c) {
    if (pageSlug.startsWith('kinderzauberer-in-')) {
      return `Kinderzauberer ${c}, Kinderzauberer in ${c}, Zauberer ${c}, Kindergeburtstag ${c}, Zaubershow ${c}, Clown ${c}, Kinderunterhaltung ${c}, NRW, Ruhrgebiet`;
    } else if (pageSlug.startsWith('geburtstag-in-')) {
      return `Kindergeburtstag ${c}, Geburtstag ${c}, Clown Kindergeburtstag ${c}, Zauberer Geburtstag ${c}, Kinderparty ${c}, Kindergeburtstag feiern ${c}, NRW, Ruhrgebiet`;
    } else if (pageSlug.startsWith('clown-in-')) {
      return `Clown ${c}, Clown in ${c}, Clownshow ${c}, Clown buchen ${c}, Zauberer ${c}, Kindergeburtstag ${c}, NRW, Ruhrgebiet`;
    }
  }
  if (isBlogPost) {
    // Blog-Posts: Focus-Keyword + Kategorien
    const cats = (page.categories || []).map((cat: {slug: string; name: string}) => cat.name);
    const parts = [focusKeyword, ...cats, 'Clown Zauberer Blog', 'NRW'].filter(Boolean);
    return [...new Set(parts)].join(', ');
  }
  // Sonstige Seiten: Focus-Keyword + allgemeine Keywords
  if (focusKeyword) {
    return `${focusKeyword}, Clown Zauberer NRW, ${focusKeyword} NRW`;
  }
  return '';
}
const pageKeywords = buildKeywords();

const schemas = [
  isCityPage && cityName ? { '@context': 'https://schema.org', '@type': 'Service', name: `Clown Zauberer in ${cityName}`, serviceType: 'Kinderunterhaltung', areaServed: { '@type': 'City', name: cityName }, provider: { '@type': 'LocalBusiness', name: 'Clown Zauberer LIAR', url: 'https://liar-entertainer.com', telephone: '+491721517578' } } : null,
  isBlogPost ? { '@context': 'https://schema.org', '@type': 'Article', headline: seoTitle, description: rawDesc, image: heroImg, author: { '@type': 'Person', name: 'Clown Zauberer LIAR' }, publisher: { '@type': 'Organization', name: 'Clown Zauberer LIAR', url: 'https://liar-entertainer.com' }, datePublished: page.date, dateModified: page.date } : null,
].filter(Boolean);
---

<BaseLayout title={seoTitle || page.title} description={rawDesc} keywords={pageKeywords || undefined} canonical={canonicalUrl} ogImage={heroImg} heroPreload={heroImg} structuredData={schemas.length > 0 ? schemas : undefined}>

{scrapedContent ? (
  <>
    {isBlogPost && (
      <section class="bg-white pt-8 pb-2">
        <div class="max-w-[750px] mx-auto px-4">
          <nav class="text-sm text-[#595959] mb-4">
            <a href="/" class="text-[#d7393e] hover:underline">Clown</a>
            <span class="mx-1">»</span>
            <a href="/blog/" class="text-[#d7393e] hover:underline">Blog</a>
            <span class="mx-1">»</span>
            <span>{page.title}</span>
          </nav>
          <h1 class="text-[#1f2025] font-extrabold text-3xl sm:text-4xl leading-tight mb-3">{page.title}</h1>
          <div class="flex flex-wrap items-center gap-3 text-sm text-[#595959] mb-6 pb-4 border-b border-gray-100">
            <time>{new Date(page.date).toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' })}</time>
            {page.categories && page.categories.length > 0 && (
              <span class="flex flex-wrap gap-1">
                {page.categories.map((c: {slug: string; name: string}) => (
                  <span class="bg-[#f4f4f4] text-[#555] px-2 py-0.5 rounded text-xs">{c.name}</span>
                ))}
              </span>
            )}
          </div>
        </div>
      </section>
    )}

    {isCityPage && displayCity && heroTitle && (
      <>
        {/* Hero-Sektion */}
        <section class="relative py-36 overflow-hidden">
          <div class="absolute inset-0 bg-cover" style={`background-image: url('${heroImg}'); background-position: center 20%;`} />
          <div class="absolute inset-0 bg-black/50" />
          <div class="relative max-w-[750px] mx-auto px-4 text-center">
            <div class="inline-flex items-center gap-2 bg-white/20 text-white rounded-full px-4 py-1.5 text-sm font-medium mb-4 backdrop-blur-sm">
              <span>📍</span> {displayCity}
            </div>
            <h1 class="text-white font-extrabold text-3xl sm:text-4xl leading-tight mb-3">{heroTitle}</h1>
            <p class="text-gray-200 text-base leading-relaxed max-w-xl mx-auto">{heroSubtitle}</p>
          </div>
        </section>
        {/* Breadcrumb */}
        <section class="bg-white pt-4 pb-0">
          <div class="max-w-6xl mx-auto px-4">
            <nav class="text-sm text-[#595959]">
              <a href="/" class="text-[#d7393e] hover:underline">Clown</a>
              <span class="mx-1">»</span>
              <a href={heroBreadcrumbParent.href} class="text-[#d7393e] hover:underline">{heroBreadcrumbParent.label}</a>
              <span class="mx-1">»</span>
              <span>{heroTitle}</span>
            </nav>
          </div>
        </section>
      </>
    )}

    <div class={`wp-scraped${isCityPage ? ' city-page' : ''}`}>
      <Fragment set:html={scrapedContent} />
    </div>

    {/* City-Page Design-System Enforcement Script */}
    {isCityPage && (
      <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
          /* ============================================================
             DESIGN SYSTEM ENFORCEMENT
             Basierend auf den Menü-Seiten (Source of Truth):
             - Max 2 farbige Sektionen pro Seite
             - Jede farbige Sektion: 60px SVG-Waves oben + unten
             - Erlaubte Farben: #d7393e (rot), #3b55d5 (blau), #1f2025 (dunkel)
             - Standard-Hintergrund: weiß oder #f9fafb (grau)
             ============================================================ */
          // === Fix 1: 2-Spalten mit langem Text + Bild: Text ab 2. H2 als volle Breite ===
          document.querySelectorAll('.has-2-columns.has-desktop-twoOne-layout, .has-2-columns.has-desktop-oneTwo-layout').forEach(section => {
            const cols = section.querySelectorAll('.wp-block-themeisle-blocks-advanced-column');
            if (cols.length < 2) return;
            let textCol = null;
            for (const col of cols) {
              if (col.querySelectorAll('h2').length >= 2) { textCol = col; break; }
            }
            if (!textCol) return;
            const h2s = textCol.querySelectorAll('h2');
            const secondH2 = h2s[1];
            const toMove = [];
            let el = secondH2;
            while (el) { toMove.push(el); el = el.nextElementSibling; }
            if (toMove.length === 0) return;
            let topSection = section;
            while (topSection.parentElement && !topSection.parentElement.classList.contains('city-page') &&
                   !topSection.parentElement.classList.contains('wp-scraped') &&
                   !topSection.parentElement.classList.contains('nv-content-wrap')) {
              topSection = topSection.parentElement;
            }
            const fullWidth = document.createElement('div');
            fullWidth.className = 'alignfull';
            fullWidth.style.cssText = 'padding: 0.75rem 0;';
            const inner = document.createElement('div');
            inner.className = 'innerblocks-wrap';
            inner.style.cssText = 'max-width: 900px; margin: 0 auto; padding: 0 1.5rem;';
            toMove.forEach(n => inner.appendChild(n));
            fullWidth.appendChild(inner);
            topSection.parentElement.insertBefore(fullWidth, topSection.nextSibling);
          });

          // === Fix 2: Gradient-Sektionen (blaues Feld) aus dem price-grid herausnehmen ===
          document.querySelectorAll('.price-grid').forEach(grid => {
            // Finde verschachtelte gradient-Sektionen innerhalb des price-grid
            grid.querySelectorAll('section').forEach(section => {
              const bg = getComputedStyle(section).backgroundImage;
              if (bg.includes('gradient') || section.querySelector('[class*="overlay"]')) {
                // Diese Section gehört nicht ins price-grid
                // Verschiebe sie nach dem price-grid als eigene volle-Breite-Sektion
                const wrapper = document.createElement('div');
                wrapper.className = 'alignfull';
                wrapper.style.cssText = section.style.cssText;
                // Übernehme den Gradient als Background
                wrapper.style.background = bg;
                wrapper.style.padding = '1rem 0';
                wrapper.style.borderRadius = '1rem';
                wrapper.style.maxWidth = '1000px';
                wrapper.style.margin = '2rem auto';

                // Verschiebe den Inhalt
                const inner = document.createElement('div');
                inner.style.cssText = 'max-width: 800px; margin: 0 auto; padding: 0 2rem; text-align: center;';
                while (section.firstChild) {
                  // Skip overlay divs
                  if (section.firstChild.classList?.contains('wp-block-themeisle-blocks-advanced-columns-overlay')) {
                    section.removeChild(section.firstChild);
                    continue;
                  }
                  inner.appendChild(section.firstChild);
                }
                wrapper.appendChild(inner);

                // Feature-Karten nebeneinander
                const featureGrid = wrapper.querySelector('.feature-highlight-grid');
                if (featureGrid) {
                  featureGrid.style.cssText = 'display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 1.5rem;';
                }

                // Einfügen nach dem price-grid-Container
                const priceParent = grid.closest('.alignfull') || grid.parentElement;
                priceParent.parentElement.insertBefore(wrapper, priceParent.nextSibling);
                section.remove();
              }
            });
          });

          // === Fix 3: Bottrop-spezifische Fixes ===
          if (location.pathname.includes('bottrop')) {
            // B1: Markiere die city-page als Bottrop
            document.querySelector('.city-page')?.classList.add('bottrop-page');

            // B1b: has-dark-bg von der Preissektion entfernen
            const darkBlueEl = document.querySelector('.dark-blue');
            if (darkBlueEl) {
              // Entferne has-dark-bg von ALLEN Elementen innerhalb dark-blue
              // AUSSER innerhalb von .bottrop-warum-blue
              darkBlueEl.querySelectorAll('.has-dark-bg').forEach(el => {
                if (!el.closest('.bottrop-warum-blue')) {
                  el.classList.remove('has-dark-bg');
                }
              });
              darkBlueEl.classList.remove('has-dark-bg');
            }

            // B1c: Preis-Überschrift explizit rot setzen
            const preisH2b = Array.from(document.querySelectorAll('h2')).find(h => h.textContent.includes('Preise für Ihren'));
            if (preisH2b) {
              preisH2b.style.setProperty('color', '#d7393e', 'important');
              // Alle Texte in der Preissektion auf dunkel
              const preisParent = preisH2b.closest('section') || preisH2b.parentElement;
              preisParent.querySelectorAll('h3, p, li, a, strong, span').forEach(el => {
                if (!el.closest('.bottrop-warum-blue') && !el.closest('.price-card')) {
                  const c = getComputedStyle(el).color;
                  if (c === 'rgb(255, 255, 255)') {
                    el.style.setProperty('color', '#1f2025', 'important');
                  }
                }
              });
            }

            // B2: Extra price-cards außerhalb des price-grid entfernen
            document.querySelectorAll('.price-card').forEach(card => {
              if (!card.closest('.price-grid')) card.remove();
            });

            // B3: "Warum Eltern" Section: explizit blauen Gradient setzen
            const warumH2 = Array.from(document.querySelectorAll('h2')).find(h => h.textContent.includes('Warum Eltern'));
            if (warumH2) {
              const warumSec = warumH2.closest('section');
              if (warumSec) {
                warumSec.classList.add('bottrop-warum-blue');
              }
            }

            // B4: Stats-Banner neu bauen und VOR "Ihre Vorteile" einfügen
            const vorteileH = Array.from(document.querySelectorAll('h2, h3')).find(h =>
              h.textContent.includes('Vorteile auf einen Blick'));
            if (vorteileH) {
              const vorteileSection = vorteileH.closest('.alignfull, section') || vorteileH.parentElement;
              // Neuen blauen Stats-Banner erstellen
              const newBanner = document.createElement('div');
              newBanner.className = 'alignfull';
              newBanner.style.cssText = 'background: linear-gradient(135deg, #3b55d5 0%, #2a3fa8 50%, #3b55d5 100%); padding: 2rem 0; text-align: center; color: #fff; margin: 0.5rem 0;';
              newBanner.innerHTML = `
                <div style="display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap; max-width: 900px; margin: 0 auto;">
                  <div style="background: rgba(255,255,255,0.15); border-radius: 12px; padding: 1.5rem 2rem; min-width: 180px;">
                    <div style="font-size: 2rem;">🪄</div>
                    <div style="font-size: 2.5rem; font-weight: 800; color: #ffb546;">400</div>
                    <div style="font-size: 0.9rem;">Shows im Jahr</div>
                  </div>
                  <div style="background: rgba(255,255,255,0.15); border-radius: 12px; padding: 1.5rem 2rem; min-width: 180px;">
                    <div style="font-size: 2rem;">😊</div>
                    <div style="font-size: 2.5rem; font-weight: 800; color: #ffb546;">110.000</div>
                    <div style="font-size: 0.9rem;">Lachende Kinder</div>
                  </div>
                  <div style="background: rgba(255,255,255,0.15); border-radius: 12px; padding: 1.5rem 2rem; min-width: 180px;">
                    <div style="font-size: 2rem;">🪄</div>
                    <div style="font-size: 2.5rem; font-weight: 800; color: #ffb546;">15</div>
                    <div style="font-size: 0.9rem;">Jahre Erfahrung</div>
                  </div>
                </div>`;
              vorteileSection.parentElement.insertBefore(newBanner, vorteileSection);
            }

            // B4b: Originale Stats-Sektion verstecken (die im roten Bereich)
            const origStats = Array.from(document.querySelectorAll('.city-page div, .city-page section')).find(el =>
              el.textContent.includes('400') && el.textContent.includes('Shows im Jahr') &&
              el.textContent.includes('110') && el.textContent.includes('Erfahrung') &&
              el.offsetHeight > 50 && el.offsetHeight < 300 && el.offsetWidth > 500 &&
              !el.querySelector('[style*="#3b55d5"]')); // Nicht den neuen Banner
            if (origStats) {
              origStats.style.setProperty('display', 'none', 'important');
            }

            // B5: ALLE roten Hintergründe weiß machen (AUSSER bottrop-warum-blue)
            document.querySelectorAll('.city-page [style*="215, 57"], .city-page [style*="d7393e"]').forEach(el => {
              if (el.closest('.bottrop-warum-blue')) return;
              el.style.setProperty('background', '#fff', 'important');
            });
          }

          // === Fix 3c: wird nach allen anderen Fixes am Ende ausgeführt (siehe unten) ===

          // === Fix 4: 2-Spalten mit Bild+Text Ungleichgewicht: Bild über Text ===
          document.querySelectorAll('.has-2-columns').forEach(section => {
            const cols = section.querySelectorAll('.wp-block-themeisle-blocks-advanced-column');
            if (cols.length < 2) return;

            let imgCol = null, textCol = null;
            for (const col of cols) {
              const hasOnlyImg = col.querySelector('figure, .wp-block-image') &&
                col.querySelectorAll('p').length <= 1;
              const textLen = col.textContent.trim().length;
              if (hasOnlyImg && textLen < 100) imgCol = col;
              else if (textLen > 400) textCol = col;
            }

            if (!imgCol || !textCol) return;

            // Messe die tatsächliche Höhe: wenn Text viel höher als Bild
            const img = imgCol.querySelector('img');
            if (!img) return;
            const imgH = img.offsetHeight || img.naturalHeight || 300;
            const textH = textCol.scrollHeight;

            // Wenn Text deutlich höher als Bild: Layout umstellen
            if (textH > imgH * 1.4) {
              section.classList.add('img-above-text');
              // Bild-Spalte VOR die Text-Spalte verschieben (oben)
              const grid = section.querySelector('.innerblocks-wrap');
              if (grid && imgCol !== grid.firstElementChild) {
                grid.insertBefore(imgCol, grid.firstElementChild);
              }
            }
          });

          // === Fix 3b: Globale Preis-Bereinigung – Extra price-cards und Preis-Hinweise entfernen ===
          // Entferne alle price-card Divs die NICHT im price-grid sind
          document.querySelectorAll('.price-card').forEach(card => {
            if (!card.closest('.price-grid')) card.remove();
          });
          // Entferne Preis-Hinweise (Fahrtkosten, Extra, etc.) die direkt nach dem price-grid stehen
          document.querySelectorAll('.price-grid').forEach(pg => {
            let el = pg.nextElementSibling;
            while (el) {
              const next = el.nextElementSibling;
              const txt = el.textContent?.trim() || '';
              // Entferne wenn es Preis/Fahrtkosten/Extra-Hinweis ist
              if (/Fahrtkosten|Extra|Ballon|Tattoo|Glitzer|Festpreis|buchbar|Wochenend|zzgl|pro Kilometer/i.test(txt) && txt.length < 500) {
                el.remove();
              } else if (el.tagName === 'P' && txt.length < 200 && /€|Euro|Preis|kosten/i.test(txt)) {
                el.remove();
              } else {
                break; // Stoppe beim ersten nicht-Preis-Element
              }
              el = next;
            }
          });

          // === Fix 3e: Banner "400 Shows / 110.000 / 15 Jahre" korrekt stylen ===
          // Suche den EXAKTEN Container der die 3 Stats enthält (kleinster Wrapper)
          const allDivs = document.querySelectorAll('.city-page div, .city-page section');
          let statsEl = null;
          for (const el of allDivs) {
            const txt = el.textContent?.trim() || '';
            if (txt.length < 1000 && txt.includes('Shows') && txt.includes('Erfahrung') &&
                (txt.includes('400') || txt.includes('Lach'))) {
              // Kleinster Container der alle 3 Stats enthält
              if (!statsEl || el.offsetHeight < statsEl.offsetHeight) {
                statsEl = el;
              }
            }
          }
          if (statsEl) {
            // Ersetze die gesamte Stats-Section durch einen sauberen Banner
            // (wie auf den Menü-Seiten: roter Hintergrund + Wave oben/unten + 3 Stat-Karten)
            const alignfullParent = statsEl.closest('.alignfull') || statsEl.closest('section') || statsEl;

            // Wave SVG oben (weiß → rot)
            const waveTop = document.createElement('div');
            waveTop.style.cssText = 'overflow:hidden;line-height:0;background:white;display:block;';
            waveTop.innerHTML = '<svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;"><path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#d7393e"/></svg>';

            // Stats-Banner
            const banner = document.createElement('div');
            banner.style.cssText = 'background:#d7393e;padding:2rem 1rem;text-align:center;';
            banner.innerHTML = `
