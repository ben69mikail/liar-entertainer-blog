              clone.style.cssText = 'max-width:400px;width:100%;height:auto;margin:1.5rem auto;display:block;border-radius:0.75rem;';
              const targetP = fH2.parentElement?.querySelector('p');
              if (targetP) targetP.after(clone);
              else fH2.after(clone);
