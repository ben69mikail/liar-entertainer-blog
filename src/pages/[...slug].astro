        let depth = 0;
        let gridEndIdx = -1;
        const searchStr = afterPreisH2.substring(gridDivStart);
        const divRegex = /<\/?div[^>]*>/gi;
        let dm;
        while ((dm = divRegex.exec(searchStr)) !== null) {
          if (dm[0].startsWith('</')) depth--;
          else depth++;
          if (depth === 0) {
            gridEndIdx = gridDivStart + dm.index + dm[0].length;
            break;
          }
        }
        if (gridEndIdx > -1) {
          const pricingBlock = afterPreisH2.substring(0, gridEndIdx);
