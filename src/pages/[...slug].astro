          const allCityEls = document.querySelectorAll('.city-page .nv-content-wrap *, .city-page .container *');
          const bcNav = document.querySelector('nav.text-sm');
          const bcBottom = bcNav ? bcNav.getBoundingClientRect().bottom : 0;
          // Finde erstes Content-Element
          let firstContentY = Infinity;
          const contentEls = document.querySelectorAll('.city-page h2, .city-page h3, .city-page p');
          for (const el of contentEls) {
            if (el.textContent?.trim()?.length > 10 && el.offsetHeight > 0) {
              const y = el.getBoundingClientRect().top;
              if (y > bcBottom && y < firstContentY) firstContentY = y;
            }
          }
          // Reduziere Padding/Margin auf allen Elementen zwischen bc und firstContent
          if (firstContentY !== Infinity && firstContentY - bcBottom > 70) {
            for (const el of allCityEls) {
              const r = el.getBoundingClientRect();
              if (r.top >= bcBottom && r.bottom <= firstContentY && r.height > 0) {
                const cs = getComputedStyle(el);
                const pt = parseFloat(cs.paddingTop);
                const mt = parseFloat(cs.marginTop);
