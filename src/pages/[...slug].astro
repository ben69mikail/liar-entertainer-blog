  _processedScraped = _processedScraped
    .replace(/mlwwlszqtwuz\.i\.optimole\.com\/w:\d+\/h:\d+\/q:mauto\/f:avif\/https:\/\/liar-entertainer\.com\/wp-content\/uploads\/2023\/08\/Clown-Zauberer-mit-Zaubershow/g,
