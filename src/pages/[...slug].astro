  const pgIdx = scrapedContent.indexOf('class="price-grid');
  if (pgIdx >= 0) {
    // Finde den Anfang des <div
    const divStart = scrapedContent.lastIndexOf('<div', pgIdx);
    // Finde das korrekte schließende </div> mit Tiefenzählung
    let depth = 0;
    let i = divStart;
    let found = false;
    while (i < scrapedContent.length) {
      const nextOpen = scrapedContent.indexOf('<div', i + 1);
      const nextClose = scrapedContent.indexOf('</div>', i + 1);
      if (nextClose < 0) break;
      if (i === divStart) { depth = 1; i = divStart + 4; continue; }
      if (nextOpen >= 0 && nextOpen < nextClose) {
        depth++;
        i = nextOpen + 4;
      } else {
        depth--;
        if (depth === 0) {
          const endIdx = nextClose + 6; // '</div>'.length
          // Ersetze den gesamten price-grid Block
          const openTag = '<div class="price-grid">';
          scrapedContent = scrapedContent.substring(0, divStart)
            + openTag + standardPriceCards + '</div>'
            + scrapedContent.substring(endIdx);
          found = true;
          break;
        }
        i = nextClose + 6;
      }
    }
  }
