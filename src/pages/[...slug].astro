              if (fImg && fH2) break;
            }
            if (fImg && fH2 && (fImg.compareDocumentPosition(fH2) & Node.DOCUMENT_POSITION_FOLLOWING)) {
              // Bild steht VOR H2 im DOM → verstecke es und clone nach H2
              const container = fImg.closest('.wp-block-image, figure, .wp-block-themeisle-blocks-advanced-column') || fImg;
