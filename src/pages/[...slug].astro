      return '';
    }
  );
  // Pattern B: wp-block-group mit "Die Preise" + "ZAUBERSHOW" (einige Seiten nutzen div statt section)
  scrapedContent = scrapedContent.replace(
    /<div[^>]*class="[^"]*wp-block-group[^"]*"[^>]*>(?:(?!<\/section>|<section)[\s\S])*?(?:Die Preise|ZAUBERSHOW)(?:(?!<\/section>|<section)[\s\S])*?(?:40 Minuten|Festpreis)[\s\S]*?(?:<\/div>\s*){2,5}/gi,
    (match) => {
      if (match.includes('price-card')) return match;
      // Nur kurze Matches (< 3000 chars) entfernen um nicht zu viel Content zu löschen
      if (match.length > 3000) return match;
