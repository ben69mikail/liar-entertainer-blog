  // Typisch: <section ...has-1-columns...>...<strong>Die Preise</strong>...<h3>ZAUBERSHOW</h3>...40 Minuten...</section>
  scrapedContent = scrapedContent.replace(
    /<section[^>]*class="[^"]*has-1-columns[^"]*"[^>]*>(?:(?!<\/section>)[\s\S])*?(?:Die Preise|ZAUBERSHOW)(?:(?!<\/section>)[\s\S])*?(?:40 Minuten|Festpreis)(?:(?!<\/section>)[\s\S])*?<\/section>/gi,
    (match) => {
      // Nur entfernen wenn KEIN price-card drin ist
