---
import BaseLayout from '../layouts/BaseLayout.astro';
import GoogleReviews from '../components/GoogleReviews.astro';
import pagesData from '../data/pages.json';
import postsData from '../data/posts.json';
import scrapedData from '../data/scraped-pages.json';

type WPItem = {
  title: string; slug: string; type: string; status: string;
  content: string; excerpt: string; date: string; link: string;
  meta: Record<string, string | undefined>;
  categories: { slug: string; name: string }[];
};
type ScrapedItem = { scrapedHtml: string; type: string; url: string; htmlLength: number; };

const allItems: WPItem[] = [...(pagesData as WPItem[]), ...(postsData as WPItem[])];
const scraped = scrapedData as Record<string, ScrapedItem>;

function resolveTitle(t: string | undefined, fb: string) {
  if (!t) return fb;
  return t
    .replace(/%title%/g, fb)
    .replace(/%sitename%/g, 'Clown Zauberer LIAR')
    .replace(/%sep%/g, '|')
    .replace(/%page%/g, '')
    .replace(/\s{2,}/g, ' ')
    .trim();
}

function getFirstImg(c: string) {
  const m = c.match(/https?:\/\/liar-entertainer\.com\/wp-content\/uploads\/[^\s"'<>)]+\.(jpg|jpeg|png|webp)/i);
  return m ? m[0] : null;
}

const SVC: Record<string, string> = {
  'kindergeburtstag': 'https://liar-entertainer.com/wp-content/uploads/2023/08/CLown-Kinderzauberer-Geburtstag.jpg',
  'clown-zauberer': 'https://liar-entertainer.com/wp-content/uploads/2023/08/Clown-Zauberer-mit-Zaubershow.jpg',
  'zauberer': 'https://liar-entertainer.com/wp-content/uploads/2023/08/Buehnen-Zauberei.jpg',
  'zaubershow': 'https://liar-entertainer.com/wp-content/uploads/2023/08/Buehnen-Zauberei.jpg',
  'clownshow': 'https://liar-entertainer.com/wp-content/uploads/2023/08/Clown-bei-Clownshow.jpg',
  'kinderzauberer': 'https://liar-entertainer.com/wp-content/uploads/2023/08/CLown-Kinderzauberer-Geburtstag.jpg',
  'ballonmodellage': 'https://liar-entertainer.com/wp-content/uploads/2023/08/Ballonmodellage-1.jpg',
  'glitzer-tattoo': 'https://liar-entertainer.com/wp-content/uploads/2023/08/Glitzer-tattoo.jpeg',
  'walk-act': 'https://liar-entertainer.com/wp-content/uploads/2023/08/Clownerie-und-Zauberei-in-NRW.jpg',
  'tisch-zauberer': 'https://liar-entertainer.com/wp-content/uploads/2023/08/Close-Up-Zauberei-Dortmund.jpg',
  'buehnen-zauberer': 'https://liar-entertainer.com/wp-content/uploads/2023/08/Buehnen-Zauberer-Essen.jpg',
  'strassen-sommer-fest': 'https://liar-entertainer.com/wp-content/uploads/2023/08/Fest.jpg',
  'kindergarten-kita': 'https://liar-entertainer.com/wp-content/uploads/2023/08/CLown-Kinderzauberer-Geburtstag.jpg',
  'karneval': 'https://liar-entertainer.com/wp-content/uploads/2023/08/Karneval-245x300.jpeg',
  'schule': 'https://liar-entertainer.com/wp-content/uploads/2023/08/CLown-Kinderzauberer-Geburtstag.jpg',
};

export function getStaticPaths() {
  const pages2 = pagesData as WPItem[];
  const posts2 = postsData as WPItem[];
  const all2 = [...pages2, ...posts2];
  const paths: { params: { slug: string }; props: { pageSlug: string } }[] = [];
  const seen = new Set<string>();

  for (const item of all2) {
    try {
      const url = new URL(item.link);
      let path = url.pathname;
      // Remove leading/trailing slashes
      path = path.replace(/^\/|\/$/g, '');
      if (!path) continue;
      // Decode URL-encoded characters
      let decoded: string;
      try { decoded = decodeURIComponent(path); } catch { decoded = path; }
      if (seen.has(decoded)) continue;
      seen.add(decoded);
      paths.push({ params: { slug: decoded }, props: { pageSlug: item.slug } });
    } catch { /* skip */ }
  }
  return paths;
}

const { slug } = Astro.params as { slug: string };
const { pageSlug } = Astro.props as { pageSlug: string };
const page = allItems.find(p => p.slug === pageSlug);
if (!page) return Astro.redirect('/');

function fixLazyImages(html: string): string {
  return html
    // Replace data-src with src (WordPress lazy-load)
    .replace(/<img([^>]*?)\ssrc="data:image\/svg\+xml[^"]*"([^>]*?)\sdata-src="([^"]+)"([^>]*?)>/gi,
      '<img$1 src="$3"$2$4>')
    // Also handle data-lazy-src
    .replace(/<img([^>]*?)\sdata-lazy-src="([^"]+)"([^>]*?)>/gi,
      '<img$1 src="$2"$3>')
    // Remove any remaining data-src attributes to clean up
    .replace(/\sdata-src="[^"]*"/gi, '')
    .replace(/\sdata-lazy-src="[^"]*"/gi, '');
}

function fixVideoEmbeds(html: string): string {
  // Remove fixed width/height from YouTube iframes and let CSS handle aspect ratio
  return html
    .replace(/<iframe([^>]*?)(width="[^"]*")([^>]*?)(height="[^"]*")([^>]*?)>/gi,
      '<iframe$1$3$5>')
    .replace(/<iframe([^>]*?)(height="[^"]*")([^>]*?)(width="[^"]*")([^>]*?)>/gi,
      '<iframe$1$3$5>');
}

function fixBrokenLinks(html: string): string {
  return html
    // 1. Entferne WordPress /author/ Links — behalte nur den Ankertext
    .replace(/<a[^>]*href="\/author\/[^"]*"[^>]*>(.*?)<\/a>/gi, '$1')
    // 2. Entferne WordPress /category/ Links — behalte nur den Ankertext
    .replace(/<a[^>]*href="\/category\/[^"]*"[^>]*>(.*?)<\/a>/gi, '$1')
    // 3. Entferne WordPress /tag/ Links — behalte nur den Ankertext
    .replace(/<a[^>]*href="\/tag\/[^"]*"[^>]*>(.*?)<\/a>/gi, '$1')
    // 4a. Fix /clown/zauberer/kinderzauberer/kinderzauberer-in-X/ → /kinderzauberer/kinderzauberer-in-X/
    .replace(/href="\/clown\/zauberer\/kinderzauberer\/(kinderzauberer-in-[^"]+)"/gi, 'href="/kinderzauberer/$1"')
    // 4b. Fix /clown/zauberer/kinderzauberer/ → /kinderzauberer/
    .replace(/href="\/clown\/zauberer\/kinderzauberer\/"/gi, 'href="/kinderzauberer/"')
    // 5. Fix /clown/zauberer/zaubershow/ → /zauberer/zaubershow/
    .replace(/href="\/clown\/zauberer\/zaubershow\/"/gi, 'href="/zauberer/zaubershow/"')
    // 6. Fix /clown/zauberer/ → /zauberer/
    .replace(/href="\/clown\/zauberer\/"/gi, 'href="/zauberer/"')
    // 7. Fix /clown/geburtstag/geburtstag-in-X/ → /kindergeburtstag/geburtstag-in-X/
    .replace(/href="\/clown\/geburtstag\/(geburtstag-in-[^"]+)"/gi, 'href="/kindergeburtstag/$1"')
    // 8. Fix /clown/geburtstag/ → /kindergeburtstag/
    .replace(/href="\/clown\/geburtstag\/"/gi, 'href="/kindergeburtstag/"')
    // 9. Fix /clown/clown-in-X/ → /clown/clownshow/clown-in-X/
    .replace(/href="\/clown\/(clown-in-[^"]+)"/gi, 'href="/clown/clownshow/$1"')
    // 10. Fix /clown/kindergeburtstag/ → /kindergeburtstag/
    .replace(/href="\/clown\/kindergeburtstag\/"/gi, 'href="/kindergeburtstag/"')
    // 11. Fix /wp-content/uploads/.../www.DOMAIN → https://www.DOMAIN
    .replace(/href="\/wp-content\/uploads\/[^"]*\/(www\.[a-z0-9][a-z0-9.-]+\.[a-z]{2,})([^"]*)"/gi,
      (_, domain, rest) => `href="https://${domain}${rest}"`)
    // 12. Entferne übrige /wp-content/ Links — behalte nur den Ankertext
    .replace(/<a[^>]*href="\/wp-content\/[^"]*"[^>]*>(.*?)<\/a>/gi, '$1')
    // 13. Fix /clown/ (root, existiert nicht) → /
    .replace(/href="\/clown\/"/gi, 'href="/"')
    // 14. Fix /clown-in-X/ (ohne /clown/ Prefix) → /clown/clownshow/clown-in-X/
    .replace(/href="\/(clown-in-[^"]+)"/gi, 'href="/clown/clownshow/$1"')
    // 15. Fix /clown/geburtstag-in-X/ → /kindergeburtstag/geburtstag-in-X/
    .replace(/href="\/clown\/(geburtstag-in-[^"]+)"/gi, 'href="/kindergeburtstag/$1"')
    // 16. Fix falsche Seiten-URLs → korrekte Ziele
    .replace(/href="\/zauberer-kindergeburtstag\/"/gi, 'href="/kindergeburtstag/"')
    .replace(/href="\/clown-kindergeburtstag\/"/gi, 'href="/kindergeburtstag/"')
    .replace(/href="\/ballonkuenstler\/"/gi, 'href="/clown/ballonmodellage/"')
    .replace(/href="\/kinderschminken\/"/gi, 'href="/clown/glitzer-tattoo/"')
    .replace(/href="\/glitzer-tattoos-kinder\/"/gi, 'href="/clown/glitzer-tattoo/"')
    // 17. Fix /clown/glitzer-tattoos (falsch) → /clown/glitzer-tattoo/
    .replace(/href="\/clown\/glitzer-tattoos"/gi, 'href="/clown/glitzer-tattoo/"')
    // 18. Fix /kontakt (ohne trailing slash) → /kontakt/
    .replace(/href="\/kontakt"/gi, 'href="/kontakt/"')
    // 19. Fix Grammatik: "DER französischer" → "DER französische"
    .replace(/DER französischer/g, 'DER französische')
    .replace(/der französischer/g, 'der französische')
    // 20. TrustIndex Widget entfernen (ersetzt durch GoogleReviews-Komponente)
    .replace(/<pre\s+class="ti-widget"[^>]*>[\s\S]*?<\/pre>/gi, '')
    .replace(/<div\s+data-src="https?:\/\/cdn\.trustindex\.io\/[^"]*"[^>]*><\/div>/gi, '');
}

function stylizeCityContent(html: string): string {
  // === A1: Preis-Karten erstellen ===
  // Überspringe wenn schon price-grid vorhanden (z.B. Gelsenkirchen mit manueller Preis-Sektion)
  if (html.includes('class="price-grid"')) {
    // Price cards already exist, skip price card creation
    // Continue with other stylizations (FAQ, emoji, etc.)
    html = html
      .replace(/<i\s+class="fas fa-magic"><\/i>/gi, '🪄')
      .replace(/<i\s+class="far fa-smile"><\/i>/gi, '😊')
      .replace(/<i\s+class="fas fa-star"><\/i>/gi, '⭐')
      .replace(/<i\s+class="fas fa-heart"><\/i>/gi, '❤️')
      .replace(/<i\s+class="fas fa-check"><\/i>/gi, '✅');
    return html;
  }
  // Verschiedene Seiten nutzen verschiedene Überschriften und Strukturen.
  // Step 1: Finde die Preis-Überschrift (erst H2, dann H3 als Fallback)
  const priceKeywords = /Preis|kostet|Leistungspaket|150\s*€|150\s*Euro/i;
  let priceHeading: { full: string; idx: number; endIdx: number } | null = null;
  let m: RegExpExecArray | null;

  // Erst H2 durchsuchen
  const h2Regex = /<h2([^>]*)>([\s\S]*?)<\/h2>/gi;
  while ((m = h2Regex.exec(html)) !== null) {
    const text = m[2].replace(/<[^>]+>/g, '');
    if (priceKeywords.test(text)) {
      priceHeading = { full: m[0], idx: m.index, endIdx: m.index + m[0].length };
      break;
    }
  }

  // Fallback: H3 (z.B. Gladbeck nutzt H3 "PREISE FÜR GLADBECK")
  if (!priceHeading) {
    const h3Regex = /<h3([^>]*)>([\s\S]*?)<\/h3>/gi;
    while ((m = h3Regex.exec(html)) !== null) {
      const text = m[2].replace(/<[^>]+>/g, '');
      if (/Preis/i.test(text)) {
        priceHeading = { full: m[0], idx: m.index, endIdx: m.index + m[0].length };
        break;
      }
    }
  }

  if (priceHeading) {
    // Step 2: Sektion-Inhalt extrahieren (bis zum nächsten H2)
    const after = html.substring(priceHeading.endIdx);
    const nextH2 = after.match(/<h2[\s>]/i);
    const sectionLen = nextH2 ? nextH2.index! : after.length;
    const priceBlock = after.substring(0, sectionLen);

    // Step 3: Preis-Items in Karten wickeln
    // Pattern A: H3+P Gruppen (z.B. Essen, Düsseldorf, Dinslaken) — alle <p> bis zum nächsten <h3> sammeln
    const h3Count = (priceBlock.match(/<h3[\s>]/gi) || []).length;
    let wrapped = priceBlock;
    if (h3Count >= 2) {
      // Sammle H3 + ALLE nachfolgenden P-Tags bis zum nächsten H3 in eine price-card
      wrapped = priceBlock.replace(
        /(<h3[^>]*>[\s\S]*?<\/h3>)((?:\s*<p[^>]*>[\s\S]*?<\/p>)+)/gi,
        '<div class="price-card">$1$2</div>'
      );
    }

    // Pattern B: <p> mit <strong>...€/Euro...</strong> (z.B. Castrop-Rauxel, Dorsten)
    if (!wrapped.includes('price-card')) {
      wrapped = priceBlock.replace(
        /(<p[^>]*>)\s*(<strong>[^<]*(?:€|Euro)[^<]*<\/strong>[\s\S]*?)(<\/p>)/gi,
        '<div class="price-card">$1$2$3</div>'
      );
    }

    // Pattern C: Emoji-markierte Preisblöcke (z.B. Gelsenkirchen: 🎭 FESTPREIS, 🚗 FAHRTKOSTEN)
    // Sammle zusammengehörige <p>-Tags zu Karten
    if (!wrapped.includes('price-card')) {
      const paragraphs = priceBlock.match(/<p[^>]*>[\s\S]*?<\/p>/gi) || [];
      if (paragraphs.length > 0) {
        let cards: string[] = [];
        let currentCard: string[] = [];
        let currentTitle = '';

        for (const p of paragraphs) {
          const text = p.replace(/<[^>]+>/g, '').trim();
          // Neuer Preis-Block startet mit Emoji oder "OPTIONALE" oder enthält "FESTPREIS"/"FAHRTKOSTEN"
          const isNewBlock = /^[🎭🚗🎈✨⭐🎪]/.test(text) || /^OPTIONALE/i.test(text) ||
            /FESTPREIS|FAHRTKOSTEN/i.test(text);
          // Checkmark-Zeilen (✓) gehören zum aktuellen Block
          const isCheckmark = /^✓/.test(text);
          // "Ihr Vorteil" ist ein separater Info-Block
          const isInfoBlock = /^Ihr Vorteil/i.test(text);

          if (isNewBlock && !isCheckmark) {
            // Vorherige Karte abschließen
            if (currentCard.length > 0) {
              cards.push(`<div class="price-card"><h3>${currentTitle}</h3>${currentCard.join('')}</div>`);
            }
            // Titel aus erstem Satz extrahieren (bis zum ersten Zeilenumbruch oder ✓)
            const titleMatch = text.match(/^(.+?(?:€|Euro|\d+\s*€))/i);
            currentTitle = titleMatch ? titleMatch[1].trim() : text.split(/\s{2,}|Im Preis/)[0].trim();
            // Rest des Paragraphen als Content
            currentCard = [p];
          } else if (isInfoBlock) {
            // Info-Block als eigene Karte
            if (currentCard.length > 0) {
              cards.push(`<div class="price-card"><h3>${currentTitle}</h3>${currentCard.join('')}</div>`);
              currentCard = [];
              currentTitle = '';
            }
            cards.push(`<div class="price-card price-card-info">${p}</div>`);
          } else {
            currentCard.push(p);
          }
        }
        // Letzte Karte abschließen
        if (currentCard.length > 0 && currentTitle) {
          cards.push(`<div class="price-card"><h3>${currentTitle}</h3>${currentCard.join('')}</div>`);
        }

        if (cards.length > 0) {
          wrapped = cards.join('\n');
        }
      }
    }

    // Pattern D: <li>-Elemente mit Preisen (€) als separate Karten (z.B. Recklinghausen)
    // Wenn nur 1 Karte existiert aber <ul><li> mit Preisen vorhanden sind
    const currentCardCount = (wrapped.match(/price-card/g) || []).length;
    if (currentCardCount <= 1) {
      const liMatches = priceBlock.match(/<li[^>]*>[\s\S]*?<\/li>/gi) || [];
      const priceLis = liMatches.filter(li => /€|Euro/i.test(li));
      if (priceLis.length > 0) {
        const liCards = priceLis.map(li => {
          const text = li.replace(/<[^>]+>/g, '').trim();
          // Titel: Emoji + <strong>Name:</strong> Preis
          const titleMatch = text.match(/^([^:]+:\s*\d+\s*€)/);
          const title = titleMatch ? titleMatch[1].trim() : text.substring(0, 50);
          // Rest als Beschreibung
          const desc = titleMatch ? text.substring(titleMatch[0].length).trim() : '';
          // Originales HTML der <li> nutzen, aber als <p> konvertieren
          const content = li.replace(/<\/?li[^>]*>/gi, '').trim();
          return `<div class="price-card"><h3>${title}</h3><p>${desc || content}</p></div>`;
        });
        // Vorhandene Karten behalten und neue anhängen
        wrapped = wrapped + liCards.join('\n');
        // Originale <ul> entfernen aus wrapped
        wrapped = wrapped.replace(/<ul[^>]*>[\s\S]*?<\/ul>/gi, '');
      }
    }

    if (wrapped.includes('price-card')) {
      html = html.substring(0, priceHeading.endIdx)
        + '<div class="price-grid">' + wrapped + '</div>'
        + html.substring(priceHeading.endIdx + sectionLen);
    }
  }

  // === A2: Font Awesome Icons → Emoji ===
  html = html
    .replace(/<i\s+class="fas fa-magic"><\/i>/gi, '🪄')
    .replace(/<i\s+class="far fa-smile"><\/i>/gi, '😊')
    .replace(/<i\s+class="fas fa-star"><\/i>/gi, '⭐')
    .replace(/<i\s+class="fas fa-heart"><\/i>/gi, '❤️')
    .replace(/<i\s+class="fas fa-check"><\/i>/gi, '✅');

  // === A3: FAQ-Karten (Bold-Fragen in Anführungszeichen) ===
  // Pattern 1: „Frage?" + Antwort im selben <p> (Essen-Style)
  html = html.replace(
    /<p([^>]*)><strong>\u201E([^<]*\?)\u201C<\/strong><br\s*\/?>\s*([\s\S]*?)<\/p>/gi,
    '<div class="faq-card"><p$1><strong>\u201E$2\u201C</strong><br>$3</p></div>'
  );
  html = html.replace(
    /<p([^>]*)><strong>„([^<]*\?)"<\/strong><br\s*\/?>\s*([\s\S]*?)<\/p>/gi,
    '<div class="faq-card"><p$1><strong>„$2"</strong><br>$3</p></div>'
  );

  // Pattern 2: ❓ Frage? in eigenem <p> + Antwort in nächstem <p> (Gelsenkirchen-Style)
  html = html.replace(
    /<p([^>]*)>❓\s*([^<]*\?)<\/p>\s*<p([^>]*)>([\s\S]*?)<\/p>/gi,
    '<div class="faq-card"><p$1><strong>„$2"</strong><br>$4</p></div>'
  );

  // === A4: KONTAKTFORMULAR-Buttons entfernen (WordPress-Überbleibsel) ===
  html = html.replace(
    /<div\s+class="wp-block-button[^"]*"[^>]*>\s*<a[^>]*>KONTAKTFORMULAR<\/a>\s*<\/div>/gi,
    ''
  );

  // === A4b: "-----" Trenner entfernen (WordPress-Überbleibsel nach KONTAKTFORMULAR) ===
  html = html.replace(/<p[^>]*>\s*_{3,}\s*<\/p>/gi, '');

  // === A4c: Kaputte Kontakt-Buttons mit Anker-Links entfernen ===
  html = html.replace(
    /<div\s+class="wp-block-button[^"]*"[^>]*>\s*<a[^>]*href="#[^"]*"[^>]*>[^<]*(?:Kontakt|kontakt)[^<]*<\/a>\s*<\/div>/gi,
    ''
  );

  // === A5: **bold** Markdown-Marker → HTML <strong> konvertieren ===
  // WordPress-Seiten (Moers, Herne, Marl, Mülheim, Herten, Haltern) haben rohe **text** Marker.
  html = html.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');

  // === A6: <details>/<summary> FAQ schöner stylen ===
  // Einige Seiten (Haltern, Düsseldorf, Castrop-Rauxel, Moers) nutzen details/summary.
  // Wir fügen CSS-Klassen hinzu für konsistentes faq-card-ähnliches Styling.
  html = html.replace(/<details/g, '<details class="city-faq-item"');
  html = html.replace(/<summary/g, '<summary class="city-faq-summary"');

  // === A7: Inline-Styles auf Bildern entfernen (width:XXXpx constraints) ===
  // WordPress setzt fixe Inline-Styles die zu kleinen Bildern auf Desktop führen.
  html = html.replace(/(<img[^>]*?)style="[^"]*width:\s*\d+px[^"]*"/gi, '$1');
  // Auch figure-Level Inline-Styles mit width
  html = html.replace(/(<figure[^>]*?)style="[^"]*width:\s*\d+px[^"]*"/gi, '$1');

  // === A8: Dunkle Sektionen abwechselnd Blau/Rot markieren ===
  // CSS-Sibling-Selektoren funktionieren nicht, da Sektionen nicht immer Geschwister sind.
  // Deshalb: build-time Klassen hinzufügen (dark-blue / dark-red abwechselnd).
  let colorIdx = 0;
  html = html.replace(/class="([^"]*\bhas-dark-bg\b[^"]*)"/gi, (match, classes) => {
    const colorClass = colorIdx % 2 === 0 ? 'dark-blue' : 'dark-red';
    colorIdx++;
    return `class="${classes} ${colorClass}"`;
  });

  return html;
}

function stripInlineGradients(html: string): string {
  // Entferne ALLE inline background-gradients aus dem gescrapten HTML.
  // WordPress setzt bunte Gradients auf Container, Sections und Spalten,
  // die zwischen Sektionen durchscheinen und das Design-System brechen.
  // Der Client-JS fügt gezielt nur die gewünschten Gradients zurück.
  return html.replace(
    /(<(?:div|section)[^>]*?)\s*style="([^"]*)"/gi,
    (match, tag, style) => {
      if (!style.includes('gradient') && !style.includes('background')) return match;
      // Entferne background gradient declarations und einfarbige backgrounds
      const cleaned = style
        .replace(/background(?:-image)?:\s*linear-gradient\([^)]+\)[^;]*;?/gi, '')
        .replace(/background(?:-color)?:\s*rgb\([^)]+\)[^;]*;?/gi, '')
        .replace(/background(?:-color)?:\s*#[0-9a-fA-F]{3,8}[^;]*;?/gi, '')
        .trim();
      return cleaned ? `${tag} style="${cleaned}"` : tag;
    }
  );
}

const rawScraped: string | null = scraped[pageSlug]?.scrapedHtml ?? null;
let _processedScraped: string | null = rawScraped ? fixVideoEmbeds(fixBrokenLinks(fixLazyImages(rawScraped))) : null;
// Für City-Pages: Alle inline-Gradients entfernen (Client-JS setzt eigene)
if (_processedScraped && (pageSlug.startsWith('geburtstag-in-') || pageSlug.startsWith('kinderzauberer-in-') || pageSlug.startsWith('clown-in-'))) {
  _processedScraped = stripInlineGradients(_processedScraped);
}

// === Gelsenkirchen-spezifisch: Zwei Bilder tauschen ===
// Bild 1 (Intro "Von Buer bis Horst"): Geburtstag-mit-dem-Clown (Portrait) → soll Zaubershow-Bild werden
// Bild 2 (Zaubershow-Beschreibung): Clown-Zauberer-mit-Zaubershow (Querformat) → soll Geburtstag-Bild werden
if (_processedScraped && pageSlug === 'geburtstag-in-gelsenkirchen') {
  const img1Src = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Geburtstag-mit-dem-Clown-768x1024.jpg';
  const img2Src = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Clown-Zauberer-mit-Zaubershow.jpg';
