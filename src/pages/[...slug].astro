                  banner.innerHTML = `
                    <div style="line-height:0;overflow:hidden;">
                      <svg viewBox="0 0 1440 40" preserveAspectRatio="none" style="display:block;width:100%;height:25px;">
                        <path d="M0,40 C360,0 1080,0 1440,40 L1440,40 L0,40 Z" fill="#d7393e"/>
                      </svg>
                    </div>
                    <div style="background:#d7393e;padding:2rem 0;text-align:center;color:#fff;">
                      <div style="display:flex;justify-content:center;gap:2rem;flex-wrap:wrap;max-width:900px;margin:0 auto;">
                        <div style="background:rgba(255,255,255,0.15);border-radius:12px;padding:1.5rem 2rem;min-width:180px;">
                          <div style="font-size:2rem;">🪄</div>
                          <div style="font-size:2.5rem;font-weight:800;color:#ffb546;">400</div>
                          <div style="font-size:0.9rem;">Shows im Jahr</div>
                        </div>
                        <div style="background:rgba(255,255,255,0.15);border-radius:12px;padding:1.5rem 2rem;min-width:180px;">
                          <div style="font-size:2rem;">😊</div>
                          <div style="font-size:2.5rem;font-weight:800;color:#ffb546;">110.000</div>
                          <div style="font-size:0.9rem;">Lachende Kinder</div>
                        </div>
                        <div style="background:rgba(255,255,255,0.15);border-radius:12px;padding:1.5rem 2rem;min-width:180px;">
                          <div style="font-size:2rem;">🪄</div>
                          <div style="font-size:2.5rem;font-weight:800;color:#ffb546;">15</div>
                          <div style="font-size:0.9rem;">Jahre Erfahrung</div>
                        </div>
                      </div>
                    </div>
                    <div style="line-height:0;overflow:hidden;">
                      <svg viewBox="0 0 1440 40" preserveAspectRatio="none" style="display:block;width:100%;height:25px;">
                        <path d="M0,0 C360,40 1080,40 1440,0 L1440,0 L0,0 Z" fill="#d7393e"/>
                      </svg>
                    </div>`;
                  vorteileSection.parentElement.insertBefore(banner, vorteileSection);
                }

                // Originale Stats-Sektion komplett verstecken
                // Finde alle Elemente mit "Shows im Jahr" die NICHT im neuen Banner sind
                document.querySelectorAll('.city-page span, .city-page div, .city-page section').forEach(el => {
                  if (el.closest('.bottrop-stats-banner-new')) return;
                  if ((el.textContent.includes('Shows im Jahr') || el.textContent.includes('Lachende Kinder')) &&
                      el.textContent.includes('Jahre Erfahrung') && el.offsetWidth > 0) {
                    // Verstecke das Element und alle Eltern bis zur nächsten Section
                    let target = el;
                    while (target && !target.classList?.contains('nv-content-wrap')) {
                      if (target.offsetHeight < 200 && target.textContent.trim().length < 200) {
                        target.style.setProperty('display', 'none', 'important');
                        break;
                      }
                      target = target.parentElement;
                    }
                  }
                });

                // Alle roten Hintergründe weiß (AUSSER warum-blue UND neuer Banner!)
                document.querySelectorAll('.city-page [style*="215, 57"]').forEach(el => {
                  if (el.closest('.bottrop-warum-blue')) return;
                  if (el.closest('.bottrop-stats-banner-new')) return; // Neuen Banner schützen
                  el.style.setProperty('background', '#fff', 'important');
                });

                // Roten Strich über "Kindergeburtstag in Bottrop und ganz NRW" entfernen
                // Das ist eine border-top oder ein schmaler roter Gradient-Container
                const nrwH = Array.from(document.querySelectorAll('h2, h3')).find(h =>
                  h.textContent.includes('Bottrop') && h.textContent.includes('NRW'));
                if (nrwH) {
                  const nrwSection = nrwH.closest('.alignfull, section');
                  if (nrwSection) {
                    // Entferne alle roten Borders/Backgrounds über der NRW-Section
                    let prev = nrwSection.previousElementSibling;
                    while (prev) {
                      const bg = getComputedStyle(prev).background || '';
                      const h = prev.offsetHeight;
                      if (h < 30 && (bg.includes('215, 57') || bg.includes('d7393e'))) {
                        prev.style.setProperty('display', 'none', 'important');
                      }
                      if (h > 30) break;
                      prev = prev.previousElementSibling;
                    }
                    // Auch border-top der Section selbst entfernen
                    nrwSection.style.setProperty('border-top', 'none', 'important');
                  }
                }
              } catch(e) { console.error('Bottrop fix error:', e); }
            }, 150);
          }

          // (Fix WAVES und Fix FINAL entfernt — das NEUES Design-System Script unten
          //  übernimmt Waves + Spacing korrekt mit max-2-Sektionen-Limit)
        });
      </script>
    )}

    {/* NEUES Design-System Script — überschreibt alle vorherigen Fixes */}
    {isCityPage && (
      <script is:inline>
        window.addEventListener('load', () => {
          const cp = document.querySelector('.city-page');
          if (!cp) return;

          // === 1. WordPress-Waves verstecken ===
          cp.querySelectorAll('.top, .bottom, .rotate').forEach(el => {
            el.style.display = 'none';
          });

          // === 2. Leere Sektionen entfernen ===
          cp.querySelectorAll('section, .alignfull, .wp-block-themeisle-blocks-advanced-columns, .wp-block-columns').forEach(s => {
            if (s.closest('.price-grid') || s.closest('[class*="stats-banner"]')) return;
            const text = s.textContent.trim();
            const hasImg = s.querySelector('img');
            const hasVid = s.querySelector('iframe');
            const hasPG = s.querySelector('.price-grid');
            if (text.length < 15 && !hasImg && !hasVid && !hasPG && s.offsetHeight > 30) {
              s.style.display = 'none';
            }
          });

          // === 3. Max 2 farbige Sektionen — Rest wird weiß ===
          const coloredSections = [];
          cp.querySelectorAll('section, .alignfull, div').forEach(s => {
            if (s.closest('[class*="stats-banner"]')) return;
            if (s.offsetHeight < 50 || s.offsetWidth < 200) return;
            // Skip wrapper sections that contain child sections (they wrap entire page content)
            // Also strip their gradients so they don't bleed through
            const childSections = s.querySelectorAll('section, .alignfull');
            if (childSections.length > 1) {
              const bg = getComputedStyle(s).backgroundImage || '';
              if (bg.includes('gradient')) {
                s.style.setProperty('background-image', 'none', 'important');
                s.style.setProperty('background-color', 'transparent', 'important');
              }
              return;
            }
            const bg = getComputedStyle(s).backgroundImage || '';
            const bgC = getComputedStyle(s).backgroundColor || '';
            const isColored = bg.includes('gradient') ||
              (bgC !== 'rgba(0, 0, 0, 0)' && bgC !== 'rgb(255, 255, 255)' && bgC !== 'rgb(249, 250, 251)');
            if (isColored && s.textContent.trim().length > 20) {
              // Prüfe: ist es ein erlaubter farbiger Bereich?
              const isRed = bg.includes('215, 57') || bg.includes('d7393e');
              const isBlue = bg.includes('59, 85') || bg.includes('3b55d5');
              const isDark = bg.includes('31, 32') || bg.includes('1f2025');
              if (isRed || isBlue || isDark) {
                // Skip if already inside a found colored section
                const isNested = coloredSections.some(cs => cs.el.contains(s) && cs.el !== s);
                if (!isNested) {
                  coloredSections.push({ el: s, color: isRed ? 'red' : isBlue ? 'blue' : 'dark' });
                }
              } else {
                // Unerlaubte Farbe → weiß machen
                s.style.setProperty('background', '#fff', 'important');
                s.querySelectorAll('h2, h3, h4, p, span, strong, li').forEach(t => {
                  if (getComputedStyle(t).color === 'rgb(255, 255, 255)') {
                    t.style.setProperty('color', '#1f2025', 'important');
                  }
                });
                s.querySelectorAll('a').forEach(a => a.style.setProperty('color', '#d7393e', 'important'));
              }
            }
          });

          // Wenn mehr als 2 farbige Sektionen: überschüssige weiß machen
          if (coloredSections.length > 2) {
            // Behalte die ersten 2, mache den Rest weiß
            coloredSections.slice(2).forEach(({ el }) => {
              el.style.setProperty('background', '#fff', 'important');
              el.querySelectorAll('h2, h3, h4, p, span, strong, li').forEach(t => {
                if (getComputedStyle(t).color === 'rgb(255, 255, 255)') {
                  t.style.setProperty('color', '#1f2025', 'important');
                }
              });
              el.querySelectorAll('a').forEach(a => a.style.setProperty('color', '#d7393e', 'important'));
            });
          }

          // === 4. SVG-Waves für die verbleibenden farbigen Sektionen ===
          const waveColors = { red: '#d7393e', blue: '#3b55d5', dark: '#1f2025' };
          coloredSections.slice(0, 2).forEach(({ el, color }) => {
            if (el.closest('[class*="stats-banner"]')) return;
            // Entferne existierende Waves (WordPress-Klassen UND dynamisch erstellte)
            el.querySelectorAll('.top, .bottom').forEach(w => w.remove());
            // Entferne auch dynamisch erstellte Wave-Divs (haben SVG mit viewBox 1440)
            for (const child of [...el.children]) {
              if (child.querySelector && child.querySelector('svg[viewBox*="1440"]') && child.children.length === 1) {
                child.remove();
              }
            }
            const fill = waveColors[color] || '#3b55d5';
            // Wave oben
            const wTop = document.createElement('div');
            wTop.style.cssText = 'overflow:hidden;line-height:0;margin-bottom:-1px;';
            wTop.innerHTML = '<svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;"><path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="' + fill + '"/></svg>';
            el.insertBefore(wTop, el.firstChild);
            // Wave unten
            const wBot = document.createElement('div');
            wBot.style.cssText = 'overflow:hidden;line-height:0;margin-top:-1px;';
            wBot.innerHTML = '<svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;"><path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/></svg>';
            el.appendChild(wBot);
          });

          // === 5. Preis-Karten: Immer 3 Spalten ===
          cp.querySelectorAll('.price-grid').forEach(pg => {
            pg.style.cssText = 'display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;max-width:1000px;margin:1rem auto 1.5rem;';
            // Entferne Extra-Cards über 3
            const cards = pg.querySelectorAll('.price-card');
            if (cards.length > 3) {
              for (let i = 3; i < cards.length; i++) cards[i].remove();
            }
          });

          // === 6. Overlay-Divs minimieren ===
          cp.querySelectorAll('.wp-block-themeisle-blocks-advanced-columns-overlay').forEach(o => {
            o.style.cssText = 'max-height:0;overflow:hidden;padding:0;';
          });
        });
      </script>
    )}

    {/* Service-Links für Blog-Posts */}
    {isBlogPost && (
      <section class="py-10 bg-[#f9fafb]">
        <div class="max-w-3xl mx-auto px-4 text-center">
          <p class="text-[#595959] font-bold text-sm uppercase tracking-widest mb-4">Unsere Leistungen</p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href="/clown/clownshow/" class="bg-white px-5 py-3 rounded-lg shadow-sm text-[#d7393e] hover:underline font-medium text-sm">🤡 Clownshow</a>
            <a href="/zauberer/" class="bg-white px-5 py-3 rounded-lg shadow-sm text-[#3b55d5] hover:underline font-medium text-sm">🎩 Zauberer</a>
            <a href="/kinderzauberer/" class="bg-white px-5 py-3 rounded-lg shadow-sm text-[#d7393e] hover:underline font-medium text-sm">✨ Kinderzauberer</a>
            <a href="/kindergeburtstag/" class="bg-white px-5 py-3 rounded-lg shadow-sm text-[#3b55d5] hover:underline font-medium text-sm">🎂 Kindergeburtstag</a>
            <a href="/zauberer/zaubershow/" class="bg-white px-5 py-3 rounded-lg shadow-sm text-[#d7393e] hover:underline font-medium text-sm">🪄 Zaubershow</a>
            <a href="/galerie/" class="bg-white px-5 py-3 rounded-lg shadow-sm text-[#3b55d5] hover:underline font-medium text-sm">📸 Galerie</a>
          </div>
        </div>
      </section>
    )}

    {/* Google Reviews – nach dem Content wie in der Referenz */}
    <GoogleReviews />

    {/* CTA-Sektion im Referenz-Stil */}
    {isCityPage ? (
      <section class="bg-gray-50 py-14">
        <div class="max-w-3xl mx-auto px-4 text-center">
          <p class="font-bold text-[#d7393e] text-sm uppercase tracking-widest mb-2">EINFACH KONTAKT AUFNEHMEN</p>
          <h2 class="text-[#1f2025] font-bold text-2xl sm:text-3xl mb-6">{cityName ? `Clown Zauberer buchen in ${displayCity}` : 'Jetzt buchen'}</h2>
          <p class="text-[#374151] mb-6 text-sm leading-relaxed max-w-xl mx-auto">
            Sie können mir Ihre Anfrage unverbindlich senden. Ihre Angaben werden selbstverständlich absolut vertraulich behandelt und nicht weitergegeben. Je mehr Angaben ich von Ihnen bekomme, desto besser kann ich Sie beraten. Sie können auch einfach unter 0172-1517578 anrufen oder über WhatsApp schreiben.
          </p>
          <a href="/kontakt/" class="inline-block bg-[#d7393e] hover:bg-[#b62e32] text-white font-bold px-8 py-3 rounded transition-colors">
            Kontaktformular
          </a>
        </div>
      </section>
    ) : (
      <section class="pb-12 bg-white">
        <div class="max-w-[750px] mx-auto px-4">
          <div class="mt-10 bg-[#f4f4f4] rounded-lg p-8 text-center">
            <h2 class="text-[#1f2025] font-bold text-xl mb-3">Jetzt buchen</h2>
            <p class="text-[#595959] mb-5">Unvergessliche Unterhaltung für Ihr Event – einfach und unverbindlich anfragen!</p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a href="/kontakt/" class="inline-flex items-center justify-center gap-2 bg-[#d7393e] hover:bg-[#b62e32] text-white font-bold px-8 py-3 rounded transition-colors">Kontakt aufnehmen</a>
              <a href="tel:+491721517578" class="inline-flex items-center justify-center bg-white border border-gray-200 text-[#1f2025] font-bold px-8 py-3 rounded hover:bg-gray-50 transition-colors">+49 172 1517578</a>
            </div>
          </div>
        </div>
      </section>
    )}

    {/* Kontakt-Info-Zeile */}
    {isCityPage && (
      <section class="bg-white py-10 border-t border-gray-100">
        <div class="max-w-3xl mx-auto px-4 text-center">
          <p class="font-bold text-[#1f2025] text-lg mb-2">Clown Zauberer LIAR</p>
          <p class="text-[#374151] mb-2">Anschrift : Beethovenstr. 15, 45966 Gladbeck</p>
          <p class="text-[#374151] mb-4">
            TEL : <a href="tel:+491721517578" class="hover:text-[#d7393e] transition-colors">0172 – 1517578</a>
            {' '}// Email :
            <a href="mailto:info@liar-entertainer.com" class="hover:text-[#d7393e] transition-colors">info@liar-entertainer.com</a>
          </p>
        </div>
      </section>
    )}
  </>
) : (
  <>
    <section class="relative py-36 overflow-hidden">
      <div class="absolute inset-0 bg-cover" style={`background-image: url('${heroImg}'); background-position: center 20%;`} />
      <div class="absolute inset-0 bg-black/50" />
      <div class="relative max-w-[750px] mx-auto px-4 text-center">
        {isCityPage && cityName && <div class="inline-flex items-center gap-2 bg-white/20 text-white rounded-full px-4 py-1.5 text-sm font-medium mb-4">📍 {cityName}</div>}
        <h1 class="text-white font-bold text-3xl sm:text-4xl leading-tight mb-3">{seoTitle || page.title}</h1>
        {rawDesc && <p class="text-gray-200 text-base leading-relaxed">{rawDesc}</p>}
      </div>
    </section>
    <section class="pt-4 pb-12 bg-white">
      <div class="max-w-[750px] mx-auto px-4">
        {fixedPageContent && <div class="wp-content"><Fragment set:html={fixedPageContent} /></div>}
      </div>
    </section>
    <GoogleReviews />
    <section class="bg-white py-10 border-t border-gray-100">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <h2 class="text-[#1f2025] font-bold text-xl mb-3">{isCityPage && cityName ? `Clown Zauberer buchen in ${cityName}` : 'Jetzt buchen'}</h2>
        <p class="text-[#595959] mb-5">Unvergessliche Unterhaltung für Ihr Event – einfach und unverbindlich anfragen!</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/kontakt/" class="inline-flex items-center justify-center gap-2 bg-[#d7393e] hover:bg-[#b62e32] text-white font-bold px-8 py-3 rounded transition-colors">Kontakt aufnehmen</a>
          <a href="tel:+491721517578" class="inline-flex items-center justify-center bg-white border border-gray-200 text-[#1f2025] font-bold px-8 py-3 rounded hover:bg-gray-50 transition-colors">+49 172 1517578</a>
        </div>
      </div>
    </section>
  </>
)}

</BaseLayout>
