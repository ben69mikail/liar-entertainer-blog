  // Beide getauschte Bilder mit Klasse für konsistente Höhe markieren
  _processedScraped = _processedScraped
    .replace(/(class="wp-image-1077[^"]*")/g, '$1 data-swap="true"')
    .replace(/(class="wp-image-304[^"]*")/g, '$1 data-swap="true"');
  // Inline-Styles entfernen (CSS übernimmt via data-swap Attribut)
  _processedScraped = _processedScraped
    .replace(/style="object-fit:cover;width:352px;height:492px"/g, '')
    .replace(/style="object-fit:cover;width:358px;height:269px"/g, '');

  // === Gelsenkirchen: Preis-Sektion komplett ersetzen ===
  // Die 2-Spalten-WordPress-Struktur macht das Regex-Matching unmöglich.
