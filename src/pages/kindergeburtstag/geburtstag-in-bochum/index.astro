const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Kindergeburtstag mit Clown Zauberer in Bochum',
  description: seoDescription,
  provider: {
    '@type': 'LocalBusiness',
    name: 'Clown Zauberer LIAR',
    url: 'https://liar-entertainer.com',
    telephone: '+491721517578',
  },
  areaServed: { '@type': 'City', name: 'Bochum' },
