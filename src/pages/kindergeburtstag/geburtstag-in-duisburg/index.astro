  </section>

  <!-- Praktische Tipps -->
  <section class="bg-white py-14">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-[#1f2025] font-bold text-2xl sm:text-3xl text-center mb-8">Praktische Tipps für Ihren Geburtstag in Duisburg</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
