---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import heroImg from '../../assets/images/kindergeburtstag/kindergeburtstag-hero.jpg';
import kinderzaubererImg from '../../assets/images/kindergeburtstag/kindergeburtstag-mit-kinderzauberer.jpg';
import karteImg from '../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import GoogleReviews from '../../components/GoogleReviews.astro';

const seoTitle = 'Zauberer Kindergeburtstag NRW | Ab 150€ | Clown LIAR';
const seoDescription = 'Zauberer für Kindergeburtstag in NRW buchen ✓ Clown Zauberer LIAR ✓ Zaubershow ab 150€ ✓ Ballonmodellage ✓ Glitzer-Tattoos ✓ 400+ Top-Bewertungen ✓ Jetzt buchen!';

const faqItems = [
  {
    question: 'Was braucht Kinderzauberer LIAR für einen Auftritt?',
    answer: 'LIAR ist ziemlich pflegeleicht: für die Show ist es wichtig, dass die Kinder gemütlich und ungestört sitzen können!!! Bei der Ballonmodellage ist nichts weiteres nötig. Bei GLITZER TATTOOS wären 2 Stühle und einen Tisch schon wichtig! So können die Kinder sehen was angeboten wird und sich bestens entscheiden!',
  },
  {
    question: 'Wieviel Platz braucht man für den Auftritt?',
    answer: 'Ohne Vorbereitungszeit und mit einer Fläche von 2×2 Meter kann ich eine Show vorführen: Wohnzimmer, Kinderzimmer, Partykeller, Terrasse, Gartenanlage, große und kleine Bühne, Bücherei, Kindergarten, Turnhalle… Ob drinnen oder draußen, das Programm lässt sich spontan und flexibel ausführen!',
  },
  {
    question: 'Wie viele Kinder sollten überhaupt eingeladen werden?',
    answer: 'Natürlich soll das Kind seine Freunde einladen. Allerdings sollte man eine feste Zahl als Limit vorgeben. Pädagogen empfehlen, maximal genauso viele Gäste einzuladen, wie das Kind alt wird. Wer kommen darf, soll das Kind selbst bestimmen. Natürlich sind auch dabei die Aufsichtspersonen (mindestens 2) nicht zu vergessen. Sicherheit geht immer vor!',
  },
  {
    question: 'Kann ich Zaubershow, Ballontiere und Glitzer Tattoos kombinieren?',
    answer: 'Ja, das ist das beliebteste Paket! Zaubershow (40 Min.) für 150€, plus Ballonmodellage (+20€) und Glitzer Tattoos (+40€). Die Gesamtdauer beträgt dann ca. 90 Minuten – der perfekte Rundum-Kindergeburtstag!',
  },
  {
    question: 'Was muss ich als Elternteil vorbereiten?',
    answer: 'Fast nichts! Es muss nur dafür gesorgt werden, dass die Kinder gemütlich sitzen können und ein Bereich von ca. 2×2 Metern frei ist. Alles andere wird mitgebracht. Für Glitzer Tattoos wären zwei Stühle und ein Tisch hilfreich.',
  },
  {
    question: 'Sind die Glitzer Tattoos hautverträglich?',
    answer: 'Ja, alle verwendeten Materialien sind dermatologisch getestet und enthalten keine bekannten Allergene. Die Tattoos halten 4-8 Tage und sind wasserfest.',
  },
  {
    question: 'Ab wie vielen Kindern kann ich buchen?',
    answer: 'Es gibt keine Mindestzahl. Die Zaubershow funktioniert bereits ab wenigen Kindern und ist für bis zu ca. 12 Kinder konzipiert. Für größere Gruppen (Schulfeste, Kita-Feste) gibt es individuelle Angebote.',
  },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Kindergeburtstag mit Clown Zauberer',
  description: 'Professionelle Zaubershow, Ballonmodellage und Glitzer Tattoos für Kindergeburtstage in NRW',
  provider: {
    '@type': 'LocalBusiness',
    name: 'Clown Zauberer LIAR',
    url: 'https://liar-entertainer.com',
    telephone: '+491721517578',
  },
  areaServed: {
    '@type': 'State',
    name: 'Nordrhein-Westfalen',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Kindergeburtstag-Pakete',
    itemListElement: [
      {
        '@type': 'Offer',
        name: 'Zaubershow',
        price: '150',
        priceCurrency: 'EUR',
        description: '40 Minuten interaktive Zaubershow für bis zu 12 Kinder, inkl. Material',
      },
      {
        '@type': 'Offer',
        name: 'Zaubershow + Ballonmodellage',
        price: '170',
        priceCurrency: 'EUR',
        description: 'Zaubershow plus Ballontiere für jedes Kind, ca. 55 Minuten',
      },
      {
        '@type': 'Offer',
        name: 'Komplett-Paket',
        price: '210',
        priceCurrency: 'EUR',
        description: 'Zaubershow + Ballonmodellage + Glitzer Tattoos, ca. 90 Minuten',
      },
    ],
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Kindergeburtstag NRW, Kindergeburtstag Clown, Kindergeburtstag Zauberer, Clown Kindergeburtstag buchen, Zauberer für Kindergeburtstag, Kinderparty NRW, Kindergeburtstag Unterhaltung"
  canonical="https://liar-entertainer.com/kindergeburtstag/"
  structuredData={structuredData}
  breadcrumbs={[{ name: 'Startseite', url: '/' }, { name: 'Kindergeburtstag', url: '/kindergeburtstag/' }]}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <Image
      src={heroImg}
      alt="Kindergeburtstag mit Clown Zauberer NRW"
      class="absolute inset-0 w-full h-full object-cover object-top"
      style="object-position: 55% 26%"
      widths={[400, 800, 1200, 1600]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-black/45"></div>
    <div class="relative flex items-center justify-center" style="min-height: 600px;">
      <h1 class="text-white font-bold text-center px-6 leading-tight" style="font-size: clamp(2rem, 5vw, 3.5rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
        Zauberer für Kindergeburtstag in NRW<br />mit Clown & Lachgarantie
      </h1>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <!-- Left: Text -->
        <div>
          <h2 class="text-[#d7393e] font-bold text-xl mb-4">Clown Zauberer für Kindergeburtstage in NRW</h2>
          <h3 class="font-bold text-lg text-[#1f2025] mb-4">Magische Momente voller Lachen, Staunen und Freude</h3>
          <p class="text-[#374151] mb-4 leading-relaxed">
            Ein Kindergeburtstag soll unvergesslich sein – voller Lachen, Spannung und echter Magie.<br />
            Mit meiner kindgerechten <a href="/zauberer/zaubershow/" class="text-[#d7393e] hover:underline">Zaubershow</a> bringe ich die Augen kleiner Gäste zum Leuchten und sorge dafür, dass jedes Kind sich als Teil der Show fühlt.
          </p>
          <p class="text-[#374151] mb-6 leading-relaxed">
            Ich bin <a href="/" class="text-[#d7393e] hover:underline">Clown</a> <a href="/zauberer/" class="text-[#d7393e] hover:underline">Zauberer</a> LIAR (Michaël Prescler) – professioneller <a href="/kinderzauberer/" class="text-[#d7393e] hover:underline">Kinderzauberer</a> mit Herz, Humor und über 15 Jahren Erfahrung auf Familienfeiern, in Kindergärten und bei Stadtfesten in ganz NRW.
          </p>
          <p class="font-semibold text-[#1f2025] mb-3">✨ Was Sie erwartet:</p>
          <ul class="space-y-2 text-[#374151]">
            <li>🎪 Interaktive Zaubershow vom Kinderzauberer (40 Min.)</li>
            <li>🎈 Ballonmodellage für jedes Kind (optional)</li>
            <li>✨ Glitzer Tattoos (optional)</li>
            <li>😊 Kindgerechter Humor vom erfahrenen Kinderzauberer</li>
            <li>📍 Flexibel in ganz NRW buchbar</li>
            <li>💰 Transparente Preise ab 150€</li>
          </ul>
        </div>
        <!-- Right: Circular Image -->
        <div class="flex justify-center">
          <Image
            src={kinderzaubererImg}
            alt="Kinderzauberer verzaubert Kinder auf einem Kindergeburtstag in NRW"
            class="rounded-full object-cover object-[20%]"
            style="width: 320px; height: 320px;"
            widths={[320, 640]}
            sizes="320px"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Wave: white → blue -->
  <div style="overflow:hidden;line-height:0;background:white;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>

  <!-- Blue: Zaubershow Section -->
  <section class="bg-[#3b55d5] py-14 text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-[#ffb546] font-bold text-sm uppercase tracking-widest mb-4">VOLLTREFFER</p>
      <h2 class="text-white font-bold text-3xl sm:text-4xl mb-6">✨ Zaubershow für Geburtstag – mit Herz &amp; Humor</h2>
      <p class="text-white leading-relaxed mb-4">
        Meine <strong class="text-white">Zaubershow</strong> ist speziell auf Kinder abgestimmt:<br />
        lebendig, interaktiv und voller Überraschungen.
      </p>
      <p class="text-white leading-relaxed mb-4">
        Die Kinder dürfen mitzaubern, lachen, staunen – und manchmal selbst zur kleinen Zauberin oder zum Zauberer werden.
      </p>
      <p class="text-white leading-relaxed mb-4">
        Dabei achte ich besonders auf <strong class="text-white">Respekt, Empathie und ein liebevolles Miteinander</strong>.<br />
        Kein Kind wird bloßgestellt – jedes Kind wird Teil einer positiven, fröhlichen Erfahrung.
      </p>
      <p class="text-white leading-relaxed">
        Egal ob im Wohnzimmer, Garten oder im Gemeindesaal – meine Show passt sich flexibel an jede Umgebung an und sorgt garantiert für strahlende Gesichter.
      </p>
    </div>
  </section>

  <!-- Wave: blue → white -->
  <div style="overflow:hidden;line-height:0;background:#3b55d5;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- Die Preise -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-[#d7393e] font-bold text-3xl sm:text-4xl text-center mb-10">Die Preise</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Zaubershow -->
        <div class="bg-white rounded-xl p-8 shadow-sm border-t-4 border-[#d7393e]">
          <h3 class="font-bold text-[#1f2025] text-xl mb-2">🎩 Zaubershow</h3>
          <p class="text-[#d7393e] font-bold text-2xl mb-4">150 €</p>
          <ul class="space-y-2 text-[#374151] text-sm mb-6">
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> 40 Minuten voller Zauber, Lachen und Staunen</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Bis ca. 12 Kinder – Mindestalter: 4 Jahre</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Inkl. Material</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Das Geburtstagskind steht immer im Mittelpunkt</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> zzgl. Fahrtkosten (0,40€/km, Hin- &amp; Rückfahrt) ab Gladbeck</li>
          </ul>
          <p class="text-[#374151] text-sm">Direkt ab der ersten Minute nimmt die Show die kleinen Gäste mit auf eine fantasievolle Reise!</p>
        </div>

        <!-- Ballonmodellage -->
        <div class="bg-white rounded-xl p-8 shadow-sm border-t-4 border-[#3b55d5]">
          <h3 class="font-bold text-[#1f2025] text-xl mb-2">🎈 Luftballonmodellage</h3>
          <p class="text-[#3b55d5] font-bold text-2xl mb-4">+ 20 €</p>
          <ul class="space-y-2 text-[#374151] text-sm mb-6">
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Für jedes Kind 1 Ballon</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Ca. 15 Minuten</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Tolle Erinnerung zum Mitnehmen</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Große Auswahl an Figuren: Hund, Schwert, Blume u.v.m.</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Perfekte Ergänzung zur Zaubershow</li>
          </ul>
          <p class="text-[#374151] text-sm">Ob Schwerter, Hunde oder Blumen – die Kinder staunen, wenn aus einem Ballon ihre Wunschfigur entsteht!</p>
        </div>

        <!-- Glitzer Tattoos -->
        <div class="bg-white rounded-xl p-8 shadow-sm border-t-4 border-[#ffb546]">
          <h3 class="font-bold text-[#1f2025] text-xl mb-2">✨ Glitzer-Tattoos</h3>
          <p class="text-[#d7393e] font-bold text-2xl mb-4">+ 40 €</p>
          <ul class="space-y-2 text-[#374151] text-sm mb-6">
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Für jedes Kind 1 Tattoo</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Ca. 30 Minuten</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Hautverträglich &amp; langanhaltend</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Viele Motive: Einhörner, Schmetterlinge, Sterne u.v.m.</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Hält mehrere Tage auf der Haut</li>
          </ul>
          <p class="text-[#374151] text-sm">Ein funkelndes Highlight, das die Kinder noch Tage nach der Feier begeistert!</p>
        </div>
      </div>

      <div class="text-center mt-10">
        <a href="/kontakt/" class="inline-block bg-[#d7393e] hover:bg-[#b62e32] text-white font-bold px-10 py-4 rounded transition-colors text-base">
          Jetzt unverbindlich anfragen
        </a>
      </div>
    </div>
  </section>

  <!-- Ballonmodellage & Glitzer Tattoos -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-[#1f2025] font-bold text-2xl sm:text-3xl text-center mb-2">
        🎈🎈 Ballonmodellage &amp; Glitzer-Tattoos – das i-Tüpfelchen zum Geburtstag
      </h2>
      <p class="text-center text-[#595959] mb-10">Das i-Tüpfelchen für den perfekten Kindergeburtstag</p>
      <p class="text-[#374151] text-center mb-10 max-w-2xl mx-auto">
        Neben der Zaubershow biete ich auf Wunsch auch <a href="/clown/ballonmodellage/" class="text-[#d7393e] hover:underline">Ballonmodellage</a> und <a href="/clown/glitzer-tattoo/" class="text-[#d7393e] hover:underline">Glitzer Tattoos</a> an – die perfekte Ergänzung für den Kindergeburtstag! Werfen Sie auch gerne einen Blick in meine <a href="/galerie/" class="text-[#d7393e] hover:underline">Galerie</a>.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <!-- Ballonmodellage -->
        <div class="bg-gray-50 rounded-xl p-8">
          <h3 class="font-bold text-[#1f2025] text-xl mb-4">🎈 Ballonmodellage</h3>
          <p class="text-[#374151] mb-4 leading-relaxed">
            Bunte Figuren, Tiere und Überraschungen – live vor den Augen der Kinder geformt. Jedes Kind bekommt sein Wunschtier mit nach Hause!
          </p>
          <p class="text-[#374151] mb-4"><strong>Beliebte Ballonfiguren:</strong><br />
            🐶 Hund | 🐱 Katze | 🦖 Dinosaurier | ⚔️ Schwert | 👑 Krone | 🌸 Blume | 🦋 Schmetterling
          </p>
          <p class="text-[#374151] mb-2"><strong>Das Besondere:</strong> Jedes Kind darf sich sein Lieblingstier wünschen, und der Clown zaubert es direkt vor den Augen der Kinder. Die Ballonfiguren sind robust und halten mehrere Tage – ein Andenken, das Freude macht!</p>
          <p class="text-[#374151] mb-2"><strong>Perfekt als:</strong> – Ergänzung zur Clown-Show – Eigenständige Attraktion auf Festen – Walk-Act auf Straßenfesten</p>
          <p class="text-[#374151] mt-4 font-medium">
            <strong>Dauer:</strong> Ca. 15 Minuten für 12 Kinder (1-2 Min. pro Figur)
          </p>
        </div>

        <!-- Glitzer Tattoos -->
        <div class="bg-gray-50 rounded-xl p-8">
          <h3 class="font-bold text-[#1f2025] text-xl mb-4">✨ Glitzer Tattoos</h3>
          <p class="text-[#374151] mb-4 leading-relaxed">
            Kleine Kunstwerke, die Kinder lieben – hautfreundlich, farbenfroh und mit glänzenden Augen garantiert. Die Tattoos halten 4-8 Tage und sind wasserfest!
          </p>
          <p class="text-[#374151] mb-4"><strong>Beliebte Motive:</strong><br />
            🦄 Einhorn | 🌸 Blumen | 🦖 Dino | ✨ Sterne | 🦋 Schmetterling | 🏴‍☠️ Pirat
          </p>
          <p class="text-[#374151] mt-4 font-medium">
            <strong>Dauer:</strong> Ca. 30 Minuten für 12 Kinder (2-3 Min. pro Tattoo)
          </p>
        </div>
      </div>

      <p class="text-center mt-8 text-[#374151] font-medium">
        💡 <strong>Tipp:</strong> Kombinieren Sie alle drei Leistungen für den perfekten Rundum-Sorglos-Kindergeburtstag!
      </p>
    </div>
  </section>

  <!-- Google Reviews -->
  <GoogleReviews />

  <!-- FAQ -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-center font-bold text-[#1f2025] text-sm uppercase tracking-widest mb-2">NOCH FRAGEN?</h2>
      <h3 class="text-center font-bold text-[#1f2025] text-2xl sm:text-3xl mb-10">
        Kindergeburtstag organisieren? Hier sind ein paar Antworten für die perfekte Feier
      </h3>

      <div class="space-y-3" id="faq-list">
        {faqItems.map((item, i) => (
          <div class="faq-item bg-white border border-gray-200 rounded-lg overflow-hidden">
            <button
              class="faq-btn w-full text-left px-6 py-4 font-semibold text-[#1f2025] flex items-center justify-between gap-4"
              aria-expanded="false"
            >
              <span>{item.question}</span>
              <svg class="w-5 h-5 flex-shrink-0 transition-transform faq-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-answer hidden px-6 pb-5 text-[#374151] leading-relaxed">
              {item.answer}
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10">
        <p class="text-[#374151] mb-2 font-semibold">Einfach Kontakt aufnehmen</p>
        <p class="text-[#374151] mb-6 text-sm leading-relaxed max-w-xl mx-auto">
          Sie können mir Ihre Anfrage für einen Kindergeburtstag unverbindlich senden. Ihre Angaben werden selbstverständlich absolut vertraulich behandelt und nicht weitergegeben. Je mehr Angaben ich von Ihnen bekomme, desto besser kann ich Sie beraten. Sie können auch einfach unter 0172-1517578 anrufen oder über WhatsApp schreiben. Ich helfe Ihnen gerne weiter.
        </p>
        <a href="/kontakt/" class="inline-block bg-[#d7393e] hover:bg-[#b62e32] text-white font-bold px-8 py-3 rounded transition-colors">
          Kontaktformular
        </a>
      </div>
    </div>
  </section>

  <!-- Video Sektion -->
  <!-- Wave oben (weiß → blau) -->
  <div style="overflow:hidden;line-height:0;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>
  <section class="py-14 bg-[#3b55d5]">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-white font-extrabold text-xl uppercase tracking-widest mb-6">
        SCHNELLE EINDRÜCKE
      </h2>
      <div class="relative w-full max-w-2xl mx-auto mb-8" style="padding-bottom: 56.25%; position: relative;">
        <iframe
          src="https://www.youtube.com/embed/Cop0SqRIX4Y"
          title="Clown Zauberer für Geburtstag, Feier, Veranstaltung in NRW : die lustigste Zaubershow im Pott!"
          class="absolute inset-0 w-full h-full rounded-lg"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
      <h3 class="text-white font-bold text-xl mb-6">
        Mehr Fotos und Videos in der Galerie
      </h3>
      <a
        href="/galerie/"
        class="inline-block bg-[#f5a623] hover:bg-[#e69420] text-[#1f2025] font-bold px-10 py-4 rounded-full text-base transition-colors"
      >
        Zur Foto- und Videogalerie
      </a>
    </div>
  </section>
  <!-- Wave unten (blau → weiß) -->
  <div style="overflow:hidden;line-height:0;background:#3b55d5;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>



  <!-- Einsatzgebiet -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-[#d7393e] font-bold text-2xl text-center mb-10">Regional und deutschlandweit</h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        <div>
