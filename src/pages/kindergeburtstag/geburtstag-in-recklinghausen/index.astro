---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import karteImg from '../../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import { Image } from 'astro:assets';
import GoogleReviews from '../../../components/GoogleReviews.astro';

const seoTitle = "Kindergeburtstag Recklinghausen | Zaubershow ab 150€";
const seoDescription = "Kindergeburtstag in Recklinghausen feiern! Clown LIAR ✓ Zaubershow ab 150€ ✓ 400+ Bewertungen ✓ Auch in Herten & Marl ✓ Jetzt unverbindlich anfragen!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Geburtstag.jpg';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Kindergeburtstag mit Clown Zauberer in Recklinghausen',
  description: seoDescription,
  provider: {
    '@type': 'LocalBusiness',
    name: 'Clown Zauberer LIAR',
    url: 'https://liar-entertainer.com',
    telephone: '+491721517578',
  },
  areaServed: { '@type': 'City', name: 'Recklinghausen' },
  offers: { '@type': 'Offer', price: '150', priceCurrency: 'EUR', description: '40 Minuten Zaubershow' },
};

const faqItems = [
  {
    question: 'Was braucht Clown LIAR für einen Auftritt?',
    answer: 'Ohne Vorbereitungszeit und mit einer Fläche von 2\u00d72 Meter kann ich eine Show vorführen: Wohnzimmer, Kinderzimmer, Partykeller, Terrasse, Gartenanlage, große und kleine Bühne, Kindergarten, Turnhalle\u2026 Ob drinnen oder draußen, das Programm lässt sich spontan und flexibel ausführen!',
  },
  {
    question: 'Wieviel Platz braucht man für das Programm?',
    answer: 'LIAR ist ziemlich pflegeleicht: für die Show ist es wichtig, dass die Kinder gemütlich und ungestört sitzen können!!! Bei der Ballonmodellage ist nichts weiteres nötig. Bei GLITZER TATTOOS wären schon 2 Stühle und einen Tisch wichtig!',
  },
  {
    question: 'Wie viele Kinder sollten überhaupt eingeladen werden?',
    answer: 'Natürlich soll das Kind seine Freunde einladen. Allerdings sollte man eine feste Zahl als Limit vorgeben. Pädagogen empfehlen, maximal genauso viele Gäste einzuladen, wie das Kind alt wird. Wer kommen darf, soll das Kind selbst bestimmen. Natürlich sind auch dabei die Aufsichtspersonen (mindestens 2) nicht zu vergessen.',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Kindergeburtstag Recklinghausen, Geburtstag Recklinghausen, Clown Kindergeburtstag Recklinghausen, Zauberer Geburtstag Recklinghausen, Kinderparty Recklinghausen, NRW"
  canonical="https://liar-entertainer.com/kindergeburtstag/geburtstag-in-recklinghausen/"
  ogImage={heroImg}
  structuredData={structuredData}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImg}'); background-position: center 20%;`}></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex flex-col items-center justify-center text-center px-6" style="min-height: 600px;">
      <div class="inline-flex items-center gap-2 bg-white/20 text-white rounded-full px-4 py-1.5 text-sm font-medium mb-4 backdrop-blur-sm">
        <span>📍</span> Recklinghausen
      </div>
      <h1 class="text-white font-extrabold text-center leading-tight mb-3" style="font-size: clamp(2rem, 5vw, 3.5rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
        Geburtstag in Recklinghausen
      </h1>
      <p class="text-gray-200 text-base leading-relaxed max-w-xl mx-auto">
        Unvergessliche Kindergeburtstage mit Clown Zauberer LIAR – Lachen, Staunen und pure Magie!
      </p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <section class="bg-white pt-4 pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="text-sm text-[#595959]">
        <a href="/" class="text-[#d7393e] hover:underline">Clown</a>
        <span class="mx-1">»</span>
        <a href="/kindergeburtstag/" class="text-[#d7393e] hover:underline">Kindergeburtstag</a>
        <span class="mx-1">»</span>
        <span>Geburtstag in Recklinghausen</span>
      </nav>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-[#d7393e] font-bold text-xl mb-4">Professionelle Kinderunterhaltung für Recklinghausen und das nördliche Ruhrgebiet</h2>
          <p class="text-[#374151] mb-4 leading-relaxed">Als erfahrener französischer Clown Zauberer mit über 15 Jahren Bühnenerfahrung weiß ich genau, was Kinder begeistert. Meine Shows sind keine starren Vorführungen, sondern lebendige, interaktive Erlebnisse, bei denen jedes Kind zum Mitmachen eingeladen wird. Besonders im Raum Recklinghausen bin ich häufig unterwegs – von der Altstadt über Suderwich bis nach Röllinghausen kenne ich die Gegend bestens und habe schon unzählige kleine Geburtstagsstars glücklich gemacht.</p>
          <p class="text-[#374151] mb-4 leading-relaxed">Viele Eltern in Recklinghausen sind überrascht, wie einfach es ist, professionelle Unterhaltung für den Kindergeburtstag zu buchen. Dabei ist genau das der Schlüssel zu einer entspannten Feier: Sie müssen sich nicht um Animation, Spiele oder Beschäftigung kümmern – ich übernehme das komplett und Sie können die Feier gemeinsam mit Ihrem Kind genießen!</p>
        </div>
        <div class="flex justify-center">
          <img
            src="https://liar-entertainer.com/wp-content/uploads/2023/08/Geburtstag-mit-dem-Clown-768x1024.jpg"
            alt="Kindergeburtstag in Recklinghausen"
            class="rounded-full object-cover object-[20%]"
            style="width: 320px; height: 320px;"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <GoogleReviews />

  <!-- Wave: white → blue -->
  <div style="overflow:hidden;line-height:0;background:white;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>
  <section class="bg-[#3b55d5] py-14 text-white">
    <div class="max-w-5xl mx-auto px-4">
      <p class="text-[#ffb546] font-bold text-sm uppercase tracking-widest mb-4 text-center">RECKLINGHAUSEN</p>
      <h2 class="text-white font-bold text-3xl sm:text-4xl mb-10 text-center">Warum Eltern in Recklinghausen sich für mich entscheiden 😊</h2>
      <p class="text-white leading-relaxed mb-4">Als französischer Künstler mit über 15 Jahren Erfahrung bringe ich eine besondere internationale Note mit. Meine Show ist professionell, liebevoll gestaltet und gleichzeitig authentisch und warmherzig. Ich arbeite nicht mit vorgefertigten Skripten, sondern reagiere auf die Kinder, baue spontane Momente ein und schaffe so ein echtes, lebendiges Erlebnis.</p>
      <p class="text-white leading-relaxed mb-4">Zudem bin ich im nördlichen Ruhrgebiet und besonders in Recklinghausen sehr gut vernetzt. Ich kenne die Region, die Mentalität und weiß, was hier bei Kinderfesten gut ankommt. Diese Verwurzelung in der Region schätzen viele Familien sehr.</p>
    </div>
  </section>
  <!-- Wave: blue → white -->
  <div style="overflow:hidden;line-height:0;background:#3b55d5;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- Die Preise -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-[#d7393e] font-bold text-3xl sm:text-4xl text-center mb-10">Die Preise</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-8 shadow-sm border-t-4 border-[#d7393e]">
          <h3 class="font-bold text-[#1f2025] text-xl mb-2">🎩 Zaubershow</h3>
          <p class="text-[#d7393e] font-bold text-2xl mb-4">150 €</p>
          <ul class="space-y-2 text-[#374151] text-sm mb-6">
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> 40 Minuten voller Zauber, Lachen und Staunen</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Bis ca. 12 Kinder – Mindestalter: 4 Jahre</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Inkl. Material</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Das Geburtstagskind steht immer im Mittelpunkt</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> zzgl. Fahrtkosten (0,40€/km, Hin- &amp; Rückfahrt) ab Gladbeck</li>
          </ul>
          <p class="text-[#374151] text-sm">Direkt ab der ersten Minute nimmt die Show die kleinen Gäste mit auf eine fantasievolle Reise!</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-sm border-t-4 border-[#3b55d5]">
          <h3 class="font-bold text-[#1f2025] text-xl mb-2">🎈 Luftballonmodellage</h3>
          <p class="text-[#3b55d5] font-bold text-2xl mb-4">+ 20 €</p>
          <ul class="space-y-2 text-[#374151] text-sm mb-6">
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Für jedes Kind 1 Ballon</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Ca. 15 Minuten</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Tolle Erinnerung zum Mitnehmen</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Große Auswahl an Figuren: Hund, Schwert, Blume u.v.m.</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Perfekte Ergänzung zur Zaubershow</li>
          </ul>
          <p class="text-[#374151] text-sm">Ob Schwerter, Hunde oder Blumen – die Kinder staunen, wenn aus einem Ballon ihre Wunschfigur entsteht!</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-sm border-t-4 border-[#ffb546]">
          <h3 class="font-bold text-[#1f2025] text-xl mb-2">✨ Glitzer-Tattoos</h3>
          <p class="text-[#d7393e] font-bold text-2xl mb-4">+ 40 €</p>
          <ul class="space-y-2 text-[#374151] text-sm mb-6">
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Für jedes Kind 1 Tattoo</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Ca. 30 Minuten</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Hautverträglich &amp; langanhaltend</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Viele Motive: Einhörner, Schmetterlinge, Sterne u.v.m.</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Hält mehrere Tage auf der Haut</li>
          </ul>
          <p class="text-[#374151] text-sm">Ein funkelndes Highlight, das die Kinder noch Tage nach der Feier begeistert!</p>
        </div>
      </div>
      <div class="text-center mt-10">
        <a href="/kontakt/" class="inline-block bg-[#d7393e] hover:bg-[#b62e32] text-white font-bold px-10 py-4 rounded transition-colors text-base">
          Jetzt unverbindlich anfragen
        </a>
      </div>
    </div>
  </section>

  <!-- Individuell abgestimmt auf Ihr Geburtstagskind -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-[#1f2025] font-bold text-2xl sm:text-3xl text-center mb-6">Individuell abgestimmt auf Ihr Geburtstagskind</h2>
      <p class="text-[#374151] mb-4 leading-relaxed">Jedes Kind ist einzigartig – und das berücksichtige ich in meiner Show. Ob Ihr Kind eher zurückhaltend ist oder voller Tatendrang steckt: Ich passe mein Programm flexibel an die Persönlichkeit des Geburtstagskindes und die Dynamik der Gruppe an. Das Geburtstagskind steht dabei selbstverständlich immer im Mittelpunkt und wird zum strahlenden Star des Nachmittags!Die Altersempfehlung liegt bei 4 bis 10 Jahren, wobei ich mein Programm perfekt auf die jeweilige Altersgruppe zuschneiden kann. Für jüngere Kinder lege ich mehr Wert auf visuelle Gags und einfache Mitmach-Elemente, während ältere Kinder auch komplexere Tricks und mehr Humor genießen können. Die Dauer der Show stimme ich mit Ihnen ab – ob 60, 75 oder 90Minuten, ich gestalte das Programm so, dass keine Langeweile aufkommt und die Aufmerksamkeit durchgehend hoch bleibt.</p>
    </div>
  </section>

  <!-- Wave: white → red (Stats) -->
  <div style="overflow:hidden;line-height:0;background:white;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#d7393e"/>
    </svg>
  </div>

  <!-- Stats Banner -->
  <section class="bg-[#d7393e] py-10 text-white text-center">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-transparent border border-white/30 rounded-xl p-6">
          <div class="text-3xl mb-2">🪄</div>
          <div class="text-4xl font-extrabold">400</div>
          <div class="text-sm mt-1">Shows im Jahr</div>
        </div>
        <div class="bg-transparent border border-white/30 rounded-xl p-6">
          <div class="text-3xl mb-2">😊</div>
          <div class="text-4xl font-extrabold">110.000</div>
          <div class="text-sm mt-1">Lachende Kinder</div>
        </div>
        <div class="bg-transparent border border-white/30 rounded-xl p-6">
          <div class="text-3xl mb-2">🪄</div>
          <div class="text-4xl font-extrabold">15</div>
          <div class="text-sm mt-1">Jahre Erfahrung</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave: red → white -->
  <div style="overflow:hidden;line-height:0;background:#d7393e;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- Was erwartet Sie bei meiner Kindergeburtstags-Show? -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-[#1f2025] font-bold text-2xl sm:text-3xl text-center mb-6">Was erwartet Sie bei meiner Kindergeburtstags-Show?</h2>
      <p class="text-[#374151] text-center leading-relaxed mb-10 max-w-3xl mx-auto">Meine Show beginnt bereits in dem Moment, in dem ich durch die Tür komme. Mit einem Augenzwinkern, einer verlorenen Clownsnase oder einem ersten kleinen Zaubertrick breche ich sofort das Eis.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#d7393e]">
          <div class="text-3xl mb-3">🎭</div>
          <h3 class="font-bold text-[#1f2025] text-lg mb-2">Sofortiger Einstieg</h3>
          <p class="text-[#374151] text-sm leading-relaxed">Kein langes Aufbauen – ich hole alle Kinder ab, selbst die schüchternsten. Diese natürliche, warmherzige Art sorgt dafür, dass sich alle von Anfang an wohl fühlen.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#3b55d5]">
          <div class="text-3xl mb-3">✨</div>
          <h3 class="font-bold text-[#1f2025] text-lg mb-2">Clown trifft Zauberer</h3>
          <p class="text-[#374151] text-sm leading-relaxed">Die perfekte Mischung: Als Clown bringe ich die Kinder zum Lachen, als Zauberer lasse ich sie staunen. Humor und Magie in einer Show!</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#ffb546]">
          <div class="text-3xl mb-3">🌟</div>
          <h3 class="font-bold text-[#1f2025] text-lg mb-2">Kinder als Stars</h3>
          <p class="text-[#374151] text-sm leading-relaxed">Die Kinder werden selbst zu kleinen Zauberern! Sie dürfen auf die „Bühne", assistieren bei Tricks und erleben hautnah, wie Magie entsteht.</p>
        </div>
      </div>
      <p class="text-[#374151] text-center leading-relaxed max-w-3xl mx-auto">Diese aktive Teilnahme macht den Unterschied – statt 40 Minuten stillzusitzen, sind die Kinder mittendrin im Geschehen, voller Energie und Begeisterung.</p>
    </div>
  </section>
  <!-- FAQ -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-center font-bold text-[#1f2025] text-sm uppercase tracking-widest mb-2">NOCH FRAGEN?</h2>
      <h3 class="text-center font-bold text-[#1f2025] text-2xl sm:text-3xl mb-10">
        Hier sind ein paar Antworten
      </h3>

      <div class="space-y-3" id="faq-list">
        <div class="faq-item bg-white border border-gray-200 rounded-lg overflow-hidden">
          <button
            class="faq-btn w-full text-left px-6 py-4 font-semibold text-[#1f2025] flex items-center justify-between gap-4"
            aria-expanded="false"
          >
            <span>Was braucht Clown LIAR für einen Auftritt?</span>
            <svg class="w-5 h-5 flex-shrink-0 transition-transform faq-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-answer hidden px-6 pb-5 text-[#374151] leading-relaxed">
            Ohne Vorbereitungszeit und mit einer Fläche von 2×2 Meter kann ich eine Show vorführen: Wohnzimmer, Kinderzimmer, Partykeller, Terrasse, Gartenanlage, große und kleine Bühne, Kindergarten, Turnhalle… Ob drinnen oder draußen, das Programm lässt sich spontan und flexibel ausführen!
          </div>
        </div>
        <div class="faq-item bg-white border border-gray-200 rounded-lg overflow-hidden">
          <button
            class="faq-btn w-full text-left px-6 py-4 font-semibold text-[#1f2025] flex items-center justify-between gap-4"
            aria-expanded="false"
          >
            <span>Wieviel Platz braucht man für das Programm?</span>
            <svg class="w-5 h-5 flex-shrink-0 transition-transform faq-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-answer hidden px-6 pb-5 text-[#374151] leading-relaxed">
            LIAR ist ziemlich pflegeleicht: für die Show ist es wichtig, dass die Kinder gemütlich und ungestört sitzen können!!! Bei der Ballonmodellage ist nichts weiteres nötig. Bei GLITZER TATTOOS wären schon 2 Stühle und einen Tisch wichtig!
          </div>
        </div>
        <div class="faq-item bg-white border border-gray-200 rounded-lg overflow-hidden">
          <button
            class="faq-btn w-full text-left px-6 py-4 font-semibold text-[#1f2025] flex items-center justify-between gap-4"
            aria-expanded="false"
          >
            <span>Wie viele Kinder sollten überhaupt eingeladen werden?</span>
            <svg class="w-5 h-5 flex-shrink-0 transition-transform faq-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-answer hidden px-6 pb-5 text-[#374151] leading-relaxed">
            Natürlich soll das Kind seine Freunde einladen. Allerdings sollte man eine feste Zahl als Limit vorgeben. Pädagogen empfehlen, maximal genauso viele Gäste einzuladen, wie das Kind alt wird. Wer kommen darf, soll das Kind selbst bestimmen. Natürlich sind auch dabei die Aufsichtspersonen (mindestens 2) nicht zu vergessen.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Video Sektion -->
  <!-- Wave oben (weiß → blau) -->
  <div style="overflow:hidden;line-height:0;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>
  <section class="py-14 bg-[#3b55d5]">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-white font-extrabold text-xl uppercase tracking-widest mb-6">
        SCHNELLE EINDRÜCKE
      </h2>
      <div class="relative w-full max-w-2xl mx-auto mb-8" style="padding-bottom: 56.25%; position: relative;">
        <iframe
          src="https://www.youtube.com/embed/Cop0SqRIX4Y"
          title="Clown Zauberer für Geburtstag, Feier, Veranstaltung in NRW : die lustigste Zaubershow im Pott!"
          class="absolute inset-0 w-full h-full rounded-lg"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
      <h3 class="text-white font-bold text-xl mb-6">
        Mehr Fotos und Videos in der Galerie
      </h3>
      <a
        href="/galerie/"
        class="inline-block bg-[#f5a623] hover:bg-[#e69420] text-[#1f2025] font-bold px-10 py-4 rounded-full text-base transition-colors"
      >
        Zur Foto- und Videogalerie
      </a>
    </div>
  </section>
  <!-- Wave unten (blau → weiß) -->
