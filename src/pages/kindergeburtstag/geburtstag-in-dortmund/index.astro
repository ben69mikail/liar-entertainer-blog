---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import karteImg from '../../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import { Image } from 'astro:assets';
import GoogleReviews from '../../../components/GoogleReviews.astro';

const seoTitle = "Kindergeburtstag Dortmund | Zaubershow ab 150€";
const seoDescription = "Kindergeburtstag in Dortmund feiern! Clown Zauberer LIAR ✓ Zaubershow ab 150€ ✓ 400+ Bewertungen ✓ Auch in Bochum & Herne ✓ Jetzt unverbindlich anfragen!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Geburtstag.jpg';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Kindergeburtstag mit Clown Zauberer in Dortmund',
  description: seoDescription,
  provider: {
    '@type': 'LocalBusiness',
    name: 'Clown Zauberer LIAR',
    url: 'https://liar-entertainer.com',
    telephone: '+491721517578',
  },
  areaServed: { '@type': 'City', name: 'Dortmund' },
  offers: { '@type': 'Offer', price: '150', priceCurrency: 'EUR', description: '40 Minuten Zaubershow' },
};

const faqItems = [
  {
    question: 'Wie weit im Voraus muss ich buchen?',
    answer: 'Ideal sind 3-4 Wochen. An beliebten Samstagen kann es auch mal schneller ausgebucht sein. Aber: Fragen kostet nichts! Manchmal habe ich auch kurzfristig Lücken.',
  },
  {
    question: 'Was ist mit sehr jungen oder älteren Kindern?',
    answer: 'Ab 4 Jahre optimal. Aber auch mit 3-Jährigen oder 11-Jährigen funktioniert es – ich passe mein Programm einfach an. Sprechen Sie mich darauf an!',
  },
  {
    question: 'Brauchen Sie Strom, Musik, Mikrofon?',
    answer: 'Nein, nein und nein! Meine Show ist „unplugged". Kein technischer Schnickschnack nötig. Das macht mich flexibel und unabhängig.',
  },
  {
    question: 'Können Eltern zuschauen?',
    answer: 'Klar! Die meisten Eltern bleiben im Hintergrund und freuen sich über die Reaktionen ihrer Kinder. Manche machen Fotos – absolut erwünscht!',
  },
  {
    question: 'Was kostet ein Clown Zauberer für einen Kindergeburtstag?',
    answer: 'Die Preise für Kindergeburtstage starten ab 150 Euro. Die genaue Gage ist abhängig von Art und Umfang der Veranstaltung, Zuschauerzahl, Anfahrtsweg und Jahreszeit. Für ein individuelles, unverbindliches Angebot kontaktieren Sie mich unter 0172-1517578 oder info@liar-entertainer.com.',
  },
  {
    question: 'Wie lange dauert eine Clown & Zaubershow für Kinder?',
    answer: 'Die Show dauert 40 Minuten, je nach Alter der Kinder und Ihren Wünschen. Die Dauer wird individuell an Ihre Veranstaltung angepasst. Zusätzlich kann Ballonmodellage oder Glitzer-Tattoos dazugebucht werden.',
  },
  {
    question: 'Wie viel Platz braucht man für die Clown- und Zaubershow?',
    answer: 'Minimal nur 2x2 Meter Fläche. Die Show funktioniert überall: Wohnzimmer, Kinderzimmer, Partykeller, Terrasse, Garten, Turnhalle, Kindergarten, Schule oder Bücherei. Keine Aufbauzeit und es wird fast keine Vorbereitung benötigt.',
  },
  {
    question: 'Welche Leistungen sind im Kindergeburtstag-Paket enthalten?',
    answer: 'Im Basis-Paket ist eine 40 minütige Clown & Zaubershow enthalten, bei der Kinder aktiv mitmachen. Optional zubuchbar: Ballonmodellage (jedes Kind bekommt eine Wunschfigur zum Mitnehmen) und Glitzer-Tattoos (hautverträglich, hält 5-7 Tage, über 50 Motive). Alles wird von LIAR mitgebracht - Sie stellen nur den Platz!',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Kindergeburtstag Dortmund, Geburtstag Dortmund, Clown Kindergeburtstag Dortmund, Zauberer Geburtstag Dortmund, Kinderparty Dortmund, NRW"
  canonical="https://liar-entertainer.com/kindergeburtstag/geburtstag-in-dortmund/"
  ogImage={heroImg}
  structuredData={structuredData}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImg}'); background-position: center 20%;`}></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex flex-col items-center justify-center text-center px-6" style="min-height: 600px;">
      <div class="inline-flex items-center gap-2 bg-white/20 text-white rounded-full px-4 py-1.5 text-sm font-medium mb-4 backdrop-blur-sm">
        <span>📍</span> Dortmund
      </div>
      <h1 class="text-white font-extrabold text-center leading-tight mb-3" style="font-size: clamp(2rem, 5vw, 3.5rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
        Geburtstag in Dortmund: Der Guide für Eltern in der Großstadt
      </h1>
      <p class="text-gray-200 text-base leading-relaxed max-w-xl mx-auto">
        Unvergessliche Kindergeburtstage mit Clown Zauberer LIAR – Lachen, Staunen und pure Magie!
      </p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <section class="bg-white pt-4 pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="text-sm text-[#595959]">
        <a href="/" class="text-[#d7393e] hover:underline">Clown</a>
        <span class="mx-1">&raquo;</span>
        <a href="/kindergeburtstag/" class="text-[#d7393e] hover:underline">Kindergeburtstag</a>
        <span class="mx-1">&raquo;</span>
        <span>Geburtstag in Dortmund</span>
      </nav>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-[#d7393e] font-bold text-xl mb-4">Professionelle Kinderunterhaltung für den Geburtstag in Dortmund</h2>
          <p class="text-[#374151] mb-4 leading-relaxed">
            In einer Großstadt haben Eltern unzählige Optionen und für einen Geburtstag in Dortmund sind die Möglichkeiten unendlich: vom Westfalenpark über das DASA-Museum bis zum Zoo. Doch manchmal ist das Beste das Einfachste – eine professionelle Show direkt bei Ihnen zu Hause.
          </p>
          <p class="text-[#374151] mb-4 leading-relaxed">
            Als Clown-Zauberer bringe ich seit 15 Jahren magische Momente zu Familien in ganz Dortmund: Hörde, Hombruch, Brackel, Aplerbeck, Mengede und allen anderen Stadtbezirken. Mein Versprechen: Ein <a href="/kindergeburtstag/" class="text-[#d7393e] hover:underline">Kindergeburtstag</a>, der nicht im Großstadt-Trubel untergeht, sondern persönlich und unvergesslich wird.
          </p>
        </div>
        <div class="flex justify-center">
          <img
            src="https://liar-entertainer.com/wp-content/uploads/2023/08/Geburtstag-mit-dem-Clown-768x1024.jpg"
            alt="Kindergeburtstag in Dortmund mit Clown Zauberer"
            class="rounded-full object-cover object-[20%]"
            style="width: 320px; height: 320px;"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <GoogleReviews />

  <!-- Dortmund ist groß – aber meine Show passt überall hin -->
  <section class="bg-white py-14">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-[#1f2025] font-bold text-2xl sm:text-3xl text-center mb-6">Dortmund ist groß – aber meine Show passt überall hin</h2>
      <p class="text-[#374151] mb-8 leading-relaxed text-center">Das Besondere an Dortmund? Die Stadt ist riesig! Jeder Stadtteil hat seinen eigenen Charakter. Und genau deshalb ist eine mobile Show ideal:</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="font-bold text-[#1f2025] text-lg mb-2">Keine Anfahrtsprobleme</h3>
          <p class="text-[#374151] leading-relaxed">Sie kennen das: Mit 10 Kindern quer durch Dortmund zum Veranstaltungsort? Ein logistischer Albtraum! Parkplatzsuche in der Innenstadt? Stress pur! Bei mir entfällt das alles – ich komme zu Ihnen.</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="font-bold text-[#1f2025] text-lg mb-2">Heimvorteil für Ihr Kind</h3>
          <p class="text-[#374151] leading-relaxed">In der eigenen Umgebung fühlen sich Kinder am wohlsten. Keine Überforderung durch fremde Umgebungen, kein Stress durch Ortswechsel. Einfach entspannt zu Hause feiern.</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="font-bold text-[#1f2025] text-lg mb-2">Unabhängig vom Wetter</h3>
          <p class="text-[#374151] leading-relaxed">Dortmund im November? Regen! Im April? Auch Regen! Bei einer Show zu Hause ist das Wetter egal. Plan B ist bereits Plan A.</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="font-bold text-[#1f2025] text-lg mb-2">Keine versteckten Kosten</h3>
          <p class="text-[#374151] leading-relaxed">Keine Eintrittspreise, keine Parkgebühren, keine teuren Zusatz-Pakete. Sie wissen genau, was Sie bezahlen.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave: white → red (Stats) -->
  <div style="overflow:hidden;line-height:0;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#d7393e"/>
    </svg>
  </div>

  <!-- Stats Banner -->
  <section class="w-full bg-[#d7393e] py-10 text-center">
    <div class="max-w-4xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-transparent border border-white/30 rounded-xl p-6">
        <div class="text-3xl mb-2">🪄</div>
        <div class="text-4xl font-extrabold text-white">400</div>
        <div class="text-white text-sm mt-1">Shows im Jahr</div>
      </div>
      <div class="bg-transparent border border-white/30 rounded-xl p-6">
        <div class="text-3xl mb-2">😊</div>
        <div class="text-4xl font-extrabold text-white">110.000</div>
        <div class="text-white text-sm mt-1">Lachende Kinder</div>
      </div>
      <div class="bg-transparent border border-white/30 rounded-xl p-6">
        <div class="text-3xl mb-2">🪄</div>
        <div class="text-4xl font-extrabold text-white">15</div>
        <div class="text-white text-sm mt-1">Jahre Erfahrung</div>
      </div>
    </div>
  </section>

  <!-- Wave: red → white -->
  <div style="overflow:hidden;line-height:0;background:#d7393e;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- Was unterscheidet meine Show von anderen Optionen? -->
  <section class="bg-white py-14">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-[#1f2025] font-bold text-2xl sm:text-3xl text-center mb-4">Was unterscheidet meine Show von anderen Optionen?</h2>
      <p class="text-[#374151] text-center mb-10 leading-relaxed">Lassen Sie uns ehrlich sein: In Dortmund gibt es viele Entertainment-Optionen. Warum sollten Sie ausgerechnet einen Clown-Zauberer buchen?</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#d7393e]">
          <h3 class="font-bold text-[#1f2025] text-lg mb-3">Die Alternative: Indoorspielplatz</h3>
          <p class="text-[#374151] leading-relaxed mb-2"><strong>Vorteile:</strong> Kinder können sich austoben, verschiedene Stationen</p>
          <p class="text-[#374151] leading-relaxed"><strong>Nachteile:</strong> Laut, unpersönlich, teuer (10-15 € pro Kind), oft überfüllt, Sie müssen ständig aufpassen</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#3b55d5]">
          <h3 class="font-bold text-[#1f2025] text-lg mb-3">Die Alternative: Zoo oder Museum</h3>
          <p class="text-[#374151] leading-relaxed mb-2"><strong>Vorteile:</strong> Bildungswert, etwas Besonderes</p>
          <p class="text-[#374151] leading-relaxed"><strong>Nachteile:</strong> Wetterabhängig, logistisch aufwendig, nicht alle Kinder interessieren sich dafür, teuer, kaum Geburtstagsatmosphäre</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#ffb546]">
          <h3 class="font-bold text-[#1f2025] text-lg mb-3">Die Alternative: Selbstorganisation</h3>
          <p class="text-[#374151] leading-relaxed mb-2"><strong>Vorteile:</strong> Kostengünstig, volle Kontrolle</p>
          <p class="text-[#374151] leading-relaxed"><strong>Nachteile:</strong> Stressig für Sie, Kinder verlieren schnell Interesse, chaotisch, Sie können den Tag nicht genießen</p>
        </div>
      </div>

      <!-- Meine Show: Das Beste aus allen Welten -->
      <div class="bg-gray-50 rounded-xl p-8 max-w-3xl mx-auto">
        <h3 class="font-bold text-[#1f2025] text-xl mb-4 text-center">Meine Show: Das Beste aus allen Welten</h3>
        <ul class="space-y-3 text-[#374151]">
          <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">✓</span> Zu Hause (entspannt für alle)</li>
          <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">✓</span> Professionell (Kinder sind 40 Minuten gebannt)</li>
          <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">✓</span> Inklusiv (jedes Kind macht mit)</li>
          <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">✓</span> Persönlich (Ihr Kind ist der Star)</li>
          <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">✓</span> Kalkulierbar (Festpreis 150 €)</li>
          <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">✓</span> Sie können entspannen (ich übernehme)</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Wave: white → blue -->
  <div style="overflow:hidden;line-height:0;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>

  <!-- Blue Section: So funktioniert eine Show -->
  <section class="bg-[#3b55d5] py-14 text-white">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-[#ffb546] font-bold text-sm uppercase tracking-widest mb-4 text-center">DORTMUND</p>
      <h2 class="text-white font-bold text-3xl sm:text-4xl mb-8 text-center">So funktioniert eine Show in Dortmund-Hörde, Hombruch oder überall sonst</h2>
      <p class="text-white leading-relaxed mb-8 text-center">Egal ob Sie in einer Hochhauswohnung in der Nordstadt wohnen oder in einem Einfamilienhaus in Aplerbeck – die Show passt sich an:</p>

      <div class="space-y-6">
        <div>
          <h3 class="text-white font-bold text-lg mb-2">Schritt 1: Ankommen und Loslegen</h3>
          <p class="text-white leading-relaxed">Ich komme mit meinem Equipment, parke (meist problemlos in Wohngebieten), grüße Sie kurz und baue meine Requisiten auf während der Clown die Kinder unterhält. Schnell und unkompliziert.</p>
        </div>
        <div>
          <h3 class="text-white font-bold text-lg mb-2">Schritt 2: Die Show</h3>
          <p class="text-white leading-relaxed">Jetzt gehört die Bühne (aka Ihr Wohnzimmer) mir und den Kindern. Sie können zuschauen oder in der Zeit letzte Vorbereitungen treffen. Die Kinder sind voll dabei – keine Langeweile, kein Chaos.</p>
        </div>
        <div>
          <h3 class="text-white font-bold text-lg mb-2">Schritt 3: Optional – Ballons und Tattoos</h3>
          <p class="text-white leading-relaxed">Falls gebucht, kommen jetzt die Extras. Kinder lieben es, ihr eigenes Ballontier zu wählen oder ein Glitzer-Tattoo auszusuchen.</p>
        </div>
        <div>
          <h3 class="text-white font-bold text-lg mb-2">Schritt 4: Ich verschwinde wieder</h3>
          <p class="text-white leading-relaxed">Ich packe zusammen und bin weg. Sie starten in den Kuchen-Teil des Geburtstags mit zufriedenen, glücklichen Kindern.</p>
        </div>
      </div>

      <p class="text-white font-bold text-center mt-8">Gesamtdauer: 40-85 Minuten (je nach Extras)</p>
    </div>
  </section>

  <!-- Wave: blue → white -->
  <div style="overflow:hidden;line-height:0;background:#3b55d5;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- Die Preise (3-Karten) -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-[#d7393e] font-bold text-3xl sm:text-4xl text-center mb-10">Die Preise</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-8 shadow-sm border-t-4 border-[#d7393e]">
          <h3 class="font-bold text-[#1f2025] text-xl mb-2">🎩 Zaubershow</h3>
          <p class="text-[#d7393e] font-bold text-2xl mb-4">150 €</p>
          <ul class="space-y-2 text-[#374151] text-sm mb-6">
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> 40 Minuten voller Zauber, Lachen und Staunen</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Bis ca. 12 Kinder – Mindestalter: 4 Jahre</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Inkl. Material</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Das Geburtstagskind steht immer im Mittelpunkt</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> zzgl. Fahrtkosten (0,40€/km, Hin- &amp; Rückfahrt) ab Gladbeck</li>
          </ul>
          <p class="text-[#374151] text-sm">Direkt ab der ersten Minute nimmt die Show die kleinen Gäste mit auf eine fantasievolle Reise!</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-sm border-t-4 border-[#3b55d5]">
          <h3 class="font-bold text-[#1f2025] text-xl mb-2">🎈 Luftballonmodellage</h3>
          <p class="text-[#3b55d5] font-bold text-2xl mb-4">+ 20 €</p>
          <ul class="space-y-2 text-[#374151] text-sm mb-6">
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Für jedes Kind 1 Ballon</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Ca. 15 Minuten</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Tolle Erinnerung zum Mitnehmen</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Große Auswahl an Figuren: Hund, Schwert, Blume u.v.m.</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Perfekte Ergänzung zur Zaubershow</li>
          </ul>
          <p class="text-[#374151] text-sm">Ob Schwerter, Hunde oder Blumen – die Kinder staunen, wenn aus einem Ballon ihre Wunschfigur entsteht!</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-sm border-t-4 border-[#ffb546]">
          <h3 class="font-bold text-[#1f2025] text-xl mb-2">✨ Glitzer-Tattoos</h3>
          <p class="text-[#d7393e] font-bold text-2xl mb-4">+ 40 €</p>
          <ul class="space-y-2 text-[#374151] text-sm mb-6">
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Für jedes Kind 1 Tattoo</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Ca. 30 Minuten</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Hautverträglich &amp; langanhaltend</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Viele Motive: Einhörner, Schmetterlinge, Sterne u.v.m.</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Hält mehrere Tage auf der Haut</li>
          </ul>
          <p class="text-[#374151] text-sm">Ein funkelndes Highlight, das die Kinder noch Tage nach der Feier begeistert!</p>
        </div>
      </div>
      <div class="text-center mt-10">
        <a href="/kontakt/" class="inline-block bg-[#d7393e] hover:bg-[#b62e32] text-white font-bold px-10 py-4 rounded transition-colors text-base">
          Jetzt unverbindlich anfragen
        </a>
      </div>
    </div>
  </section>
  <!-- Video Sektion -->
  <!-- Wave oben (weiß → blau) -->
  <div style="overflow:hidden;line-height:0;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>
  <section class="py-14 bg-[#3b55d5]">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-white font-extrabold text-xl uppercase tracking-widest mb-6">
        SCHNELLE EINDRÜCKE
      </h2>
      <div class="relative w-full max-w-2xl mx-auto mb-8" style="padding-bottom: 56.25%; position: relative;">
        <iframe
          src="https://www.youtube.com/embed/Cop0SqRIX4Y"
          title="Clown Zauberer für Geburtstag, Feier, Veranstaltung in NRW : die lustigste Zaubershow im Pott!"
          class="absolute inset-0 w-full h-full rounded-lg"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
