---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import karteImg from '../../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import { Image } from 'astro:assets';
import GoogleReviews from '../../../components/GoogleReviews.astro';

const seoTitle = "Kindergeburtstag Dorsten | Zaubershow ab 150€";
const seoDescription = "Kindergeburtstag in Dorsten mit Clown LIAR ✓ Zaubershow ab 150€ ✓ Glitzer-Tattoos ✓ 400+ Top-Bewertungen ✓ Auch in Marl & Haltern ✓ Jetzt buchen!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Geburtstag.jpg';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Kindergeburtstag mit Clown Zauberer in Dorsten',
  description: seoDescription,
  provider: {
    '@type': 'LocalBusiness',
    name: 'Clown Zauberer LIAR',
    url: 'https://liar-entertainer.com',
    telephone: '+491721517578',
  },
  areaServed: { '@type': 'City', name: 'Dorsten' },
  offers: { '@type': 'Offer', price: '150', priceCurrency: 'EUR', description: '40 Minuten Zaubershow' },
};

const faqItems = [
  {
    question: 'Wie lange vorher buchen?',
    answer: 'Ideal: 3-4 Wochen. Bei mir gilt: First come, first served. Samstage im Sommer sind heiß begehrt. Aber unter der Woche habe ich oft noch kurzfristig Kapazitäten.',
  },
  {
    question: 'Was müssen Sie vorbereiten?',
    answer: 'Ehrlich? Fast nichts. Die Kinder brauchen Platz zum Sitzen (Stühle, Kissen, egal). Bei Glitzer-Tattoos wären Tisch + Stühle praktisch. Das war\'s. Ich bringe den Rest.',
  },
  {
    question: 'Welche Altersgruppe ist ideal?',
    answer: 'Ab 4 Jahre läuft es super. Bis 10 Jahre haben alle Spaß. Bei gemischten Altersgruppen passe ich das Programm dynamisch an – kein Problem!',
  },
  {
    question: 'Funktioniert das draußen im Garten?',
    answer: 'Ja! Gerade im Sommer ist das wunderbar. Mein Tipp: Haben Sie Plan B (drinnen) für den Fall von Regen. Aber bei Sonnenschein im Garten? Magisch!',
  },
  {
    question: 'Was bei sehr kleinen Räumen?',
    answer: 'Kein Problem! Ich brauche tatsächlich nur wenige Quadratmeter. Ein durchschnittliches Wohnzimmer reicht völlig. Die Show ist flexibel konzipiert.',
  },
  {
    question: 'Können Geschwister/Eltern zuschauen?',
    answer: 'Unbedingt! Je mehr, desto besser die Stimmung. Eltern sind oft genauso begeistert wie die Kinder. Und Geschwister? Sind natürlich auch Teil der Show!',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Kindergeburtstag Dorsten, Geburtstag Dorsten, Clown Kindergeburtstag Dorsten, Zauberer Geburtstag Dorsten, Kinderparty Dorsten, NRW"
  canonical="https://liar-entertainer.com/kindergeburtstag/geburtstag-in-dorsten/"
  ogImage={heroImg}
  structuredData={structuredData}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImg}'); background-position: center 20%;`}></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex flex-col items-center justify-center text-center px-6" style="min-height: 600px;">
      <div class="inline-flex items-center gap-2 bg-white/20 text-white rounded-full px-4 py-1.5 text-sm font-medium mb-4 backdrop-blur-sm">
        <span>📍</span> Dorsten
      </div>
      <h1 class="text-white font-extrabold text-center leading-tight mb-3" style="font-size: clamp(2rem, 5vw, 3.5rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
        Geburtstag in Dorsten
      </h1>
      <p class="text-gray-200 text-base leading-relaxed max-w-xl mx-auto">
        Erfolgsrezepte für unvergessliche Feiern
      </p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <section class="bg-white pt-4 pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="text-sm text-[#595959]">
        <a href="/" class="text-[#d7393e] hover:underline">Clown</a>
        <span class="mx-1">&raquo;</span>
        <a href="/kindergeburtstag/" class="text-[#d7393e] hover:underline">Kindergeburtstag</a>
        <span class="mx-1">&raquo;</span>
        <span>Geburtstag in Dorsten</span>
      </nav>
    </div>
  </section>

  <!-- Intro Section: Text + Bild -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-[#d7393e] font-bold text-xl mb-4">Der Entertainer, der Kinderträume in Dorsten wahr macht</h2>
          <p class="text-[#374151] mb-4 leading-relaxed">
            Wissen Sie, was den perfekten Kindergeburtstag in Dorsten ausmacht? Es sind nicht die teuersten Geschenke oder die aufwendigste Dekoration. Es ist der Moment, wenn Ihr Kind mit leuchtenden Augen zu Ihnen läuft und flüstert: „Das war der BESTE Geburtstag EVER!"
          </p>
          <p class="text-[#374151] mb-4 leading-relaxed">
            Seit 15 Jahren kreiere ich genau solche Momente in Dorsten – von der Innenstadt über Holsterhausen bis nach Wulfen. Als Clown-Zauberer habe ich eine Mission: Kindergeburtstage zu schaffen, über die Kinder noch Monate später reden.
          </p>
        </div>
        <div class="flex justify-center">
          <img
            src="https://liar-entertainer.com/wp-content/uploads/2023/08/Geburtstag-mit-dem-Clown-768x1024.jpg"
            alt="Kindergeburtstag in Dorsten mit Clown Zauberer"
            class="rounded-full object-cover object-[20%]"
            style="width: 320px; height: 320px;"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <GoogleReviews />

  <!-- 3 Zutaten für einen erfolgreichen Kindergeburtstag -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-[#1f2025] font-bold text-2xl sm:text-3xl text-center mb-4">Was macht einen Kindergeburtstag wirklich erfolgreich?</h2>
      <p class="text-[#374151] text-center mb-10 leading-relaxed">Nach hunderten Feiern in Dorsten habe ich ein klares Muster erkannt. Erfolgreiche Kindergeburtstage haben drei Zutaten:</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Zutat 1 -->
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#d7393e]">
          <div class="w-12 h-12 rounded-full bg-[#d7393e] text-white flex items-center justify-center font-extrabold text-xl mb-4">1</div>
          <h3 class="font-bold text-[#1f2025] text-lg mb-2">Ein klarer Fokus</h3>
          <p class="text-[#374151] text-sm leading-relaxed">
            Viele Eltern überladen den Geburtstag mit zu vielen Aktivitäten. Schatzsuche, Topfschlagen, Basteln, Kuchen, noch mehr Spiele… Am Ende sind alle erschöpft und keiner hatte richtig Spaß. Besser: EIN Highlight, das alle begeistert. Bei mir ist das eine 40-minütige Show, die alle fesselt.
          </p>
        </div>
        <!-- Zutat 2 -->
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#3b55d5]">
          <div class="w-12 h-12 rounded-full bg-[#3b55d5] text-white flex items-center justify-center font-extrabold text-xl mb-4">2</div>
          <h3 class="font-bold text-[#1f2025] text-lg mb-2">Inklusion aller Kinder</h3>
          <p class="text-[#374151] text-sm leading-relaxed">
            Das größte Problem bei Kindergeburtstagen? Manche Kinder fühlen sich ausgeschlossen. Der sportliche Junge gewinnt alle Wettspiele, schüchterne Kinder trauen sich nicht mitzumachen. Bei meiner Zaubershow gibt es keine Verlierer – jedes Kind ist ein Star.
          </p>
        </div>
        <!-- Zutat 3 -->
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#ffb546]">
          <div class="w-12 h-12 rounded-full bg-[#ffb546] text-white flex items-center justify-center font-extrabold text-xl mb-4">3</div>
          <h3 class="font-bold text-[#1f2025] text-lg mb-2">Entlastung für Sie</h3>
          <p class="text-[#374151] text-sm leading-relaxed">
            Hand aufs Herz: Kindergeburtstage sind anstrengend. Die Planung, die Durchführung, das Aufräumen danach. Mit einem professionellen Entertainer geben Sie die Verantwortung ab – und können den Tag tatsächlich genießen.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave: white → blue -->
  <div style="overflow:hidden;line-height:0;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>

  <!-- Blue Section: Magic Formula -->
  <section class="bg-[#3b55d5] py-14 text-white">
    <div class="max-w-5xl mx-auto px-4">
      <p class="text-[#ffb546] font-bold text-sm uppercase tracking-widest mb-4 text-center">MEINE SHOW</p>
      <h2 class="text-white font-bold text-3xl sm:text-4xl mb-10 text-center">So funktioniert die Magic-Formula</h2>
      <p class="text-white leading-relaxed mb-10 text-center max-w-3xl mx-auto">
        Lassen Sie mich Ihnen zeigen, wie ich arbeite. Es ist ein bewährtes System, das in 15 Jahren perfektioniert wurde:
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Schritt 1 -->
        <div class="bg-white/10 rounded-xl p-6">
          <div class="w-10 h-10 rounded-full bg-[#ffb546] text-[#1f2025] flex items-center justify-center font-extrabold text-lg mb-3">1</div>
          <h3 class="font-bold text-white text-base mb-2">Der Wow-Einstieg</h3>
          <p class="text-white text-sm leading-relaxed">
            Ich starte NICHT mit „Hallo Kinder, ich bin der Zauberer". Das wäre langweilig. Stattdessen passiert sofort etwas Unerwartetes. Ein Gegenstand verschwindet. Taucht woanders auf. Die Kinder: „WAS?!" – und ab diesem Moment habe ich ihre volle Aufmerksamkeit.
          </p>
        </div>
        <!-- Schritt 2 -->
        <div class="bg-white/10 rounded-xl p-6">
          <div class="w-10 h-10 rounded-full bg-[#ffb546] text-[#1f2025] flex items-center justify-center font-extrabold text-lg mb-3">2</div>
          <h3 class="font-bold text-white text-base mb-2">Der Geburtstagskind-Gipfel</h3>
          <p class="text-white text-sm leading-relaxed">
            Hier kommt der emotionale Höhepunkt. Ihr Kind führt DEN spektakulärsten Trick vor. Ich habe ihn extra für diesen Moment aufgehoben. Die Reaktion? Tosender Applaus! Ihr Kind fühlt sich wie ein Superstar. Dieser Moment zahlt sich aus.
          </p>
        </div>
        <!-- Schritt 3 -->
        <div class="bg-white/10 rounded-xl p-6">
          <div class="w-10 h-10 rounded-full bg-[#ffb546] text-[#1f2025] flex items-center justify-center font-extrabold text-lg mb-3">3</div>
          <h3 class="font-bold text-white text-base mb-2">Die Beteiligungswelle</h3>
          <p class="text-white text-sm leading-relaxed">
            Jetzt hole ich systematisch jedes Kind in die Show. Nicht alle auf einmal – das wäre Chaos. Sondern nacheinander, jedes mit einer kleinen Aufgabe. Plötzlich sind SIE die Zauberer. Die anderen schauen zu und feuern an. Teamgeist entsteht.
          </p>
        </div>
        <!-- Schritt 4 -->
        <div class="bg-white/10 rounded-xl p-6">
          <div class="w-10 h-10 rounded-full bg-[#ffb546] text-[#1f2025] flex items-center justify-center font-extrabold text-lg mb-3">4</div>
          <h3 class="font-bold text-white text-base mb-2">Das Grand Finale</h3>
          <p class="text-white text-sm leading-relaxed">
            Zum Abschluss noch ein Knalleffekt, den KEINER erwartet. Die Show endet auf dem absoluten Peak. Resultat: Die Kinder wollen mehr. Und genau das ist der Punkt – lieber aufhören, wenn es am schönsten ist.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave: blue → white -->
  <div style="overflow:hidden;line-height:0;background:#3b55d5;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- Die Preise -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-[#d7393e] font-bold text-3xl sm:text-4xl text-center mb-4">Was Sie für 150 Euro bekommen – der ehrliche Überblick</h2>
      <p class="text-[#374151] text-center mb-10 leading-relaxed">Ich glaube an Transparenz. Hier ist genau, was im Preis enthalten ist:</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Zaubershow -->
        <div class="bg-white rounded-xl p-8 shadow-sm border-t-4 border-[#d7393e]">
          <h3 class="font-bold text-[#1f2025] text-xl mb-2">🎩 Zaubershow</h3>
          <p class="text-[#d7393e] font-bold text-2xl mb-4">150 €</p>
          <ul class="space-y-2 text-[#374151] text-sm mb-6">
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Komplette 40-Minuten-Show – Mix aus Zauberei und Clownerie</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Alle Requisiten und Materialien inklusive</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Für bis zu 12 Kinder (ab 4 Jahren)</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Geburtstagskind als Haupt-Protagonist</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Kein Wochentags-Aufschlag – 150 € gilt immer</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> zzgl. Fahrtkosten (0,40€/km, Hin- &amp; Rückfahrt) ab Gladbeck</li>
          </ul>
          <p class="text-[#374151] text-sm">Warum dieser Preis fair ist: Sie sparen sich Eintritt für Indoorspielplatz (oft 10-15 € pro Kind = 120-180 €) – Keine zusätzlichen Kosten für Location-Miete – Professionelle Unterhaltung statt improvisierte Spiele.</p>
        </div>
        <!-- Ballonmodellage -->
        <div class="bg-white rounded-xl p-8 shadow-sm border-t-4 border-[#3b55d5]">
          <h3 class="font-bold text-[#1f2025] text-xl mb-2">🎈 Ballonmodellage</h3>
          <p class="text-[#3b55d5] font-bold text-2xl mb-4">+ 20 €</p>
          <ul class="space-y-2 text-[#374151] text-sm mb-6">
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> 15 Minuten pure Begeisterung</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Jedes Kind bekommt SEIN Wunsch-Ballontier</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Tolle Erinnerung zum Mitnehmen</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Große Auswahl an Figuren: Hund, Schwert, Blume u.v.m.</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Perfekte Ergänzung zur Zaubershow</li>
          </ul>
          <p class="text-[#374151] text-sm">Oft höre ich: „Das Ballontier wurde sogar mit ins Bett genommen!"</p>
        </div>
        <!-- Glitzer Tattoos -->
        <div class="bg-white rounded-xl p-8 shadow-sm border-t-4 border-[#ffb546]">
          <h3 class="font-bold text-[#1f2025] text-xl mb-2">✨ Glitzer-Tattoos</h3>
          <p class="text-[#d7393e] font-bold text-2xl mb-4">+ 40 €</p>
          <ul class="space-y-2 text-[#374151] text-sm mb-6">
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> 30 Minuten Glitzer-Magie</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Professionelle, hautfreundliche Tattoos</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Halten 5-7 Tage</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Superhelden-Symbole, Schmetterlinge u.v.m.</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Eigentlich lieben ALLE Kinder Glitzer!</li>
          </ul>
          <p class="text-[#374151] text-sm">Der Renner: Superhelden-Symbole bei Jungs, Schmetterlinge bei Mädchen. Aber eigentlich lieben ALLE Kinder Glitzer!</p>
        </div>
      </div>
      <!-- Fahrtkosten-Hinweis -->
      <div class="bg-gray-50 rounded-xl p-6 mt-6 text-center">
        <p class="text-[#374151] text-sm leading-relaxed">
          <strong>Fahrtkosten:</strong> Von Gladbeck nach Dorsten sind es etwa 20 Kilometer. Bei 0,40 € pro Kilometer sind das rund 8 €. Überschaubar, oder?
        </p>
      </div>
      <div class="text-center mt-10">
        <a href="/kontakt/" class="inline-block bg-[#d7393e] hover:bg-[#b62e32] text-white font-bold px-10 py-4 rounded transition-colors text-base">
          Jetzt unverbindlich anfragen
        </a>
      </div>
    </div>
  </section>

  <!-- Galerie -->
  <section class="bg-white py-14">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-[#1f2025] font-bold text-2xl sm:text-3xl text-center mb-2">Live-Beweis gefällig?</h2>
      <p class="text-[#374151] text-center mb-10 leading-relaxed">In meiner Online-Galerie sehen Sie echte Fotos und Videos von echten Kindergeburtstagen in Dorsten. Keine gestellten Werbebilder. Echte Reaktionen, echte Emotionen. Klicken Sie rein – es lohnt sich!</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <img src="https://liar-entertainer.com/wp-content/uploads/2023/08/Zaubershow-mit-Clown-Zauberer.jpg" alt="Auftritt Zaubershow mit Clown Zauberer in Dorsten" class="rounded-xl w-full object-cover object-top shadow-sm" loading="lazy" style="height:280px" />
        <img src="https://liar-entertainer.com/wp-content/uploads/2023/08/Kosten-Preis-Clown-NRW.jpg" alt="Clown Zauberer für Kindergeburtstag im Einsatz in NRW" class="rounded-xl w-full object-cover object-top shadow-sm" loading="lazy" style="height:280px" />
        <img src="https://liar-entertainer.com/wp-content/uploads/2023/08/Zaubervorfuehrung-auf-dem-Weihnachtsmarkt-Dortmund.jpg" alt="Zaubervorführung auf dem Weihnachtsmarkt" class="rounded-xl w-full object-cover object-top shadow-sm" loading="lazy" style="height:280px" />
      </div>
    </div>
  </section>

  <!-- Video Sektion -->
  <!-- Wave oben (weiß → blau) -->
  <div style="overflow:hidden;line-height:0;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>
  <section class="py-14 bg-[#3b55d5]">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-white font-extrabold text-xl uppercase tracking-widest mb-6">
        SCHNELLE EINDRÜCKE
      </h2>
      <div class="relative w-full max-w-2xl mx-auto mb-8" style="padding-bottom: 56.25%; position: relative;">
        <iframe
          src="https://www.youtube.com/embed/Cop0SqRIX4Y"
          title="Clown Zauberer für Geburtstag, Feier, Veranstaltung in NRW : die lustigste Zaubershow im Pott!"
          class="absolute inset-0 w-full h-full rounded-lg"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
      <h3 class="text-white font-bold text-xl mb-6">
        Mehr Fotos und Videos in der Galerie
      </h3>
      <a
        href="/galerie/"
        class="inline-block bg-[#f5a623] hover:bg-[#e69420] text-[#1f2025] font-bold px-10 py-4 rounded-full text-base transition-colors"
      >
        Zur Foto- und Videogalerie
      </a>
    </div>
  </section>
  <!-- Wave unten (blau → weiß) -->
  <div style="overflow:hidden;line-height:0;background:#3b55d5;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- FAQ: Praktische Infos -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-center font-bold text-[#1f2025] text-sm uppercase tracking-widest mb-2">NOCH FRAGEN?</h2>
      <h3 class="text-center font-bold text-[#1f2025] text-2xl sm:text-3xl mb-10">
        Praktische Infos, die Sie wissen sollten
      </h3>

      <div class="space-y-3" id="faq-list">
        {faqItems.map((item) => (
          <div class="faq-item bg-white border border-gray-200 rounded-lg overflow-hidden">
            <button
              class="faq-btn w-full text-left px-6 py-4 font-semibold text-[#1f2025] flex items-center justify-between gap-4"
              aria-expanded="false"
            >
              <span>{item.question}</span>
              <svg class="w-5 h-5 flex-shrink-0 transition-transform faq-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-answer hidden px-6 pb-5 text-[#374151] leading-relaxed">
              {item.answer}
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10">
        <p class="text-[#374151] mb-2 font-semibold">Einfach Kontakt aufnehmen</p>
