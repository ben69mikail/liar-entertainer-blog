---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import karteImg from '../../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import { Image } from 'astro:assets';
import GoogleReviews from '../../../components/GoogleReviews.astro';

const seoTitle = "Kindergeburtstag Essen | Zaubershow ab 150€";
const seoDescription = "Kindergeburtstag in Essen feiern mit Clown LIAR ✓ Zaubershow ab 150€ ✓ Ballonmodellage & Glitzer-Tattoos ✓ 400+ Bewertungen ✓ Auch in Mülheim & Bochum!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Geburtstag.jpg';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Kindergeburtstag mit Clown Zauberer in Essen',
  description: seoDescription,
  provider: {
    '@type': 'LocalBusiness',
    name: 'Clown Zauberer LIAR',
    url: 'https://liar-entertainer.com',
    telephone: '+491721517578',
  },
  areaServed: { '@type': 'City', name: 'Essen' },
  offers: { '@type': 'Offer', price: '150', priceCurrency: 'EUR', description: '40 Minuten Zaubershow' },
};

const faqItems = [
  {
    question: 'Wie lange im Voraus muss ich buchen?',
    answer: 'Im Ruhrpott läuft das entspannt. 2-3 Wochen reichen meist. An Samstagen ist mehr los, da empfehle ich 4 Wochen. Aber manchmal geht auch spontan was – einfach anrufen!',
  },
  {
    question: 'Funktioniert das auch in kleinen Wohnungen?',
    answer: 'Klar! Ich war schon in 2-Zimmer-Wohnungen. Hauptsache, die Kinder haben Platz zum Sitzen. Alles andere regeln wir.',
  },
  {
    question: 'Was bei gemischten Altersgruppen?',
    answer: 'Überhaupt kein Thema. Von 4 bis 10 Jahren – ich passe die Show an. Die Großen helfen bei komplizierteren Tricks, die Kleinen bei den Lustigen. Funktioniert super.',
  },
  {
    question: 'Können Eltern dabei bleiben?',
    answer: 'Na klar! Viele Eltern schauen zu, machen Fotos, lachen mit. Manche nutzen die Zeit für Vorbereitungen. Beides völlig okay.',
  },
  {
    question: 'Was ist mit Parken in Essen?',
    answer: 'Gute Frage! In Wohngebieten geht\'s meist. In der Innenstadt manchmal knifflig – aber auch das kriegen wir hin. Bisher hat\'s immer geklappt.',
  },
  {
    question: 'Was kostet ein Clown Zauberer für einen Kindergeburtstag?',
    answer: 'Die Preise für Kindergeburtstage starten ab 150 Euro. Die genaue Gage ist abhängig von Art und Umfang der Veranstaltung, Zuschauerzahl, Anfahrtsweg und Jahreszeit. Für ein individuelles, unverbindliches Angebot kontaktieren Sie mich unter 0172-1517578 oder info@liar-entertainer.com.',
  },
  {
    question: 'Wie lange dauert eine Clown & Zaubershow für Kinder?',
    answer: 'Die Show dauert 40 Minuten, je nach Alter der Kinder und Ihren Wünschen. Die Dauer wird individuell an Ihre Veranstaltung angepasst. Zusätzlich kann Ballonmodellage oder Glitzer-Tattoos dazugebucht werden.',
  },
  {
    question: 'Wie viel Platz braucht man für die Clown- und Zaubershow?',
    answer: 'Minimal nur 2x2 Meter Fläche. Die Show funktioniert überall: Wohnzimmer, Kinderzimmer, Partykeller, Terrasse, Garten, Turnhalle, Kindergarten, Schule oder Bücherei. Keine Aufbauzeit und es wird fast keine Vorbereitung benötigt.',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Kindergeburtstag Essen, Geburtstag Essen, Clown Kindergeburtstag Essen, Zauberer Geburtstag Essen, Kinderparty Essen, NRW"
  canonical="https://liar-entertainer.com/kindergeburtstag/geburtstag-in-essen/"
  ogImage={heroImg}
  structuredData={structuredData}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImg}'); background-position: center 20%;`}></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex flex-col items-center justify-center text-center px-6" style="min-height: 600px;">
      <div class="inline-flex items-center gap-2 bg-white/20 text-white rounded-full px-4 py-1.5 text-sm font-medium mb-4 backdrop-blur-sm">
        <span>📍</span> Essen
      </div>
      <h1 class="text-white font-extrabold text-center leading-tight mb-3" style="font-size: clamp(2rem, 5vw, 3.5rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
        Geburtstag in Essen: Echter Pott-Zauber für Ihre Feier
      </h1>
      <p class="text-gray-200 text-base leading-relaxed max-w-xl mx-auto">
        Ihr Clown-Zauberer für alle Essener Stadtteile
      </p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <section class="bg-white pt-4 pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="text-sm text-[#595959]">
        <a href="/" class="text-[#d7393e] hover:underline">Clown</a>
        <span class="mx-1">&raquo;</span>
        <a href="/kindergeburtstag/" class="text-[#d7393e] hover:underline">Kindergeburtstag</a>
        <span class="mx-1">&raquo;</span>
        <span>Geburtstag in Essen</span>
      </nav>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-[#d7393e] font-bold text-xl mb-4">Geburtstag in Essen: Echter Pott-Zauber für Ihre Feier</h2>
          <h3 class="font-bold text-lg text-[#1f2025] mb-4">Ihr Clown-Zauberer für alle Essener Stadtteile</h3>
          <p class="text-[#374151] mb-4 leading-relaxed">
            Kindergeburtstag in Essen – die grüne Hauptstadt des Ruhrgebiets bietet alles: Von der Zeche Zollverein bis zum Grugapark, vom Baldeneysee bis zur Innenstadt. Doch manchmal ist das Beste ganz nah: Eine Show direkt bei Ihnen zu Hause, ehrlich, sympathisch und typisch Ruhrpott.
          </p>
          <p class="text-[#374151] mb-4 leading-relaxed">
            Als Clown-Zauberer aus dem Revier kenne ich Essen wie meine Westentasche. Seit 15 Jahren bringe ich Magie nach Rüttenscheid, Werden, Steele, Kray und in jeden anderen Stadtteil. Mein Versprechen: Keine Schnickschnack, sondern echtes Entertainment, das Kinder begeistert und Eltern überzeugt.
          </p>
        </div>
        <div class="flex justify-center">
          <img
            src="https://liar-entertainer.com/wp-content/uploads/2023/08/Geburtstag-mit-dem-Clown-768x1024.jpg"
            alt="Kindergeburtstag in Essen mit Clown Zauberer"
            class="rounded-full object-cover object-[20%]"
            style="width: 320px; height: 320px;"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <GoogleReviews />

  <!-- Warum Essen perfekt ist für Kindergeburtstage zu Hause -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-[#1f2025] font-bold text-2xl sm:text-3xl text-center mb-6">Warum Essen perfekt ist für Kindergeburtstage zu Hause</h2>
      <p class="text-[#374151] text-center mb-10 leading-relaxed">Essen ist anders als andere Großstädte. Hier kennt man sich, hier ist man bodenständig, hier zählt Authentizität. Genau das macht meine Show aus:</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#d7393e]">
          <h3 class="font-bold text-[#1f2025] text-lg mb-3">Ruhrpott-Mentalität trifft auf Showqualität</h3>
          <p class="text-[#374151] leading-relaxed">Kein aufgesetztes Getue. Kein übertriebenes Theater. Sondern: Ehrliche Unterhaltung mit Herz. Ich bin so, wie die Menschen im Ruhrgebiet sind – direkt, sympathisch, verlässlich.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#3b55d5]">
          <h3 class="font-bold text-[#1f2025] text-lg mb-3">Grüne Stadt, kurze Wege</h3>
          <p class="text-[#374151] leading-relaxed">Essen hat über 50 Stadtteile, aber alle sind gut erreichbar. Von Gladbeck aus bin ich in 20-30 Minuten bei Ihnen – egal ob Kettwig im Süden oder Karnap im Norden.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#ffb546]">
          <h3 class="font-bold text-[#1f2025] text-lg mb-3">Vielfalt, die verbindet</h3>
          <p class="text-[#374151] leading-relaxed">Essen ist bunt. Verschiedene Kulturen, verschiedene Lebensstile. Meine Show funktioniert überall – vom Hochhaus in Katernberg bis zur Villa in Bredeney. Weil Kinder überall gleich sind: Sie wollen Spaß, Staunen, Lachen.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave: white → red (Stats) -->
  <div style="overflow:hidden;line-height:0;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#d7393e"/>
    </svg>
  </div>

  <!-- Stats Banner -->
  <section class="w-full bg-[#d7393e] py-10 text-center">
    <div class="max-w-4xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-transparent border border-white/30 rounded-xl p-6">
        <div class="text-3xl mb-2">🪄</div>
        <div class="text-4xl font-extrabold text-white">400</div>
        <div class="text-white text-sm mt-1">Shows im Jahr</div>
      </div>
      <div class="bg-transparent border border-white/30 rounded-xl p-6">
        <div class="text-3xl mb-2">😊</div>
        <div class="text-4xl font-extrabold text-white">110.000</div>
        <div class="text-white text-sm mt-1">Lachende Kinder</div>
      </div>
      <div class="bg-transparent border border-white/30 rounded-xl p-6">
        <div class="text-3xl mb-2">🪄</div>
        <div class="text-4xl font-extrabold text-white">15</div>
        <div class="text-white text-sm mt-1">Jahre Erfahrung</div>
      </div>
    </div>
  </section>

  <!-- Wave: red → white -->
  <div style="overflow:hidden;line-height:0;background:#d7393e;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- Meine Show: Unkompliziert und wirkungsvoll -->
  <section class="bg-white py-14">
    <div class="max-w-5xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
      <div>
        <h2 class="text-[#1f2025] font-bold text-2xl mb-4">Meine Show: Unkompliziert und wirkungsvoll</h2>
        <p class="text-[#374151] mb-6 leading-relaxed">Lassen Sie mich ehrlich sein: Ich bin kein Zirkusdirektor. Ich bin ein Handwerker. Mein Handwerk? Kinder zum Lachen bringen. Und das mache ich verdammt gut.</p>
        <h3 class="font-bold text-lg text-[#1f2025] mb-3">Was Sie bekommen: Das Komplettpaket</h3>
        <ul class="space-y-3 text-[#374151]">
          <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">✓</span> <strong>40 Minuten Show</strong> – Von der ersten Sekunde an haben die Kinder Spaß. Keine langatmigen Einleitungen, kein Geplänkel. Direkt rein ins Vergnügen.</li>
          <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">✓</span> <strong>Interaktive Zauberei</strong> – Die Kinder sind nicht nur Zuschauer. Sie zaubern mit, führen Tricks vor, sind die Stars. Ihr Kind mittendrin, nicht nur dabei.</li>
          <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">✓</span> <strong>Authentische Clownerie</strong> – Keine gruselige Maske, kein überdrehtes Gehabe. Sondern sympathischer Humor, der Kinder UND Eltern zum Schmunzeln bringt.</li>
          <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">✓</span> <strong>Komplette Ausstattung</strong> – Ich bringe alles mit. Sie müssen nichts organisieren, nichts vorbereiten. Einfach Kinder hinsetzen und genießen.</li>
        </ul>
      </div>
      <div>
        <h3 class="font-bold text-lg text-[#1f2025] mb-3 mt-8 md:mt-0">Was Sie NICHT bekommen</h3>
        <p class="text-[#374151] leading-relaxed">Keine falschen Versprechungen. Kein Hokuspokus. Keine überzogenen Erwartungen. Sondern: Ehrliche 40 Minuten Entertainment, die funktionieren. Versprochen.</p>
        <img
          src="https://liar-entertainer.com/wp-content/uploads/2023/08/Zaubershow-mit-Clown-Zauberer.jpg"
          alt="Zaubershow mit Clown Zauberer in Essen"
          class="rounded-xl w-full shadow-sm mt-6"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Preise: Klar und fair wie im Pott -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-[#d7393e] font-bold text-3xl sm:text-4xl text-center mb-4">Preise: Klar und fair wie im Pott</h2>
      <p class="text-[#374151] text-center mb-10">Ich weiß, dass Kindergeburtstage ins Geld gehen können. Deshalb halte ich meine Preise fair und transparent:</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Basis-Show -->
        <div class="bg-white rounded-xl p-8 shadow-sm border-t-4 border-[#d7393e]">
          <h3 class="font-bold text-[#1f2025] text-xl mb-2">🎩 Basis: Zaubershow</h3>
          <p class="text-[#d7393e] font-bold text-2xl mb-4">150 €</p>
          <ul class="space-y-2 text-[#374151] text-sm mb-6">
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> 40 Minuten Show – Zauberei + Clownerie</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Alle Materialien inklusive</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Bis zu 12 Kinder (ab 4 Jahre)</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Festpreis ohne Wochentags-Zuschlag</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> zzgl. Fahrtkosten (0,40€/km, Hin- &amp; Rückfahrt) ab Gladbeck</li>
          </ul>
          <p class="text-[#374151] text-sm">Das Geburtstagskind steht immer im Mittelpunkt!</p>
        </div>
        <!-- Ballonmodellage -->
        <div class="bg-white rounded-xl p-8 shadow-sm border-t-4 border-[#3b55d5]">
          <h3 class="font-bold text-[#1f2025] text-xl mb-2">🎈 Extra Ballons</h3>
          <p class="text-[#3b55d5] font-bold text-2xl mb-4">+ 20 €</p>
          <ul class="space-y-2 text-[#374151] text-sm mb-6">
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> 15 Minuten Ballonkunst</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Jedes Kind bekommt sein Wunschtier</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Hund, Schwert, Blume, Katze und mehr</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Tolle Erinnerung zum Mitnehmen</li>
            <li class="flex items-start gap-2"><span class="text-[#3b55d5]">✓</span> Perfekte Ergänzung zur Zaubershow</li>
          </ul>
          <p class="text-[#374151] text-sm">Die nehmen sie mit nach Hause und spielen tagelang damit. Lohnt sich!</p>
        </div>
        <!-- Glitzer-Tattoos -->
        <div class="bg-white rounded-xl p-8 shadow-sm border-t-4 border-[#ffb546]">
          <h3 class="font-bold text-[#1f2025] text-xl mb-2">✨ Extra Tattoos</h3>
          <p class="text-[#d7393e] font-bold text-2xl mb-4">+ 40 €</p>
          <ul class="space-y-2 text-[#374151] text-sm mb-6">
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> 30 Minuten Glitzer-Tattoos</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Professionell, hautfreundlich</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Halten eine Woche</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Auch Jungs lieben es!</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e]">✓</span> Viele Motive zur Auswahl</li>
          </ul>
          <p class="text-[#374151] text-sm">Ein funkelndes Highlight, das die Kinder noch Tage nach der Feier begeistert!</p>
        </div>
      </div>
      <!-- Anfahrt-Hinweis -->
      <div class="bg-gray-50 rounded-xl p-6 mt-6 text-center">
        <p class="text-[#374151] text-sm"><strong>Anfahrt:</strong> Ca. 15-30 € – Von Gladbeck nach Essen sind's etwa 20-30 km. Bei 0,40 € pro Kilometer bleiben die Fahrtkosten überschaubar. Ehrliche Rechnung, keine Überraschungen.</p>
      </div>
      <!-- CTA -->
      <div class="text-center mt-10">
        <a href="/kontakt/" class="inline-block bg-[#d7393e] hover:bg-[#b62e32] text-white font-bold px-10 py-4 rounded transition-colors text-base">
          Jetzt unverbindlich anfragen
        </a>
      </div>
    </div>
  </section>

  <!-- Praktische Tipps für Ihren Kindergeburtstag in Essen -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-[#1f2025] font-bold text-2xl sm:text-3xl text-center mb-10">Praktische Tipps für Ihren Kindergeburtstag in Essen</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#d7393e]">
          <h3 class="font-bold text-[#1f2025] text-lg mb-2">🕐 Bester Zeitpunkt</h3>
          <p class="text-[#374151] leading-relaxed">Nachmittags zwischen 14-16 Uhr. Kinder sind ausgeschlafen, aber noch nicht müde.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#3b55d5]">
          <h3 class="font-bold text-[#1f2025] text-lg mb-2">📋 Ablauf-Tipp</h3>
          <p class="text-[#374151] leading-relaxed">Show → Kuchen → Geschenke auspacken. In dieser Reihenfolge klappt's am besten.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#ffb546]">
          <h3 class="font-bold text-[#1f2025] text-lg mb-2">👧 Anzahl Kinder</h3>
          <p class="text-[#374151] leading-relaxed">6-12 ist optimal. Weniger geht auch, mehr wird unübersichtlich.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#d7393e]">
          <h3 class="font-bold text-[#1f2025] text-lg mb-2">🌤️ Wetter-Plan</h3>
          <p class="text-[#374151] leading-relaxed">Show funktioniert drinnen UND draußen. Bei unsicherem Wetter: Drinnen als Standard.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#3b55d5]">
          <h3 class="font-bold text-[#1f2025] text-lg mb-2">👶 Geschwister</h3>
          <p class="text-[#374151] leading-relaxed">Dürfen natürlich mitschauen! Auch kleinere oder größere Geschwister sind willkommen.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Video Sektion -->
  <!-- Wave oben (weiß → blau) -->
  <div style="overflow:hidden;line-height:0;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>
  <section class="py-14 bg-[#3b55d5]">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-white font-extrabold text-xl uppercase tracking-widest mb-6">
        SCHNELLE EINDRÜCKE
      </h2>
      <div class="relative w-full max-w-2xl mx-auto mb-8" style="padding-bottom: 56.25%; position: relative;">
        <iframe
          src="https://www.youtube.com/embed/Cop0SqRIX4Y"
          title="Clown Zauberer für Geburtstag, Feier, Veranstaltung in NRW : die lustigste Zaubershow im Pott!"
          class="absolute inset-0 w-full h-full rounded-lg"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
      <h3 class="text-white font-bold text-xl mb-6">
        Mehr Fotos und Videos in der Galerie
      </h3>
      <a
        href="/galerie/"
        class="inline-block bg-[#f5a623] hover:bg-[#e69420] text-[#1f2025] font-bold px-10 py-4 rounded-full text-base transition-colors"
      >
        Zur Foto- und Videogalerie
      </a>
    </div>
  </section>
  <!-- Wave unten (blau → weiß) -->
  <div style="overflow:hidden;line-height:0;background:#3b55d5;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>
  <!-- FAQ -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-center font-bold text-[#1f2025] text-sm uppercase tracking-widest mb-2">NOCH FRAGEN?</h2>
      <h3 class="text-center font-bold text-[#1f2025] text-2xl sm:text-3xl mb-10">
        Was Essener Eltern wissen wollen
      </h3>

      <div class="space-y-3" id="faq-list">
