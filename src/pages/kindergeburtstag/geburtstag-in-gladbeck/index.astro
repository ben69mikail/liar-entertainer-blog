---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import karteImg from '../../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import { Image } from 'astro:assets';
import GoogleReviews from '../../../components/GoogleReviews.astro';

const seoTitle = "Kindergeburtstag Gladbeck | Zaubershow ab 150€";
const seoDescription = "Kindergeburtstag in Gladbeck — Heimatstadt von Clown LIAR! ✓ Zaubershow ab 150€ ✓ Keine Fahrtkosten ✓ 400+ Bewertungen ✓ Ballonmodellage ✓ Jetzt buchen!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Geburtstag.jpg';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Kindergeburtstag mit Clown Zauberer in Gladbeck',
  description: seoDescription,
  provider: {
    '@type': 'LocalBusiness',
    name: 'Clown Zauberer LIAR',
    url: 'https://liar-entertainer.com',
    telephone: '+491721517578',
  },
  areaServed: { '@type': 'City', name: 'Gladbeck' },
  offers: { '@type': 'Offer', price: '150', priceCurrency: 'EUR', description: '40 Minuten Zaubershow' },
};

const faqItems = [
  {
    question: 'Was braucht Clown LIAR für einen Auftritt?',
    answer: 'Ohne Vorbereitungszeit und mit einer Fläche von 2x2 Meter kann ich eine Show vorführen: Wohnzimmer, Kinderzimmer, Partykeller, Terrasse, Gartenanlage, große und kleine Bühne, Kindergarten, Turnhalle... Ob drinnen oder draußen, das Programm lässt sich spontan und flexibel ausführen!',
  },
  {
    question: 'Wieviel Platz braucht man für das Programm?',
    answer: 'LIAR ist ziemlich pflegeleicht: für die Show ist es wichtig, dass die Kinder gemütlich und ungestört sitzen können!!! Bei der Ballonmodellage ist nichts weiteres nötig. Bei GLITZER TATTOOS wären schon 2 Stühle und einen Tisch wichtig!',
  },
  {
    question: 'Wie viele Kinder sollten überhaupt eingeladen werden?',
    answer: 'Natürlich soll das Kind seine Freunde einladen. Allerdings sollte man eine feste Zahl als Limit vorgeben. Pädagogen empfehlen, maximal genauso viele Gäste einzuladen, wie das Kind alt wird. Wer kommen darf, soll das Kind selbst bestimmen. Natürlich sind auch dabei die Aufsichtspersonen (mindestens 2) nicht zu vergessen.',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Kindergeburtstag Gladbeck, Geburtstag Gladbeck, Clown Kindergeburtstag Gladbeck, Zauberer Geburtstag Gladbeck, Kinderparty Gladbeck, NRW"
  canonical="https://liar-entertainer.com/kindergeburtstag/geburtstag-in-gladbeck/"
  ogImage={heroImg}
  structuredData={structuredData}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImg}'); background-position: center 20%;`}></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex flex-col items-center justify-center text-center px-6" style="min-height: 600px;">
      <div class="inline-flex items-center gap-2 bg-white/20 text-white rounded-full px-4 py-1.5 text-sm font-medium mb-4 backdrop-blur-sm">
        <span>📍</span> Gladbeck
      </div>
      <h1 class="text-white font-extrabold text-center leading-tight mb-3" style="font-size: clamp(2rem, 5vw, 3.5rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
        Geburtstag in Gladbeck
      </h1>
      <p class="text-gray-200 text-base leading-relaxed max-w-xl mx-auto">
        Unvergessliche Kindergeburtstage mit Clown Zauberer LIAR – Lachen, Staunen und pure Magie!
      </p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <section class="bg-white pt-4 pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="text-sm text-[#595959]">
        <a href="/" class="text-[#d7393e] hover:underline">Clown</a>
        <span class="mx-1">»</span>
        <a href="/kindergeburtstag/" class="text-[#d7393e] hover:underline">Kindergeburtstag</a>
        <span class="mx-1">»</span>
        <span>Geburtstag in Gladbeck</span>
      </nav>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-[#d7393e] font-bold text-xl mb-4">Kindergeburtstag in Gladbeck – Clown &amp; Zauberer aus Ihrer Stadt!</h2>
          <p class="text-[#374151] mb-4 leading-relaxed">Sie suchen Entertainment für einen Geburtstag in Gladbeck? Perfekt – ich bin direkt bei Ihnen um die Ecke! Seit über 15 Jahren lebe und arbeite ich in der Beethovenstraße 15 in Gladbeck-Mitte und bringe als <a href="/" class="text-[#d7393e] hover:underline">Clown</a> &amp; <a href="/zauberer/" class="text-[#d7393e] hover:underline">Zauberer</a> Kinderaugen zum Leuchten – in ganz Gladbeck und darüber hinaus.</p>
          <p class="text-[#374151] font-bold mb-2">Ihr Gladbecker Vorteil:</p>
          <ul class="space-y-2 text-[#374151] mb-4">
            <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">✓</span> 0 € Fahrtkosten – ich bin bereits vor Ort!</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">✓</span> Maximale Flexibilität – auch kurzfristige Termine möglich</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">✓</span> Ich kenne Gladbeck wie meine Westentasche</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">✓</span> Nachbarschaftlicher Service mit persönlicher Note</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">✓</span> Schnelle Erreichbarkeit bei Fragen oder Änderungen</li>
            <li class="flex items-start gap-2"><span class="text-[#d7393e] font-bold">✓</span> Unterstützung lokaler Dienstleister statt große Agenturen</li>
          </ul>
          <p class="text-[#374151] leading-relaxed">Als echter Gladbecker weiß ich, was Familien hier schätzen: Bodenständiges Entertainment ohne Schnickschnack, verlässliche Absprachen und ein faires Preis-Leistungs-Verhältnis. Genau das bekommen Sie bei mir!</p>
        </div>
        <div class="flex justify-center">
          <img
            src="https://liar-entertainer.com/wp-content/uploads/2023/08/Geburtstag-mit-dem-Clown-768x1024.jpg"
            alt="Geburtstag in Gladbeck mit dem Clown aus Ihrer Stadt"
            class="rounded-full object-cover object-[20%]"
            style="width: 320px; height: 320px;"
            loading="lazy"
          />
