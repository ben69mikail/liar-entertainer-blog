      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- Die Preise -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-[#d7393e] font-bold text-3xl sm:text-4xl text-center mb-10">Was kostet eine Show in Dinslaken?</h2>
      <p class="text-[#374151] text-center mb-10 max-w-2xl mx-auto">Keine versteckten Preise, keine Überraschungen beim Bezahlen. Hier die klare Übersicht:</p>
