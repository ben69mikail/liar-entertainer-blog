        <!-- Zaubershow -->
        <div class="bg-white rounded-xl p-8 shadow-sm border-t-4 border-[#d7393e]">
          <h3 class="font-bold text-[#1f2025] text-xl mb-2">🎩 Standard-Paket</h3>
