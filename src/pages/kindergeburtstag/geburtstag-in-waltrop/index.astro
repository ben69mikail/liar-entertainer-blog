---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import karteImg from '../../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import { Image } from 'astro:assets';
import GoogleReviews from '../../../components/GoogleReviews.astro';

const seoTitle = "Kindergeburtstag Waltrop | Zaubershow ab 150€";
const seoDescription = "Kindergeburtstag in Waltrop unvergesslich machen! Clown LIAR ✓ Zaubershow ab 150€ ✓ 400+ Bewertungen ✓ Auch in Datteln & Castrop-Rauxel ✓ Anfragen!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Geburtstag.jpg';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Kindergeburtstag mit Clown Zauberer in Waltrop',
  description: seoDescription,
  provider: {
    '@type': 'LocalBusiness',
    name: 'Clown Zauberer LIAR',
    url: 'https://liar-entertainer.com',
    telephone: '+491721517578',
  },
  areaServed: { '@type': 'City', name: 'Waltrop' },
  offers: { '@type': 'Offer', price: '150', priceCurrency: 'EUR', description: '40 Minuten Zaubershow' },
};

const faqItems = [
  {
    question: 'Was braucht Clown LIAR für einen Auftritt?',
    answer: 'Ohne Vorbereitungszeit und mit einer Fläche von 2\u00d72 Meter kann ich eine Show vorführen: Wohnzimmer, Kinderzimmer, Partykeller, Terrasse, Gartenanlage, große und kleine Bühne, Kindergarten, Turnhalle\u2026 Ob drinnen oder draußen, das Programm lässt sich spontan und flexibel ausführen!',
  },
  {
    question: 'Wieviel Platz braucht man für das Programm?',
    answer: 'LIAR ist ziemlich pflegeleicht: für die Show ist es wichtig, dass die Kinder gemütlich und ungestört sitzen können!!! Bei der Ballonmodellage ist nichts weiteres nötig. Bei GLITZER TATTOOS wären schon 2 Stühle und einen Tisch wichtig!',
  },
  {
    question: 'Wie viele Kinder sollten überhaupt eingeladen werden?',
    answer: 'Natürlich soll das Kind seine Freunde einladen. Allerdings sollte man eine feste Zahl als Limit vorgeben. Pädagogen empfehlen, maximal genauso viele Gäste einzuladen, wie das Kind alt wird. Wer kommen darf, soll das Kind selbst bestimmen. Natürlich sind auch dabei die Aufsichtspersonen (mindestens 2) nicht zu vergessen.',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Kindergeburtstag Waltrop, Geburtstag Waltrop, Clown Kindergeburtstag Waltrop, Zauberer Geburtstag Waltrop, Kinderparty Waltrop, NRW"
  canonical="https://liar-entertainer.com/kindergeburtstag/geburtstag-in-waltrop/"
  ogImage={heroImg}
  structuredData={structuredData}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImg}'); background-position: center 20%;`}></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex flex-col items-center justify-center text-center px-6" style="min-height: 600px;">
      <div class="inline-flex items-center gap-2 bg-white/20 text-white rounded-full px-4 py-1.5 text-sm font-medium mb-4 backdrop-blur-sm">
        <span>📍</span> Waltrop
      </div>
      <h1 class="text-white font-extrabold text-center leading-tight mb-3" style="font-size: clamp(2rem, 5vw, 3.5rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
        Geburtstag in Waltrop
      </h1>
      <p class="text-gray-200 text-base leading-relaxed max-w-xl mx-auto">
        Unvergessliche Kindergeburtstage mit Clown Zauberer LIAR – Lachen, Staunen und pure Magie!
      </p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <section class="bg-white pt-4 pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="text-sm text-[#595959]">
        <a href="/" class="text-[#d7393e] hover:underline">Clown</a>
        <span class="mx-1">»</span>
        <a href="/kindergeburtstag/" class="text-[#d7393e] hover:underline">Kindergeburtstag</a>
        <span class="mx-1">»</span>
        <span>Geburtstag in Waltrop</span>
      </nav>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-[#d7393e] font-bold text-xl mb-4">Professionelle Kinderunterhaltung – entspannte Eltern, glückliche Kinder! 😊👨‍👩‍👧‍👦</h2>
          <p class="text-[#374151] mb-4 leading-relaxed">Sie kennen das sicherlich: Ein Kindergeburtstag steht bevor und die Fragen häufen sich. Welche Spiele begeistern wirklich alle Kinder? Wie hält man eine bunte Truppe mehrere Stunden bei Laune? Was tun, wenn manche Kinder schüchtern sind und andere sehr wild? 🤔</p>
          <p class="text-[#374151] mb-4 leading-relaxed">Die Antwort ist einfacher als gedacht: Holen Sie sich professionelle Unterstützung ins Haus! Als erfahrener Clown Zauberer kenne ich all diese Herausforderungen und weiß genau, wie man jede Kindergruppe begeistert. Ich komme mit meiner kompletten Ausstattung zu Ihnen nach Waltrop – ob in die Innenstadt, nach Brockenscheidt, Oberwiese oder Elverlingsen – und übernehme die komplette Unterhaltung der kleinen Gäste. ✨</p>
          <p class="text-[#374151] mb-4 leading-relaxed">Während ich die Kinder verzaubere und zum Lachen bringe, können Sie entspannt Fotos machen, mit anderen Eltern plaudern oder einfach den besonderen Tag genießen. Keine Hektik, kein Stress – nur strahlende Kinderaugen und unvergessliche Erinnerungen! 📸💫</p>
        </div>
        <div class="flex justify-center">
          <img
            src="https://liar-entertainer.com/wp-content/uploads/2023/08/Geburtstag-mit-dem-Clown-768x1024.jpg"
            alt="Kindergeburtstag in Waltrop"
            class="rounded-full object-cover object-[20%]"
            style="width: 320px; height: 320px;"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <GoogleReviews />

  <!-- Wave: white → blue -->
  <div style="overflow:hidden;line-height:0;background:white;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>
  <section class="bg-[#3b55d5] py-14 text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-[#ffb546] font-bold text-sm uppercase tracking-widest mb-4">WALTROP</p>
      <h2 class="text-white font-bold text-3xl sm:text-4xl mb-6">✨ Kindergeburtstag in Waltrop – mit Herz &amp; Humor</h2>
      <p class="text-white leading-relaxed mb-4">
        Meine Show ist speziell auf Kinder abgestimmt: lebendig, interaktiv und voller Überraschungen.
      </p>
      <p class="text-white leading-relaxed">
        Die Kinder dürfen mitzaubern, lachen, staunen – und manchmal selbst zur kleinen Zauberin oder zum Zauberer werden.
        Dabei achte ich besonders auf Respekt, Empathie und ein liebevolles Miteinander.
      </p>
    </div>
  </section>
  <!-- Wave: blue → white -->
  <div style="overflow:hidden;line-height:0;background:#3b55d5;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- Die Preise -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-[#d7393e] font-bold text-3xl sm:text-4xl text-center mb-10">Die Preise</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-8 shadow-sm border-t-4 border-[#d7393e]">
