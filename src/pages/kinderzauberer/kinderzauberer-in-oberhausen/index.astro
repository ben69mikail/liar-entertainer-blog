---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import karteImg from '../../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import { Image } from 'astro:assets';
import GoogleReviews from '../../../components/GoogleReviews.astro';

const seoTitle = "Kinderzauberer Oberhausen | TOP Bewertet | Buchen";
const seoDescription = "Kinderzauberer in Oberhausen für Kinder-Events ✓ Clown LIAR ✓ 400+ Top-Bewertungen ✓ Ab 150€ ✓ Auch in Gladbeck & Bottrop ✓ Jetzt anfragen!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Kinderzauberer-in-Oberhausen-3.jpg';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Kinderzauberer in Oberhausen",
  "description": "Kinderzauberer LIAR für Kindergeburtstag und Kinderevents in Oberhausen, NRW",
  "url": "https://liar-entertainer.com/kinderzauberer/kinderzauberer-in-oberhausen/",
  "serviceType": ["Kinderzauberer", "Zaubershow für Kinder"],
  "provider": {
    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com",
    "telephone": "+491721517578"
  },
  "areaServed": { "@type": "City", "name": "Oberhausen" },
  "offers": { "@type": "Offer", "price": "150", "priceCurrency": "EUR" }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was kostet ein Kinderzauberer in Oberhausen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Für Kindergeburtstage gibt es Festpreise. Größere Events nach individueller Absprache. Innerhalb Oberhausens keine Extra-Anfahrtskosten. Anruf genügt: 0172-1517578"
      }
    },
    {
      "@type": "Question",
      "name": "Wo kann die Show stattfinden?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Überall! Wohnzimmer, Garten, Gemeindezentrum, Turnhalle, Centro-Eventfläche, Park – mit nur 2x2m Platz bin ich dabei."
      }
    },
    {
      "@type": "Question",
      "name": "Wie lange im Voraus buchen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Beliebte Termine (Samstage, Ferienzeiten) am besten 2-3 Monate vorher. Unter der Woche oft auch kurzfristig möglich."
      }
    }
  ]
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Kinderzauberer Oberhausen, Kinderzauberer in Oberhausen, Zauberer Oberhausen, Kindergeburtstag Oberhausen, Zaubershow Oberhausen, NRW"
  canonical="https://liar-entertainer.com/kinderzauberer/kinderzauberer-in-oberhausen/"
  ogImage={heroImg}
  structuredData={structuredData}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImg}'); background-position: center 20%;`}></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex flex-col items-center justify-center text-center px-6" style="min-height: 600px;">
      <div class="inline-flex items-center gap-2 bg-white/20 text-white rounded-full px-4 py-1.5 text-sm font-medium mb-4 backdrop-blur-sm">
        <span>📍</span> Oberhausen
      </div>
      <h1 class="text-white font-extrabold text-center leading-tight mb-3" style="font-size: clamp(2rem, 5vw, 3.5rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
        Kinderzauberer in Oberhausen
