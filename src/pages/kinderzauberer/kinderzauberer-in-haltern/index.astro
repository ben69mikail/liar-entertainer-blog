const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Kinderzauberer in Haltern am See",
  "description": "Kinderzauberer LIAR für Kindergeburtstag und Kinderevents in Haltern am See, NRW",
  "url": "https://liar-entertainer.com/kinderzauberer/kinderzauberer-in-haltern/",
