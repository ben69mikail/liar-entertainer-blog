        <div class="bg-white rounded-xl p-6 shadow-sm"><h4 class="font-bold text-[#1f2025] mb-2">🏢 Firmenfeiern &amp; Betriebsfeste</h4><p class="text-[#374151] text-sm leading-relaxed">Kinderbetreuung mit Entertainment-Faktor</p></div>
        <div class="bg-white rounded-xl p-6 shadow-sm"><h4 class="font-bold text-[#1f2025] mb-2">💒 Hochzeiten &amp; Familienfeiern</h4><p class="text-[#374151] text-sm leading-relaxed">Kinderprogramm für entspannte Eltern</p></div>
        <div class="bg-white rounded-xl p-6 shadow-sm"><h4 class="font-bold text-[#1f2025] mb-2">🎪 Stadt- &amp; Straßenfeste</h4><p class="text-[#374151] text-sm leading-relaxed">Publikumsmagnet für Open-Air-Events</p></div>
        <div class="bg-white rounded-xl p-6 shadow-sm"><h4 class="font-bold text-[#1f2025] mb-2">⛪ Kommunion &amp; Konfirmation</h4><p class="text-[#374151] text-sm leading-relaxed">Festliche Unterhaltung für junge Gäste</p></div>
      </div>
    </div>
  </section>

  <!-- Bildergalerie -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-2 gap-4">
        <img src="https://liar-entertainer.com/wp-content/uploads/2023/08/Zaubershow.jpg" alt="Staunende Kinder bei einer Zaubershow mit Kinderzauberer in Düsseldorf" class="rounded-xl w-full object-cover object-top shadow-sm" loading="lazy" style="height:280px" />
        <img src="https://liar-entertainer.com/wp-content/uploads/2023/08/Zaubershow-mit-Clown-Zauberer.jpg" alt="Auftritt Zaubershow mit Clown und Kinderzauberer in Düsseldorf" class="rounded-xl w-full object-cover object-top shadow-sm" loading="lazy" style="height:280px" />
