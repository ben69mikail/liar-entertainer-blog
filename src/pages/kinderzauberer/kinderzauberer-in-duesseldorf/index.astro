---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import karteImg from '../../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import { Image } from 'astro:assets';
import GoogleReviews from '../../../components/GoogleReviews.astro';

const seoTitle = "Kinderzauberer Düsseldorf | TOP Bewertet | Buchen";
const seoDescription = "Kinderzauberer in Düsseldorf buchen ✓ Lustige Zaubershow für Kindergeburtstag ✓ 400+ Bewertungen ✓ Ab 150€ ✓ Auch in Duisburg & Mülheim ✓ Anfragen!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Kinderzauberer-in-Duesseldorf-1.jpg';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Kinderzauberer in Düsseldorf",
  "description": "Kinderzauberer LIAR für Kindergeburtstag und Kinderevents in Düsseldorf, NRW",
  "url": "https://liar-entertainer.com/kinderzauberer/kinderzauberer-in-duesseldorf/",
  "serviceType": ["Kinderzauberer", "Zaubershow für Kinder"],
  "provider": {
    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com",
    "telephone": "+491721517578"
  },
  "areaServed": { "@type": "City", "name": "Düsseldorf" },
  "offers": { "@type": "Offer", "price": "150", "priceCurrency": "EUR" }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was kostet ein Kinderzauberer in Düsseldorf? 💰",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Preisgestaltung richtet sich nach mehreren Faktoren: Veranstaltungstyp und -größe, gewünschte Programmdauer, Teilnehmerzahl sowie Entfernung. Für klassische Kindergeburtstage habe ich attraktive Festpreise! Fordern Sie unverbindlich ein individuelles Angebot an – ich berate Sie gerne ausführlich! 📞"
      }
    },
    {
      "@type": "Question",
      "name": "Welche Raumgröße wird benötigt? 📏",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Meine Zaubershow in Düsseldorf ist maximal anpassungsfähig! Ich benötige lediglich eine Aktionsfläche von 2×2 Metern – ohne langwierigen Aufbau oder komplizierte Vorbereitung. Ob in Wohnräumen, Gärten 🌳, Partykellern, Kindergärten, Schulräumen oder auf Großveranstaltungen: Ich passe mich optimal an Ihre räumlichen Verhältnisse an."
      }
    },
    {
      "@type": "Question",
      "name": "Wie lange dauert eine Show? ⏰",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Zaubershow in Düsseldorf kann ab 30 Minuten gebucht werden und wird präzise auf Ihre Bedürfnisse zugeschnitten. Ideal für: Kindergeburtstage 🎉, Kitafeste, Schulveranstaltungen, Sommerfeste, Firmenevents, Hochzeiten, Kommunionen oder Straßenfeste. Die exakte Showlänge stimme ich individuell auf Ihr Event und das Publikum ab."
      }
    }
  ]
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Kinderzauberer Düsseldorf, Kinderzauberer in Düsseldorf, Zauberer Düsseldorf, Kindergeburtstag Düsseldorf, Zaubershow Düsseldorf, NRW"
  canonical="https://liar-entertainer.com/kinderzauberer/kinderzauberer-in-duesseldorf/"
  ogImage={heroImg}
  structuredData={structuredData}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImg}'); background-position: center 20%;`}></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex flex-col items-center justify-center text-center px-6" style="min-height: 600px;">
      <div class="inline-flex items-center gap-2 bg-white/20 text-white rounded-full px-4 py-1.5 text-sm font-medium mb-4 backdrop-blur-sm">
        <span>📍</span> Düsseldorf
      </div>
      <h1 class="text-white font-extrabold text-center leading-tight mb-3" style="font-size: clamp(2rem, 5vw, 3.5rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
        TOP Show mit Kinderzauberer in Düsseldorf buchen
