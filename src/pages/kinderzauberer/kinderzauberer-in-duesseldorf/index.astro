        <img src="https://liar-entertainer.com/wp-content/uploads/2023/08/Zaubervorfuehrung-auf-dem-Weihnachtsmarkt-Dortmund.jpg" alt="Zaubervorführung auf dem Weihnachtsmarkt mit dem Kinderzauberer" class="rounded-xl w-full object-cover object-top shadow-sm" loading="lazy" style="height:280px" />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-center font-bold text-[#1f2025] text-sm uppercase tracking-widest mb-2">NOCH FRAGEN?</h2>
      <h3 class="text-center font-bold text-[#1f2025] text-2xl sm:text-3xl mb-10">
        Hier sind ein paar Antworten
