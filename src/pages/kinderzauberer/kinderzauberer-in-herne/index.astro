---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import karteImg from '../../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import { Image } from 'astro:assets';
import GoogleReviews from '../../../components/GoogleReviews.astro';

const seoTitle = "Kinderzauberer Herne | TOP Bewertet | Buchen";
const seoDescription = "Kinderzauberer in Herne für Kindergeburtstag & Feste ✓ Clown LIAR ✓ 400+ Bewertungen ✓ Ab 150€ ✓ Auch in Bochum & Gelsenkirchen ✓ Jetzt buchen!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Kinderzauberer-in-Herne-3.jpg';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Kinderzauberer in Herne",
  "description": "Kinderzauberer LIAR für Kindergeburtstag und Kinderevents in Herne, NRW",
  "url": "https://liar-entertainer.com/kinderzauberer/kinderzauberer-in-herne/",
  "serviceType": ["Kinderzauberer", "Zaubershow für Kinder"],
  "provider": {
    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com",
    "telephone": "+491721517578"
  },
  "areaServed": { "@type": "City", "name": "Herne" },
  "offers": { "@type": "Offer", "price": "150", "priceCurrency": "EUR" }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was kostet ein Kinderzauberer in Herne? 💰",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Preisgestaltung richtet sich nach verschiedenen Faktoren: Veranstaltungsart und -umfang, gewünschte Showdauer, Gästezahl sowie Entfernung. Für klassische Kindergeburtstage habe ich transparente Festpreise! Fordern Sie gerne ein unverbindliches und individuelles Angebot an – ich berate Sie kompetent! 📞"
      }
    },
    {
      "@type": "Question",
      "name": "Welchen Platzbedarf hat die Show? 📏",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Meine Zaubershow in Herne ist extrem anpassungsfähig! Erforderlich ist lediglich eine Spielfläche von 2×2 Metern – ohne zeitraubenden Aufbau oder aufwendige Vorbereitung. Ob in Wohnräumen, Gartenbereichen 🌳, Partykellern, Kindergärten, Schulräumen oder auf Großveranstaltungen: Ich arrangiere mich optimal nach den räumlichen Möglichkeiten."
      }
    },
    {
      "@type": "Question",
      "name": "Wie lange dauert eine typische Vorführung? ⏰",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Zaubershow in Herne kann ab 30 Minuten gebucht werden und wird exakt auf Ihre Anforderungen abgestimmt. Optimal für: Kindergeburtstage 🎉, Kitaevents, Schulveranstaltungen, Sommerfeste, Firmenveranstaltungen, Hochzeiten, Kommunionen oder Straßenfeste. Die genaue Programmdauer passe ich individuell auf Ihr Event und die Altersstruktur an."
      }
    }
  ]
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
