    </div>
  </section>

  <!-- Bildergalerie -->
  <section class="bg-white py-14">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <img src="https://liar-entertainer.com/wp-content/uploads/2023/08/Zaubershow-mit-Clown-Zauberer.jpg" alt="Auftritt Zaubershow mit Clown und Kinderzauberer in Herten" class="rounded-xl w-full object-cover object-top shadow-sm" loading="lazy" style="height:280px" />
        <img src="https://liar-entertainer.com/wp-content/uploads/2023/08/Kosten-Preis-Clown-NRW.jpg" alt="Clown Zauberer LIAR im Einsatz in NRW" class="rounded-xl w-full object-cover object-top shadow-sm" loading="lazy" style="height:280px" />
        <img src="https://liar-entertainer.com/wp-content/uploads/2023/08/Zaubervorfuehrung-auf-dem-Weihnachtsmarkt-Dortmund.jpg" alt="Zaubervorführung von Kinderzauberer in Herten auf dem Weihnachtsmarkt" class="rounded-xl w-full object-cover object-top shadow-sm" loading="lazy" style="height:280px" />
        <img src="https://liar-entertainer.com/wp-content/uploads/2023/08/Ballonmodellage-e1692870125222.jpg" alt="Ballonmodellage beim Kinderzauberer in Herten" class="rounded-xl w-full object-cover object-top shadow-sm" loading="lazy" style="height:280px" />
        <img src="https://liar-entertainer.com/wp-content/uploads/2025/10/Pantomime-11.jpg" alt="Pantomime und Clown-Kunst in Herten" class="rounded-xl w-full object-cover object-top shadow-sm" loading="lazy" style="height:280px" />
