---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import karteImg from '../../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import { Image } from 'astro:assets';
import GoogleReviews from '../../../components/GoogleReviews.astro';

const seoTitle = "Kinderzauberer Herten | TOP Bewertet | Buchen";
const seoDescription = "Kinderzauberer in Herten buchen ✓ Lustige Zaubershow für Kinder ✓ 400+ Bewertungen ✓ Ab 150€ ✓ Auch in Recklinghausen & Marl ✓ Jetzt anfragen!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Kinderzauberer-in-HERTEN-3.jpg';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Kinderzauberer in Herten",
  "description": "Kinderzauberer LIAR für Kindergeburtstag und Kinderevents in Herten, NRW",
  "url": "https://liar-entertainer.com/kinderzauberer/kinderzauberer-in-herten/",
  "serviceType": ["Kinderzauberer", "Zaubershow für Kinder"],
  "provider": {
    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com",
    "telephone": "+491721517578"
  },
  "areaServed": { "@type": "City", "name": "Herten" },
  "offers": { "@type": "Offer", "price": "150", "priceCurrency": "EUR" }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was investiere ich für einen Kinderzauberer in Herten? 💰",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Meine Honorare richten sich nach dem Rahmen: Welche Art Event? Wie lange soll ich unterhalten? Wie viele Kinder? Welche Anfahrt? Für private Kindergeburtstage habe ich klare Paketpreise – damit Sie wissen, woran Sie sind! Lassen Sie uns sprechen – ich erstelle Ihnen gerne ein passendes Angebot! 📞"
      }
    },
    {
      "@type": "Question",
      "name": "Welche räumlichen Voraussetzungen brauche ich? 📏",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Meine Show ist extrem flexibel! Eine Grundfläche von 2×2 Metern genügt – mehr nicht. Kein spezielles Licht, keine Bühne erforderlich. Ob Wohnzimmer, Garten 🌳, Keller, Kita-Raum oder große Halle: Ich mache das Beste aus jeder Location!"
      }
    },
    {
      "@type": "Question",
      "name": "Wie lang sollte die Show sein? ⏰",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ab 30 Minuten ist buchbar – und nach oben gibt's kaum Grenzen. Je nach Event empfehle ich unterschiedliche Längen: Für Kindergeburtstage 🎉 oft 40-60 Minuten, für Kita-Gruppen manchmal kürzer, für Großveranstaltungen auch länger. Wir finden gemeinsam die ideale Dauer!"
      }
    }
  ]
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Kinderzauberer Herten, Kinderzauberer in Herten, Zauberer Herten, Kindergeburtstag Herten, Zaubershow Herten, NRW"
  canonical="https://liar-entertainer.com/kinderzauberer/kinderzauberer-in-herten/"
  ogImage={heroImg}
  structuredData={structuredData}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImg}'); background-position: center 20%;`}></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex flex-col items-center justify-center text-center px-6" style="min-height: 600px;">
      <div class="inline-flex items-center gap-2 bg-white/20 text-white rounded-full px-4 py-1.5 text-sm font-medium mb-4 backdrop-blur-sm">
        <span>📍</span> Herten
      </div>
      <h1 class="text-white font-extrabold text-center leading-tight mb-3" style="font-size: clamp(2rem, 5vw, 3.5rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
        Kinderzauberer in Herten buchen | Erlebnis-Show für Kinder
