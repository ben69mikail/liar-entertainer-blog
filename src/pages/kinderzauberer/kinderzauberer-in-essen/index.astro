---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import karteImg from '../../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import { Image } from 'astro:assets';
import GoogleReviews from '../../../components/GoogleReviews.astro';

const seoTitle = "Kinderzauberer Essen | TOP Bewertet | Buchen";
const seoDescription = "Kinderzauberer in Essen buchen ✓ Zaubershow für Kindergeburtstag & Kita ✓ 400+ Bewertungen ✓ Ab 150€ ✓ Auch in Mülheim & Bochum ✓ Jetzt anfragen!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Kinderzauberer-in-Essen-3.jpg';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Kinderzauberer in Essen",
  "description": "Kinderzauberer LIAR für Kindergeburtstag und Kinderevents in Essen, NRW",
  "url": "https://liar-entertainer.com/kinderzauberer/kinderzauberer-in-essen/",
  "serviceType": ["Kinderzauberer", "Zaubershow für Kinder"],
  "provider": {
    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com",
    "telephone": "+491721517578"
  },
  "areaServed": { "@type": "City", "name": "Essen" },
  "offers": { "@type": "Offer", "price": "150", "priceCurrency": "EUR" }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was braucht Clown LIAR für einen Auftritt?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ohne Vorbereitungszeit und mit einer Fläche von 2×2 Meter kann ich eine Show vorführen: Wohnzimmer, Kinderzimmer, Partykeller, Terrasse, Gartenanlage, große und kleine Bühne, Kindergarten, Turnhalle… Ob drinnen oder draußen, das Programm lässt sich spontan und flexibel ausführen!"
      }
    },
    {
      "@type": "Question",
      "name": "Wieviel Platz braucht man für das Programm?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "LIAR ist ziemlich pflegeleicht: für die Show ist es wichtig, dass die Kinder gemütlich und ungestört sitzen können!!! Bei der Ballonmodellage ist nichts weiteres nötig. Bei GLITZER TATTOOS wären schon 2 Stühle und einen Tisch wichtig!"
      }
    },
    {
      "@type": "Question",
      "name": "Wie viele Kinder sollten überhaupt eingeladen werden?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Natürlich soll das Kind seine Freunde einladen. Allerdings sollte man eine feste Zahl als Limit vorgeben. Pädagogen empfehlen, maximal genauso viele Gäste einzuladen, wie das Kind alt wird. Wer kommen darf, soll das Kind selbst bestimmen. Natürlich sind auch dabei die Aufsichtspersonen (mindestens 2) nicht zu vergessen."
      }
    }
  ]
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Kinderzauberer Essen, Kinderzauberer in Essen, Zauberer Essen, Kindergeburtstag Essen, Zaubershow Essen, NRW"
  canonical="https://liar-entertainer.com/kinderzauberer/kinderzauberer-in-essen/"
  ogImage={heroImg}
  structuredData={structuredData}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImg}'); background-position: center 20%;`}></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex flex-col items-center justify-center text-center px-6" style="min-height: 600px;">
      <div class="inline-flex items-center gap-2 bg-white/20 text-white rounded-full px-4 py-1.5 text-sm font-medium mb-4 backdrop-blur-sm">
        <span>📍</span> Essen
      </div>
      <h1 class="text-white font-extrabold text-center leading-tight mb-3" style="font-size: clamp(2rem, 5vw, 3.5rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
        Kinderzauberer in Essen buchen 🎩 – Fantastische Momente für Ihre Kleinen
      </h1>
      <p class="text-gray-200 text-base leading-relaxed max-w-xl mx-auto">
        Magische Zaubershow für Kinder in Essen – Staunen, Lachen und unvergessliche Momente!
      </p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <section class="bg-white pt-4 pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="text-sm text-[#595959]">
        <a href="/" class="text-[#d7393e] hover:underline">Clown</a>
        <span class="mx-1">»</span>
        <a href="/kinderzauberer/" class="text-[#d7393e] hover:underline">Kinderzauberer</a>
        <span class="mx-1">»</span>
        <span>Kinderzauberer in Essen buchen 🎩 – Fantastische Momente für Ihre Kleinen</span>
      </nav>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-[#d7393e] font-bold text-xl mb-4">Kinderzauberer in Essen mit fantastischer Zaubershow! 🌟</h2>
          <p class="text-[#374151] mb-4 leading-relaxed">Mit dem professionellen Kinderzauberer in Essen erleben die Kinder fantastische und unvergessliche Momente! 🎪 Die Zaubershow vereint verblüffende Zauberei mit herzlicher Clownerie, wobei ausschließlich die Kinder (niemals die technischen Tricks!) die absoluten Hauptdarsteller sind. Die kleinen Gäste werden durchgängig aktiviert und schwanken kontinuierlich zwischen spontanem Gelächter und fassungslosem Staunen. Pure Magie zum Anfassen! ✨</p>
          <p class="text-[#374151] mb-4 leading-relaxed">Diese farbenfrohe und humorvolle Show wurde in den vergangenen Jahren kontinuierlich auf Kinderveranstaltungen gebucht und wurde zu einer der beliebtesten in der Region. Warum? Weil hier verblüffende Ereignisse stattfinden, die durch die aktive Beteiligung der Kinder absolut unglaublich erscheinen. Für die jungen Teilnehmer wird diese Zaubershow zu einem unvergesslichen Erlebnis, das noch lange in Erinnerung bleibt! Die nachfolgenden Videos vermitteln Ihnen einen authentischen Eindruck von meiner Arbeit und zeigen, wie meine Zaubershow in Essen Kinderherzen erobert. 🎥</p>
        </div>
        <div class="flex justify-center">
          <img
            src="https://liar-entertainer.com/wp-content/uploads/2023/08/Kinderzauberer-in-Essen-2.jpg"
            alt="Kinderzauberer in Essen"
            class="rounded-full object-cover object-[20%]"
            style="width: 320px; height: 320px;"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <GoogleReviews />

  <!-- Wave: white → blue -->
  <div style="overflow:hidden;line-height:0;background:white;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>
  <section class="bg-[#3b55d5] py-14 text-white">
    <div class="max-w-5xl mx-auto px-4">
      <p class="text-[#ffb546] font-bold text-sm uppercase tracking-widest mb-4 text-center">ESSEN</p>
      <h2 class="text-white font-bold text-3xl sm:text-4xl mb-10 text-center">WEITERE VORTEILE</h2>
      <p class="text-white leading-relaxed mb-4">Mit minimalem Aufwand Ihrerseits und praktisch ohne Vorbereitungszeit komme ich zu Ihrer Veranstaltung und starte sofort mit meinem erprobten Programm: begeisterte Kinder, mitreißende Stimmung und entspannte Eltern! Ob in Wohnräumen 🏠, Außenbereichen 🌳 oder professionellen Eventlocations – ich passe meine Show optimal an die jeweiligen Bedingungen an.</p>
      <p class="text-white leading-relaxed mb-4">Die jungen Zuschauer werden immer wieder aktiv eingebunden und schwanken konstant zwischen herzhaftem Lachen und ungläubigem Staunen… und meine erfolgreichste Nummer funktioniert ausnahmslos: Kindern ein strahlendes Lächeln ins Gesicht zu zaubern! 😊 Sind die Kinder glücklich, sind die Eltern glücklich!</p>
      <div class="flex flex-wrap gap-3 justify-center mt-8">
        <a href="/kinderzauberer/" class="inline-block bg-white text-[#3b55d5] font-bold px-8 py-3 rounded transition-colors hover:bg-gray-100">Über die Zaubershow</a>
        <a href="/kontakt/" class="inline-block bg-[#ffb546] hover:bg-[#e69420] text-white font-bold px-8 py-3 rounded transition-colors">Kontaktformular</a>
      </div>
    </div>
  </section>
  <!-- Wave: blue → white -->
  <div style="overflow:hidden;line-height:0;background:#3b55d5;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- Ihr vertrauensvoller Kinderzauberer in Essen mit TOP Bewertungen! ⭐ -->
  <section class="bg-white py-14">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div>
          <h2 class="text-[#1f2025] font-bold text-2xl sm:text-3xl mb-6">Ihr vertrauensvoller Kinderzauberer in Essen mit TOP Bewertungen! ⭐</h2>
          <p class="text-[#374151] mb-4 leading-relaxed">Mit LIAR, dem erfahrenen Kinderzauberer in Essen, verwandeln Sie jede Veranstaltung in einen außergewöhnlichen Tag! Mit meiner bewährten Zaubershow schaffe ich Erlebnisse, die bei den Kindern nachhaltig in Erinnerung bleiben und noch Wochen später für Gesprächsstoff sorgen. 🎉</p>
          <p class="text-[#374151] mb-4 leading-relaxed">Sie suchen einen Kinderzauberer in Essen? Als passionierter Entertainer für Kinder (perfekt beispielsweise für Kindergeburtstage) erlebe ich täglich funkelnde Kinderaugen 👀 und faszinierte Gesichter – und genau diese puren Glücksmomente sind meine größte Motivation! Durch fantasievoll gestaltete Geschichten werden gewöhnliche Alltagsobjekte zu geheimnisvollen Zauberwerkzeugen. Das überrascht, elektrisiert und schafft eine Atmosphäre voller Begeisterung – und genau das macht einen hervorragenden Kinderzauberer aus! 🪄</p>
        </div>
        <div class="flex justify-center">
          <img src="https://liar-entertainer.com/wp-content/uploads/2023/08/Kinderzauberer-in-Essen-1.jpg" alt="Kinderzauberer in Essen bei einer Veranstaltung" class="rounded-xl w-full max-w-md object-cover object-top shadow-sm" style="max-height:400px;max-width:28rem" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Wave: white → red (Stats) -->
  <div style="overflow:hidden;line-height:0;background:white;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#d7393e"/>
    </svg>
  </div>

  <!-- Stats Banner -->
  <section class="bg-[#d7393e] py-10 text-white text-center">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-transparent border border-white/30 rounded-xl p-6">
          <div class="text-3xl mb-2">🪄</div>
          <div class="text-4xl font-extrabold">400</div>
          <div class="text-sm mt-1">Shows im Jahr</div>
        </div>
        <div class="bg-transparent border border-white/30 rounded-xl p-6">
          <div class="text-3xl mb-2">😊</div>
          <div class="text-4xl font-extrabold">110.000</div>
          <div class="text-sm mt-1">Lachende Kinder</div>
        </div>
        <div class="bg-transparent border border-white/30 rounded-xl p-6">
          <div class="text-3xl mb-2">🪄</div>
          <div class="text-4xl font-extrabold">15</div>
          <div class="text-sm mt-1">Jahre Erfahrung</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave: red → white -->
  <div style="overflow:hidden;line-height:0;background:#d7393e;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- Kindergeburtstag in Essen -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div class="flex justify-center md:order-1">
          <img src="https://liar-entertainer.com/wp-content/uploads/2023/08/Zaubershow-NRW.jpg" alt="Kindergeburtstag in Essen mit Zaubershow" class="rounded-xl w-full max-w-md object-cover object-top shadow-sm" style="max-height:400px;max-width:28rem" loading="lazy" />
        </div>
        <div class="md:order-2">
          <h2 class="text-[#1f2025] font-bold text-2xl sm:text-3xl mb-6">Kindergeburtstag in Essen mit Lachgarantie! 🎂🎈</h2>
          <p class="text-[#374151] mb-4 leading-relaxed">Die wenigsten Eltern in Essen wissen, dass sie einen Clown Zauberer ganz unkompliziert für private Feiern nach Hause einladen können! Doch genau das ist möglich: Einen Kinderzauberer in Essen zu buchen ist kinderleicht – er ist die optimale Lösung zur Animation beim Kindergeburtstag. Ich komme direkt zu Ihnen nach Hause 🏠, in Ihren Garten oder in gemietete Räumlichkeiten!</p>
          <div class="mt-6">
            <a href="/kindergeburtstag/" class="inline-block bg-[#d7393e] hover:bg-[#b62e32] text-white font-bold px-8 py-3 rounded transition-colors">Kindergeburtstag – Preise</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Anlässe für den Kinderzauberer in Essen -->
  <section class="bg-white py-14">
    <div class="max-w-5xl mx-auto px-4">
      <h3 class="text-[#1f2025] font-bold text-xl text-center mb-8">Anlässe für den Kinderzauberer in Essen 👧👦</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#d7393e]"><h4 class="font-bold text-[#1f2025] mb-2">🎂 Kindergeburtstag</h4><p class="text-[#374151] text-sm leading-relaxed">Unvergessliche Feier zu Hause oder in gemieteten Locations</p></div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#3b55d5]"><h4 class="font-bold text-[#1f2025] mb-2">🏫 Schulfeste &amp; Kita-Events</h4><p class="text-[#374151] text-sm leading-relaxed">Begeisterung für große Kindergruppen</p></div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#ffb546]"><h4 class="font-bold text-[#1f2025] mb-2">🏢 Firmenfeiern &amp; Betriebsfeste</h4><p class="text-[#374151] text-sm leading-relaxed">Kinderbetreuung mit Entertainment-Faktor</p></div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#d7393e]"><h4 class="font-bold text-[#1f2025] mb-2">💒 Hochzeiten &amp; Familienfeiern</h4><p class="text-[#374151] text-sm leading-relaxed">Kinderprogramm für entspannte Eltern</p></div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#3b55d5]"><h4 class="font-bold text-[#1f2025] mb-2">🎪 Stadt- &amp; Straßenfeste</h4><p class="text-[#374151] text-sm leading-relaxed">Publikumsmagnet für Open-Air-Events</p></div>
        <div class="bg-white rounded-xl p-6 shadow-sm border-t-4 border-[#ffb546]"><h4 class="font-bold text-[#1f2025] mb-2">⛪ Kommunion &amp; Konfirmation</h4><p class="text-[#374151] text-sm leading-relaxed">Festliche Unterhaltung für junge Gäste</p></div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-center font-bold text-[#1f2025] text-sm uppercase tracking-widest mb-2">NOCH FRAGEN?</h2>
      <h3 class="text-center font-bold text-[#1f2025] text-2xl sm:text-3xl mb-10">
        Hier sind ein paar Antworten
      </h3>

      <div class="space-y-3" id="faq-list">
        <div class="faq-item bg-white border border-gray-200 rounded-lg overflow-hidden">
          <button
            class="faq-btn w-full text-left px-6 py-4 font-semibold text-[#1f2025] flex items-center justify-between gap-4"
            aria-expanded="false"
          >
            <span>Was braucht Clown LIAR für einen Auftritt?</span>
            <svg class="w-5 h-5 flex-shrink-0 transition-transform faq-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-answer hidden px-6 pb-5 text-[#374151] leading-relaxed">
            Ohne Vorbereitungszeit und mit einer Fläche von 2×2 Meter kann ich eine Show vorführen: Wohnzimmer, Kinderzimmer, Partykeller, Terrasse, Gartenanlage, große und kleine Bühne, Kindergarten, Turnhalle… Ob drinnen oder draußen, das Programm lässt sich spontan und flexibel ausführen!
          </div>
        </div>
        <div class="faq-item bg-white border border-gray-200 rounded-lg overflow-hidden">
          <button
            class="faq-btn w-full text-left px-6 py-4 font-semibold text-[#1f2025] flex items-center justify-between gap-4"
            aria-expanded="false"
          >
            <span>Wieviel Platz braucht man für das Programm?</span>
            <svg class="w-5 h-5 flex-shrink-0 transition-transform faq-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-answer hidden px-6 pb-5 text-[#374151] leading-relaxed">
            LIAR ist ziemlich pflegeleicht: für die Show ist es wichtig, dass die Kinder gemütlich und ungestört sitzen können!!! Bei der Ballonmodellage ist nichts weiteres nötig. Bei GLITZER TATTOOS wären schon 2 Stühle und einen Tisch wichtig!
          </div>
        </div>
        <div class="faq-item bg-white border border-gray-200 rounded-lg overflow-hidden">
          <button
            class="faq-btn w-full text-left px-6 py-4 font-semibold text-[#1f2025] flex items-center justify-between gap-4"
            aria-expanded="false"
          >
            <span>Wie viele Kinder sollten überhaupt eingeladen werden?</span>
            <svg class="w-5 h-5 flex-shrink-0 transition-transform faq-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-answer hidden px-6 pb-5 text-[#374151] leading-relaxed">
            Natürlich soll das Kind seine Freunde einladen. Allerdings sollte man eine feste Zahl als Limit vorgeben. Pädagogen empfehlen, maximal genauso viele Gäste einzuladen, wie das Kind alt wird. Wer kommen darf, soll das Kind selbst bestimmen. Natürlich sind auch dabei die Aufsichtspersonen (mindestens 2) nicht zu vergessen.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Video Sektion -->
  <!-- Wave oben (weiß → blau) -->
  <div style="overflow:hidden;line-height:0;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>
  <section class="py-14 bg-[#3b55d5]">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-white font-extrabold text-xl uppercase tracking-widest mb-6">
        SCHNELLE EINDRÜCKE
      </h2>
      <div class="relative w-full max-w-2xl mx-auto mb-8" style="padding-bottom: 56.25%; position: relative;">
        <iframe
          src="https://www.youtube.com/embed/Cop0SqRIX4Y"
          title="Clown Zauberer für Geburtstag, Feier, Veranstaltung in NRW : die lustigste Zaubershow im Pott!"
          class="absolute inset-0 w-full h-full rounded-lg"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
      <h3 class="text-white font-bold text-xl mb-6">
        Mehr Fotos und Videos in der Galerie
      </h3>
      <a
        href="/galerie/"
        class="inline-block bg-[#f5a623] hover:bg-[#e69420] text-[#1f2025] font-bold px-10 py-4 rounded-full text-base transition-colors"
      >
        Zur Foto- und Videogalerie
      </a>
    </div>
  </section>
  <!-- Wave unten (blau → weiß) -->
  <div style="overflow:hidden;line-height:0;background:#3b55d5;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>



  <!-- Einsatzgebiet -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-[#d7393e] font-bold text-2xl text-center mb-10">Einsatzgebiete: Kinderzauberer in Essen und ganz NRW</h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        <div>
          <p class="text-[#374151] mb-4 leading-relaxed">
            Als Kinderzauberer bin ich in allen Essener Stadtteilen verfügbar: Stadtbezirk I (Stadtmitte, Ostviertel, Nordviertel, Westviertel, Südviertel, Huttrop), Stadtbezirk II (Rüttenscheid, Bergerhausen, Rellinghausen, Stadtwald), Stadtbezirk III (Essen-West), Stadtbezirk IV (Borbeck), Stadtbezirk V (Altenessen), Stadtbezirk VI (Katernberg), Stadtbezirk VII (Steele, Kray), Stadtbezirk VIII (Essen-Ruhrhalbinsel), Stadtbezirk IX (Werden, Kettwig) sowie im gesamten Ruhrgebiet und darüber hinaus. Auch überregionale und internationale Buchungen sind möglich!
          </p>
          <p class="text-[#374151] leading-relaxed">
            Auf Anfrage bin ich auch außerhalb von NRW buchbar – inklusive Belgien, Frankreich, Österreich und Schweiz!
          </p>
        </div>
        <div>
          <Image
            src={karteImg}
            alt="Karte Einsatzgebiet Kinderzauberer Essen"
