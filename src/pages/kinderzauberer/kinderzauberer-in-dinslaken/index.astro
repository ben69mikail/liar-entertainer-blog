    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com",
    "telephone": "+491721517578"
  },
  "areaServed": { "@type": "City", "name": "Dinslaken" },
  "offers": { "@type": "Offer", "price": "150", "priceCurrency": "EUR" }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was kostet ein Kinderzauberer in Dinslaken? 💰",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Kosten für einen Kinderzauberer in Dinslaken variieren je nach Art der Veranstaltung, Dauer der Show, Zuschauerzahl und Anfahrt. Für Kindergeburtstage biete ich Festpreise an. Kontaktieren Sie mich unverbindlich für ein individuelles Angebot – ich berate Sie gerne! 📞"
      }
