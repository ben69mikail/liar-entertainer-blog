const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Kinderzauberer-in-Dinslaken-2.jpg';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Kinderzauberer in Dinslaken",
  "description": "Kinderzauberer LIAR für Kindergeburtstag und Kinderevents in Dinslaken, NRW",
  "url": "https://liar-entertainer.com/kinderzauberer/kinderzauberer-in-dinslaken/",
