---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import karteImg from '../../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import { Image } from 'astro:assets';
import GoogleReviews from '../../../components/GoogleReviews.astro';

const seoTitle = "Kinderzauberer Mülheim | TOP Bewertet | Buchen";
const seoDescription = "Kinderzauberer in Mülheim an der Ruhr ✓ Zaubershow für Kinder ✓ 400+ Bewertungen ✓ Ab 150€ ✓ Auch in Essen & Oberhausen ✓ Jetzt unverbindlich buchen!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Kinderzauberer-in-Muelheim-3.jpg';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Kinderzauberer in Mülheim",
  "description": "Kinderzauberer LIAR für Kindergeburtstag und Kinderevents in Mülheim, NRW",
  "url": "https://liar-entertainer.com/kinderzauberer/kinderzauberer-in-muelheim/",
  "serviceType": ["Kinderzauberer", "Zaubershow für Kinder"],
  "provider": {
    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com",
    "telephone": "+491721517578"
  },
  "areaServed": { "@type": "City", "name": "Mülheim" },
  "offers": { "@type": "Offer", "price": "150", "priceCurrency": "EUR" }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "💰 Was kostet ein Kinderzauberer in Mülheim?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Gute Nachrichten: Für Kindergeburtstage arbeite ich mit Festpreisen! 🎂 Diese sind fair kalkuliert und transparent. Für größere Events (Stadtfeste, Firmenfeiern, etc.) erstelle ich individuelle Angebote – abhängig von Dauer, Zuschauerzahl und Art der Veranstaltung. Innerhalb von Mülheim berechne ich keine Extra-Anfahrtskosten. 🚗Tipp: Fragen Sie frühzeitig an – besonders beliebte Termine (Samstage, Ferienzeiten) sind oft Monate im Voraus ausgebucht! 📅"
      }
    },
    {
      "@type": "Question",
      "name": "🏠 Wie viel Platz brauche ich für die Zaubershow?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Super wenig! 😊 Eine Fläche von etwa 2×2 Metern reicht völlig aus. Das funktioniert problemlos in: 🏡 Wohnzimmer (auch in kleinen Wohnungen!)🧒 Kinderzimmer (wenn groß genug)🏠 Partykeller oder Hobbyraum🌳 Garten oder Terrasse🏢 Gemeindehäuser & Turnhallen🎪 Bühnen aller GrößenWichtig: Ich bringe mein komplettes Equipment mit und benötige keine Steckdose (außer bei großen Bühnen-Shows). Vorbereitungszeit? Minimal! ⚡"
      }
    },
    {
      "@type": "Question",
      "name": "⏰ Wie lange dauert die Zaubershow?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Das ist flexibel! 🕐 Die Standard-Variante für Kindergeburtstage in Mülheim dauert 40 Minuten – perfekt für die Aufmerksamkeitsspanne der Kinder. Aber ich passe mich an.Die Show lässt sich problemlos in jeden Ablaufplan integrieren – egal ob vor oder nach dem Kuchenessen! 🍰"
      }
    }
  ]
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Kinderzauberer Mülheim, Kinderzauberer in Mülheim, Zauberer Mülheim, Kindergeburtstag Mülheim, Zaubershow Mülheim, NRW"
  canonical="https://liar-entertainer.com/kinderzauberer/kinderzauberer-in-muelheim/"
  ogImage={heroImg}
  structuredData={structuredData}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImg}'); background-position: center 20%;`}></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex flex-col items-center justify-center text-center px-6" style="min-height: 600px;">
      <div class="inline-flex items-center gap-2 bg-white/20 text-white rounded-full px-4 py-1.5 text-sm font-medium mb-4 backdrop-blur-sm">
        <span>📍</span> Mülheim
