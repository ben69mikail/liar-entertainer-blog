---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';

import heroImg from '../../assets/images/kinderzauberer/kinderzauberer-hero.jpg';
import kindergeburtstagMitKinderzauberer from '../../assets/images/kindergeburtstag/kindergeburtstag-mit-kinderzauberer.jpg';
import clownerieUndZauberei from '../../assets/images/home/clownerie-und-zauberei.jpg';
import fotogalerieClownZauberer16 from '../../assets/images/galerie/fotogalerie-clown-zauberer-16.jpg';
import zaubershowMitClownZaubererLiar from '../../assets/images/kinderzauberer/zaubershow-mit-clown-zauberer-liar.jpg';
import clownZaubererGladbeck from '../../assets/images/kinderzauberer/clown-zauberer-gladbeck.jpg';
import GoogleReviews from '../../components/GoogleReviews.astro';

const seoTitle = 'Kinderzauberer NRW | TOP Bewertungen | Clown LIAR';
const seoDescription = 'Kinderzauberer LIAR in NRW buchen ✓ Lustige Zaubershow für Kindergeburtstag, Kita & Schule ✓ Ab 150€ ✓ 400+ Top-Bewertungen ✓ Jetzt unverbindlich anfragen!';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Kinderzauberer in NRW",
  "description": "Professioneller Kinderzauberer LIAR – Zaubershow für Kindergeburtstag, Schulfeste und Familienfeiern in NRW",
  "url": "https://liar-entertainer.com/kinderzauberer/",
  "serviceType": ["Kinderzauberer", "Zaubershow für Kinder"],
  "provider": {
    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com",
    "telephone": "+491721517578"
  },
  "areaServed": { "@type": "State", "name": "Nordrhein-Westfalen" },
  "offers": {
    "@type": "Offer",
    "price": "150",
    "priceCurrency": "EUR",
    "description": "Zaubershow ab 150€, ca. 40 Minuten"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was kostet einen Auftritt von Kinderzauberer LIAR?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Gage richtet sich nach Art und Umfang der Veranstaltung, Zuschauerzahl, Anfahrtsweg und Jahreszeit. Für Kindergeburtstage biete ich transparente Festpreise an. Kontaktieren Sie mich für ein unverbindliches Angebot – ich berate Sie gerne persönlich!"
      }
    },
    {
      "@type": "Question",
      "name": "Wieviel Platz braucht man für die Zaubershow?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ich benötige lediglich eine Fläche von etwa 2×2 Metern. Das bedeutet: Die Show ist möglich im Wohnzimmer, Kinderzimmer, Partykeller, auf der Terrasse, im Garten, in Turnhallen, Kindergärten, auf kleinen und großen Bühnen – praktisch überall!"
      }
    },
    {
      "@type": "Question",
      "name": "Wie lange dauert eine Vorführung mit dem Kinderzauberer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Show ist ab 25-30 Minuten buchbar und lässt sich flexibel gestalten. Für größere Veranstaltungen oder wenn mehr Zeit zur Verfügung steht, biete ich auch Programme von 45-60 Minuten an. Die Dauer stimme ich individuell mit Ihnen ab."
      }
    },
    {
      "@type": "Question",
      "name": "Für welches Alter ist die Zaubershow geeignet?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Meine Zaubershow ist für Kinder von 3 bis 12 Jahren konzipiert. Ich passe das Programm altersgerecht an: Für Kindergartenkinder gestalte ich die Show etwas einfacher und kürzer, für Grundschulkinder darf es komplexer und länger sein."
      }
    }
  ]
};

const structuredData = [serviceSchema, faqSchema];

---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Kinderzauberer NRW, Kinderzauberer buchen, Zauberer für Kinder, Zaubershow Kindergeburtstag, Kinderzauberer Ruhrgebiet"
  canonical="https://liar-entertainer.com/kinderzauberer/"
  structuredData={structuredData}
  breadcrumbs={[{ name: 'Startseite', url: '/' }, { name: 'Kinderzauberer', url: '/kinderzauberer/' }]}
>

  <!-- Page Title -->
  <section class="bg-white pt-8 pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <p class="text-sm text-[#595959] mb-4">
        <a href="/" class="hover:text-[#d7393e]">Clown</a> »
        <a href="/" class="hover:text-[#d7393e]">Clown Zauberer LIAR</a> »
        <span>Kinderzauberer</span>
      </p>
      <h1 class="font-black text-[#1f2025] text-2xl sm:text-4xl lg:text-5xl mb-6">Kinderzauberer in NRW – Zaubershow für Kindergeburtstag</h1>
    </div>
  </section>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 576px;">
    <Image
      src={heroImg}
      alt="Kinderzauberer NRW – Zaubershow für Kinder"
      class="absolute inset-0 w-full h-full object-cover object-top"
      style="object-position: 46% 70%"
      widths={[480, 768, 1200, 1600]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="relative flex items-center justify-center" style="min-height: 576px;">
      <h2 class="text-white font-bold text-center px-6 leading-tight" style="font-size: clamp(1.8rem, 4.5vw, 3.2rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
        Kinderzauberer in NRW –<br />Zaubershow für unvergessliche Momente
      </h2>
    </div>
  </section>

  <!-- Intro Text -->
  <section class="bg-white py-12">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="text-[#374151] text-lg leading-relaxed mb-4">
        Lachen, Staunen und magische Momente – das ist es, was Kinderaugen strahlen lässt.
      </p>
      <p class="text-[#374151] leading-relaxed mb-4">
        Ich bin Clown Zauberer LIAR (Michaël Prescler) und bringe seit über 15 Jahren Kinder und Familien bei Kindergeburtstagen, Schulfesten und Familienfeiern und Veranstaltungen in NRW zum Staunen.
      </p>
      <p class="text-[#374151] leading-relaxed mb-6">
        Meine <a href="/zauberer/zaubershow/" class="text-[#d7393e] hover:underline">Zaubershow</a> ist speziell für Kinder entwickelt: bunt, humorvoll und voller Mitmachmomente. Schauen Sie sich auch meine <a href="/galerie/" class="text-[#d7393e] hover:underline">Galerie</a> an!
      </p>
      <p class="font-bold text-[#1f2025] text-lg">
        🎉 Perfekt für Kindergeburtstage, Feste, Kindergärten und Schulen.
      </p>
    </div>
  </section>

  <!-- Wave: white → blue -->
  <div style="overflow:hidden;line-height:0;background:white;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>

  <!-- Blue section: YouTube Video -->
  <section class="bg-[#3b55d5] py-12">
    <div class="max-w-4xl mx-auto px-4">
      <div class="relative w-full" style="padding-bottom: 56.25%;">
        <iframe
          src="https://www.youtube.com/embed/Cop0SqRIX4Y"
          title="Clown Zauberer für Geburtstag, Feier, Veranstaltung in NRW : die lustigste Zaubershow im Pott!"
          class="absolute inset-0 w-full h-full rounded-lg"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Wave: blue → white -->
  <div style="overflow:hidden;line-height:0;background:#3b55d5;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- So läuft die Zaubershow ab -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="font-bold text-[#1f2025] text-2xl sm:text-3xl mb-6">So läuft die Zaubershow ab – Magie zum Mitmachen</h2>
          <hr class="border-[#1f2025] w-32 mb-6" />
          <p class="text-[#374151] mb-4 leading-relaxed">
            Meine Kinderzaubershow beginnt mit einer spannenden Geschichte, die die Kinder sofort in ihren Bann zieht. Schon nach wenigen Minuten wird aus der Geschichte eine rasante, witzige und zauberhafte Show, bei der die Grenzen zwischen Zauberer und Publikum verschwimmen.
          </p>
          <p class="font-semibold text-[#1f2025] mb-4">Die Kinder erleben:</p>
          <ul class="space-y-2 text-[#374151] mb-6">
            <li>✅ Verblüffende Zaubertricks mit Alltagsgegenständen</li>
            <li>✅ Eigene Zaubermomente, wenn sie mir auf der „Bühne" assistieren</li>
            <li>✅ Lustiges Chaos, wenn Tricks scheinbar schiefgehen</li>
            <li>✅ Staunen und Lachen im ständigen Wechsel</li>
            <li>✅ Das unbezahlbare Gefühl, selbst gezaubert zu haben</li>
          </ul>
          <p class="text-[#374151] mb-8 leading-relaxed">
            Der beste Trick? Den gibt es nicht – denn der schönste Moment ist immer, wenn ich den Kindern ein echtes Lächeln ins Gesicht zaubere. Das ist die Magie, die wirklich zählt!
          </p>
          <a href="/kindergeburtstag/" class="inline-block bg-[#d7393e] hover:bg-[#b62e32] text-white font-bold px-8 py-3 rounded transition-colors">
            Kindergeburtstag – Preise
          </a>
        </div>
        <div class="flex justify-center">
          <Image
            src={kindergeburtstagMitKinderzauberer}
            alt="Kinderzauberer auf einem Kindergeburtstag in Essen"
            class="rounded-full object-cover object-[20%]"
            style="width: 300px; height: 300px;"
            loading="lazy"
            widths={[300, 600]}
            sizes="300px"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 3-Column Info Cards mit runden Bildern -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Einfach und unkompliziert -->
        <div class="text-center px-4">
          <div class="flex justify-center mb-4">
            <Image
              src={clownerieUndZauberei}
              alt="Kinderzauberer LIAR verbindet Clownerie und Zauberei auf einem Kinderfest"
              class="rounded-full object-cover object-[20%]"
              style="width: 150px; height: 150px;"
              loading="lazy"
              widths={[150, 300]}
              sizes="150px"
            />
          </div>
          <hr class="border-[#1f2025] border-2 mx-auto mb-4 w-4/5" />
          <h3 class="font-bold text-[#1f2025] text-lg mb-3">Einfach und unkompliziert</h3>
          <p class="text-[#374151] leading-relaxed text-sm">
            Mit wenig Aufwand und fast ohne Vorbereitungszeit komme ich vorbei… und lege mit meinem Programm los: lachende Kinder, ausgelassene Stimmung und entspannte Eltern!
          </p>
        </div>
        <!-- Sehen und mit fiebern -->
        <div class="text-center px-4">
          <div class="flex justify-center mb-4">
            <Image
              src={fotogalerieClownZauberer16}
              alt="Kinderzauberer bringt Kinder zum Staunen bei Zaubershow in NRW"
              class="rounded-full object-cover object-[20%]"
              style="width: 150px; height: 150px;"
              loading="lazy"
              widths={[150, 300]}
              sizes="150px"
            />
          </div>
          <hr class="border-[#1f2025] border-2 mx-auto mb-4 w-4/5" />
          <h3 class="font-bold text-[#1f2025] text-lg mb-3">Sehen und mit fiebern</h3>
          <p class="text-[#374151] leading-relaxed text-sm">
            Die Kinder werden immer wieder mit eingebunden und pendeln die ganze Zeit zwischen Lachen und Staunen… und mein bester Trick funktioniert immer: den Kindern ein Lächeln ins Gesicht zu zaubern.
          </p>
        </div>
        <!-- Witziger Kinderzauberer -->
        <div class="text-center px-4">
          <div class="flex justify-center mb-4">
            <Image
              src={zaubershowMitClownZaubererLiar}
              alt="Kinderzauberer bei Zaubershow in einer Schule"
              class="rounded-full object-cover object-[20%]"
              style="width: 150px; height: 150px;"
              loading="lazy"
              widths={[150, 300]}
              sizes="150px"
            />
          </div>
          <hr class="border-[#1f2025] border-2 mx-auto mb-4 w-4/5" />
          <h3 class="font-bold text-[#1f2025] text-lg mb-3">Witziger Kinderzauberer</h3>
          <p class="text-[#374151] leading-relaxed text-sm">
            Ob Schulfeier, Weihnachtsfeier, Hochzeit, Gartenfest, oder Kommunion sowie Kindergärten oder Schulen sorge ich für staunende und lachende Gesichter. Auch im Wohnzimmer für den Kindergeburtstag!
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <GoogleReviews />

  <!-- Wave: white → red -->
  <div style="overflow:hidden;line-height:0;background:white;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#d7393e"/>
    </svg>
  </div>

  <!-- Stats Banner -->
  <section class="bg-[#d7393e] py-10 text-white text-center">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-transparent border border-white/30 rounded-xl p-6">
          <div class="text-3xl mb-2">🪄</div>
          <div class="text-4xl font-extrabold">400</div>
          <div class="text-sm mt-1">Shows im Jahr</div>
        </div>
        <div class="bg-transparent border border-white/30 rounded-xl p-6">
          <div class="text-3xl mb-2">😊</div>
          <div class="text-4xl font-extrabold">110.000</div>
          <div class="text-sm mt-1">Lachende Kinder</div>
        </div>
        <div class="bg-transparent border border-white/30 rounded-xl p-6">
          <div class="text-3xl mb-2">🪄</div>
          <div class="text-4xl font-extrabold">15</div>
          <div class="text-sm mt-1">Jahre Erfahrung</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave: red → white -->
  <div style="overflow:hidden;line-height:0;background:#d7393e;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- FAQ / Wissenwertes -->
  <section class="bg-white py-14">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-bold text-[#1f2025] text-2xl sm:text-3xl text-center mb-10">
        WISSENWERTES über den ZAuberer für KINDER
      </h2>
      <div class="space-y-8">
        <div>
          <h3 class="font-bold text-[#1f2025] text-center mb-4">Was kostet einen Auftritt von Kinderzauberer LIAR?</h3>
          <p class="text-[#374151] leading-relaxed">
            Die Gage richtet sich nach Art und Umfang der Veranstaltung, Zuschauerzahl, Anfahrtsweg und Jahreszeit. Für Kindergeburtstage biete ich transparente Festpreise an. Kontaktieren Sie mich für ein unverbindliches Angebot – ich berate Sie gerne persönlich!
          </p>
        </div>
        <div>
          <h3 class="font-bold text-[#1f2025] text-center mb-4">Wieviel Platz braucht man für die Zaubershow?</h3>
          <p class="text-[#374151] leading-relaxed">
            Ich benötige lediglich eine Fläche von etwa 2×2 Metern. Das bedeutet: Die Show ist möglich im Wohnzimmer, Kinderzimmer, Partykeller, auf der Terrasse, im Garten, in Turnhallen, Kindergärten, auf kleinen und großen Bühnen – praktisch überall!
          </p>
        </div>
        <div>
          <h3 class="font-bold text-[#1f2025] text-center mb-4">Wie lange dauert eine Vorführung mit dem Kinderzauberer?</h3>
          <p class="text-[#374151] leading-relaxed">
            Die Show ist ab 25-30 Minuten buchbar und lässt sich flexibel gestalten. Für größere Veranstaltungen oder wenn mehr Zeit zur Verfügung steht, biete ich auch Programme von 45-60 Minuten an. Die Dauer stimme ich individuell mit Ihnen ab.
          </p>
        </div>
        <div>
          <h3 class="font-bold text-[#1f2025] text-center mb-4">Für welches Alter ist die Zaubershow geeignet?</h3>
          <p class="text-[#374151] leading-relaxed">
            Meine Zaubershow ist für Kinder von 3 bis 12 Jahren konzipiert. Ich passe das Programm altersgerecht an: Für Kindergartenkinder gestalte ich die Show etwas einfacher und kürzer, für Grundschulkinder darf es komplexer und länger sein.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Einsatzgebiet -->
  <section class="bg-gray-50 py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-[#d7393e] font-bold text-2xl text-center mb-2">Regional und deutschlandweit</h2>
      <h3 class="font-bold text-[#1f2025] text-center mb-10">Kinderzauberer Einsatzgebiet</h3>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        <div>
          <p class="text-[#374151] mb-4 leading-relaxed">
            Ich trete regelmäßig in Städten wie: <a href="/kinderzauberer/kinderzauberer-in-oberhausen/" class="text-[#3b55d5] hover:underline">Oberhausen</a>, <a href="/kinderzauberer/kinderzauberer-in-gelsenkirchen/" class="text-[#3b55d5] hover:underline">Gelsenkirchen</a>, <a href="/kinderzauberer/kinderzauberer-in-essen/" class="text-[#3b55d5] hover:underline">Essen</a>, <a href="/kinderzauberer/kinderzauberer-in-duisburg/" class="text-[#3b55d5] hover:underline">Duisburg</a>, <a href="/kinderzauberer/kinderzauberer-in-dorsten/" class="text-[#3b55d5] hover:underline">Dorsten</a>, <a href="/kinderzauberer/kinderzauberer-in-herten/" class="text-[#3b55d5] hover:underline">Herten</a>, <a href="/kinderzauberer/kinderzauberer-in-herne/" class="text-[#3b55d5] hover:underline">Herne</a>, <a href="/kinderzauberer/kinderzauberer-in-marl/" class="text-[#3b55d5] hover:underline">Marl</a>, Gladbeck, <a href="/kinderzauberer/kinderzauberer-in-muelheim/" class="text-[#3b55d5] hover:underline">Mülheim</a>, <a href="/kinderzauberer/kinderzauberer-in-duesseldorf/" class="text-[#3b55d5] hover:underline">Düsseldorf</a>, <a href="/kinderzauberer/kinderzauberer-in-dortmund/" class="text-[#3b55d5] hover:underline">Dortmund</a>, <a href="/kinderzauberer/kinderzauberer-in-moers/" class="text-[#3b55d5] hover:underline">Moers</a>, <a href="/kinderzauberer/kinderzauberer-in-bochum/" class="text-[#3b55d5] hover:underline">Bochum</a>, <a href="/kinderzauberer/kinderzauberer-in-bottrop/" class="text-[#3b55d5] hover:underline">Bottrop</a>, <a href="/kinderzauberer/kinderzauberer-in-datteln/" class="text-[#3b55d5] hover:underline">Datteln</a>, <a href="/kinderzauberer/kinderzauberer-in-dinslaken/" class="text-[#3b55d5] hover:underline">Dinslaken</a>, <a href="/kinderzauberer/kinderzauberer-in-haltern/" class="text-[#3b55d5] hover:underline">Haltern</a>, <a href="/kinderzauberer/kinderzauberer-in-recklinghausen/" class="text-[#3b55d5] hover:underline">Recklinghausen</a> … Jedoch kann man mich auch überregional und international (Frankreich, Belgien, Österreich, Schweiz) buchen!
          </p>
          <div class="space-y-3">
            <p class="font-semibold text-[#1f2025]">Jetzt unverbindlich anfragen</p>
            <p>📧 <a href="mailto:info@liar-entertainer.com" class="text-[#3b55d5] hover:underline">info@liar-entertainer.com</a></p>
            <p>📞 <a href="tel:+491721517578" class="text-[#3b55d5] hover:underline">+49 172 1517578</a></p>
          </div>
        </div>
        <div>
          <Image
            src={clownZaubererGladbeck}
            alt="Einsatzgebiet Kinderzauberer LIAR in NRW – Karte mit Standort Gladbeck"
            class="rounded-lg w-full h-auto"
            loading="lazy"
            widths={[400, 800]}
            sizes="(min-width: 1024px) 50vw, 100vw"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="bg-white py-12 border-t border-gray-100">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-bold text-[#1f2025] text-xl mb-4">Einfach Kontakt aufnehmen</h2>
      <p class="text-[#374151] mb-6 leading-relaxed">
        Sie können mir Ihre Anfrage unverbindlich senden. Ihre Angaben werden selbstverständlich absolut vertraulich behandelt und nicht weitergegeben. Je mehr Angaben ich von Ihnen bekomme, desto besser kann ich Sie beraten. Sie können auch einfach unter 0172-1517578 anrufen oder über WhatsApp schreiben. Ich helfe Ihnen gerne weiter.
      </p>
      <a href="/kontakt/" class="inline-block bg-[#d7393e] hover:bg-[#b62e32] text-white font-bold px-8 py-3 rounded transition-colors">
        Kontaktformular
      </a>
    </div>
  </section>

</BaseLayout>
