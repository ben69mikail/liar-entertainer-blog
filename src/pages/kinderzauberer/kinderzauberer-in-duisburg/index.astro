---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import karteImg from '../../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import { Image } from 'astro:assets';
import GoogleReviews from '../../../components/GoogleReviews.astro';

const seoTitle = "Kinderzauberer Duisburg | TOP Bewertet | Buchen";
const seoDescription = "Kinderzauberer in Duisburg für Kinder-Events & Geburtstag ✓ Clown LIAR ✓ 400+ Bewertungen ✓ Ab 150€ ✓ Auch in Oberhausen & Dinslaken ✓ Jetzt buchen!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Kinderzauberer-in-Duisburg-1.jpg';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Kinderzauberer in Duisburg",
  "description": "Kinderzauberer LIAR für Kindergeburtstag und Kinderevents in Duisburg, NRW",
  "url": "https://liar-entertainer.com/kinderzauberer/kinderzauberer-in-duisburg/",
  "serviceType": ["Kinderzauberer", "Zaubershow für Kinder"],
  "provider": {
    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com",
    "telephone": "+491721517578"
  },
  "areaServed": { "@type": "City", "name": "Duisburg" },
  "offers": { "@type": "Offer", "price": "150", "priceCurrency": "EUR" }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was kostet ein Kinderzauberer in Duisburg? 💰",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Investition richtet sich nach verschiedenen Kriterien: Veranstaltungsformat und -umfang, Programmlänge, Gästezahl sowie Anfahrtsdistanz. Für klassische Kindergeburtstage biete ich transparente Paketpreise! Nehmen Sie gerne Kontakt auf für ein individuelles und kostenloses Angebot – ich berate Sie fundiert! 📞"
      }
    },
    {
      "@type": "Question",
      "name": "Welchen Platzbedarf hat die Show? 📏",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Meine Zaubershow in Duisburg ist maximal flexibel! Erforderlich ist lediglich eine Spielfläche von 2×2 Metern – ohne zeitaufwendigen Aufbau oder komplizierte Vorbereitung. Ob in Privaträumen, Außenbereichen 🌳, Partylokalen, Kindergärten, Schulgebäuden oder auf Großveranstaltungen: Ich arrangiere mich optimal nach den räumlichen Möglichkeiten."
      }
    },
    {
      "@type": "Question",
      "name": "Wie lange dauert eine typische Performance? ⏰",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Zaubershow in Duisburg ist ab 30 Minuten buchbar und wird präzise auf Ihre Wünsche angepasst. Optimal für: Kindergeburtstage 🎉, Kitaevents, Schulprojekte, Sommerfeste, Firmenveranstaltungen, Hochzeiten, Kommunionen oder öffentliche Feste. Die genaue Showdauer stimme ich individuell auf Ihr Event und die Altersstruktur ab."
      }
    },
    {
      "@type": "Question",
      "name": "Nur in Duisburg tätig? 🗺️",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolut nicht! Als Kinderzauberer bin ich in ganz Duisburg sowie allen Stadtteilen verfügbar: Mitte, Süd, Nord, Walsum, Homberg, Rheinhausen, Meiderich sowie im gesamten Umfeld: Oberhausen, Mülheim, Dinslaken, Moers, Essen, Düsseldorf und darüber hinaus in Gelsenkirchen, Bottrop, Krefeld, Dortmund, Bochum und zahlreichen weiteren NRW-Städten. Auch bundesweite und internationale Engagements 🌍 (Niederlande, Belgien, Österreich, Schweiz) nehme ich gerne an!"
      }
    }
  ]
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
