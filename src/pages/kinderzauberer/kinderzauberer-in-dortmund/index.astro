---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import karteImg from '../../../assets/images/home/clown-zauberer-gladbeck-karte.jpg';
import { Image } from 'astro:assets';
import GoogleReviews from '../../../components/GoogleReviews.astro';

const seoTitle = "Kinderzauberer Dortmund | TOP Bewertet | Buchen";
const seoDescription = "Kinderzauberer in Dortmund für Kindergeburtstag & Events ✓ Clown LIAR ✓ 400+ Bewertungen ✓ Ab 150€ ✓ Auch in Bochum & Herne ✓ Jetzt buchen!";
const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Kinderzauberer-in-Dortmund-1.jpg';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Kinderzauberer in Dortmund",
  "description": "Kinderzauberer LIAR für Kindergeburtstag und Kinderevents in Dortmund, NRW",
  "url": "https://liar-entertainer.com/kinderzauberer/kinderzauberer-in-dortmund/",
  "serviceType": ["Kinderzauberer", "Zaubershow für Kinder"],
  "provider": {
    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com",
    "telephone": "+491721517578"
  },
  "areaServed": { "@type": "City", "name": "Dortmund" },
  "offers": { "@type": "Offer", "price": "150", "priceCurrency": "EUR" }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was braucht Clown LIAR für einen Auftritt?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ohne Vorbereitungszeit und mit einer Fläche von 2×2 Meter kann ich eine Show vorführen: Wohnzimmer, Kinderzimmer, Partykeller, Terrasse, Gartenanlage, große und kleine Bühne, Kindergarten, Turnhalle… Ob drinnen oder draußen, das Programm lässt sich spontan und flexibel ausführen!"
      }
    },
    {
      "@type": "Question",
      "name": "Wieviel Platz braucht man für das Programm?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "LIAR ist ziemlich pflegeleicht: für die Show ist es wichtig, dass die Kinder gemütlich und ungestört sitzen können!!! Bei der Ballonmodellage ist nichts weiteres nötig. Bei GLITZER TATTOOS wären schon 2 Stühle und einen Tisch wichtig!"
      }
    },
    {
      "@type": "Question",
      "name": "Wie viele Kinder sollten überhaupt eingeladen werden?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Natürlich soll das Kind seine Freunde einladen. Allerdings sollte man eine feste Zahl als Limit vorgeben. Pädagogen empfehlen, maximal genauso viele Gäste einzuladen, wie das Kind alt wird. Wer kommen darf, soll das Kind selbst bestimmen. Natürlich sind auch dabei die Aufsichtspersonen (mindestens 2) nicht zu vergessen."
      }
    }
  ]
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Kinderzauberer Dortmund, Kinderzauberer in Dortmund, Zauberer Dortmund, Kindergeburtstag Dortmund, Zaubershow Dortmund, NRW"
  canonical="https://liar-entertainer.com/kinderzauberer/kinderzauberer-in-dortmund/"
  ogImage={heroImg}
  structuredData={structuredData}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 600px;">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImg}'); background-position: center 20%;`}></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative flex flex-col items-center justify-center text-center px-6" style="min-height: 600px;">
      <div class="inline-flex items-center gap-2 bg-white/20 text-white rounded-full px-4 py-1.5 text-sm font-medium mb-4 backdrop-blur-sm">
        <span>📍</span> Dortmund
      </div>
      <h1 class="text-white font-extrabold text-center leading-tight mb-3" style="font-size: clamp(2rem, 5vw, 3.5rem); text-shadow: 2px 2px 8px rgba(0,0,0,0.5);">
        Kinderzauberer in Dortmund – Magische Shows für Ihr Event
      </h1>
      <p class="text-gray-200 text-base leading-relaxed max-w-xl mx-auto">
        Magische Zaubershow für Kinder in Dortmund – Staunen, Lachen und unvergessliche Momente!
      </p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <section class="bg-white pt-4 pb-0">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="text-sm text-[#595959]">
        <a href="/" class="text-[#d7393e] hover:underline">Clown</a>
        <span class="mx-1">»</span>
        <a href="/kinderzauberer/" class="text-[#d7393e] hover:underline">Kinderzauberer</a>
        <span class="mx-1">»</span>
        <span>Kinderzauberer in Dortmund – Magische Shows für Ihr Event</span>
      </nav>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-[#d7393e] font-bold text-xl mb-4">Der beliebteste Kinderzauberer in Dortmund! ⭐</h2>
          <p class="text-[#374151] mb-4 leading-relaxed">Mit LIAR, dem professionellen Kinderzauberer in Dortmund, verwandeln Sie jedes Event in ein magisches Abenteuer! 🎪 Ob Kindergeburtstag, Schulveranstaltung oder Firmenevent mit Kinderprogramm – meine mitreißende Zaubershow hinterlässt bleibende Eindrücke bei Kindern von 3 bis 12 Jahren.</p>
          <p class="text-[#374151] mb-4 leading-relaxed">Das Besondere? Jede Show wird individuell konzipiert und auf Ihr Event abgestimmt! ✨</p>
          <p class="text-[#374151] mb-4 leading-relaxed">Sie planen ein Event in Dortmund und suchen professionelle Unterhaltung für Kinder? Als erfahrener Kinderentertainer erlebe ich immer wieder, wie die Augen der Kleinen vor Begeisterung funkeln 👀 und ihre Gesichter vor Staunen erstarren – diese magischen Momente sind der Grund, warum ich meinen Beruf liebe! Durch spannende Rahmengeschichten werden alltägliche Dinge zu geheimnisvollen Zauberobjekten. Das beeindruckt, elektrisiert und sorgt für eine Atmosphäre purer Freude! 🎉</p>
          <div class="flex flex-wrap gap-3 mt-4">
            <a href="/zauberer/zaubershow/" class="inline-block bg-[#3b55d5] hover:bg-[#2a3fa8] text-white font-bold px-8 py-3 rounded transition-colors">Über die Zaubershow</a>
            <a href="/kindergeburtstag/" class="inline-block bg-[#d7393e] hover:bg-[#b62e32] text-white font-bold px-8 py-3 rounded transition-colors">Kindergeburtstag – Preise</a>
          </div>
        </div>
        <div class="flex justify-center">
          <img
            src="https://liar-entertainer.com/wp-content/uploads/2023/08/Kinderzauberer-in-Dortmund-3.jpg"
            alt="Kinderzauberer in Dortmund"
            class="rounded-full object-cover object-[20%]"
            style="width: 320px; height: 320px;"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <GoogleReviews />

  <!-- Wave: white → blue -->
  <div style="overflow:hidden;line-height:0;background:white;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 Q720,60 1440,0 L1440,60 L0,60 Z" fill="#3b55d5"/>
    </svg>
  </div>
  <section class="bg-[#3b55d5] py-14 text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-[#ffb546] font-bold text-sm uppercase tracking-widest mb-4">DORTMUND</p>
      <h2 class="text-white font-bold text-3xl sm:text-4xl mb-6">✨ Kinderzauberer in Dortmund – mit Herz &amp; Humor</h2>
      <p class="text-white leading-relaxed mb-4">
        Meine Show ist speziell auf Kinder abgestimmt: lebendig, interaktiv und voller Überraschungen.
      </p>
      <p class="text-white leading-relaxed">
        Die Kinder dürfen mitzaubern, lachen, staunen – und manchmal selbst zur kleinen Zauberin oder zum Zauberer werden.
        Dabei achte ich besonders auf Respekt, Empathie und ein liebevolles Miteinander.
      </p>
    </div>
  </section>
  <!-- Wave: blue → white -->
  <div style="overflow:hidden;line-height:0;background:#3b55d5;display:block;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 Q720,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- Magische Zaubershow in Dortmund – Entertainment auf höchstem Niveau! 🪄 -->
  <section class="bg-white py-14">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-[#1f2025] font-bold text-2xl sm:text-3xl text-center mb-10">Magische Zaubershow in Dortmund – Entertainment auf höchstem Niveau! 🪄</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div>
          <p class="text-[#374151] mb-4 leading-relaxed">Die Zaubershow in Dortmund verbindet meisterhafte Zauberkunst mit herzlicher Komik – und dabei stehen ausnahmslos die Kinder (nicht etwa die Illusion!) im Fokus des Geschehens. Als aktive Mitspieler erleben die jungen Gäste einen permanenten Wechsel zwischen ausgelassenem Gelächter 😄 und fassungslosem Erstaunen.</p>
          <p class="text-[#374151] mb-4 leading-relaxed">Meine bunte und energiegeladene Performance ist perfekt auf verschiedene Altersgruppen zugeschnitten. Die Kinder werden zu Protagonisten der Show, verwandeln sich in Zauberhelfer 🎩 und sind Teil verblüffender Illusionen, die ihre Vorstellungskraft übersteigen.</p>
        </div>
        <div>
          <img src="https://liar-entertainer.com/wp-content/uploads/2023/08/Kinderzauberer-in-Dortmund-2-1.jpg" alt="Zaubershow mit Kinderzauberer in Dortmund" class="rounded-xl w-full object-cover object-top shadow-sm" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Wave: white → red (Stats) -->
  <div style="overflow:hidden;line-height:0;background:white;display:block;">
