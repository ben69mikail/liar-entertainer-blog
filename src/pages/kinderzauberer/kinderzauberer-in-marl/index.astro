const heroImg = 'https://liar-entertainer.com/wp-content/uploads/2023/08/Kinderzauberer-in-Marl-3.jpg';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Kinderzauberer in Marl",
  "description": "Kinderzauberer LIAR für Kindergeburtstag und Kinderevents in Marl, NRW",
  "url": "https://liar-entertainer.com/kinderzauberer/kinderzauberer-in-marl/",
  "serviceType": ["Kinderzauberer", "Zaubershow für Kinder"],
  "provider": {
    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com",
    "telephone": "+491721517578"
  },
  "areaServed": { "@type": "City", "name": "Marl" },
  "offers": { "@type": "Offer", "price": "150", "priceCurrency": "EUR" }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was kostet ein Kinderzauberer für einen Kindergeburtstag in Marl?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Kosten für einen Auftritt als Kinderzauberer in Marl variieren je nach mehreren Faktoren: Art und Dauer der Veranstaltung, Anzahl der Kinder, Entfernung innerhalb Marls und Jahreszeit. Für Kindergeburtstage biete ich Festpreise an, die transparent und fair kalkuliert sind. Kontaktieren Sie mich einfach für ein unverbindliches Angebot – ich berate Sie gerne persönlich zu den Möglichkeiten für Ihre Feier in Marl."
      }
    },
    {
      "@type": "Question",
      "name": "Wie viel Platz wird für die Zaubershow in Marl benötigt?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die gute Nachricht: Meine Show ist extrem flexibel! Ich benötige lediglich eine Fläche von etwa 2×2 Metern und komme fast ohne Vorbereitungszeit aus. Ob in Ihrem Wohnzimmer in Sinsen, im Partykeller in Alt-Marl, auf der Terrasse in Brassert oder im Gemeindehaus – ich passe mich den örtlichen Gegebenheiten an. Auch für größere Events in Turnhallen, Bürgerzentren oder auf der Bühne beim Stadtfest bin ich bestens gerüstet."
      }
    },
    {
      "@type": "Question",
      "name": "Wie lange dauert eine Zaubervorführung mit dem Kinderzauberer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Meine Zaubershow können Sie flexibel ab 30 Minuten buchen. Die Standard-Variante dauert etwa 45 Minuten – ideal für die Aufmerksamkeitsspanne der Kinder und perfekt als Highlight während eines Kindergeburtstags. Für größere Veranstaltungen oder Stadtfeste in Marl biete ich auch längere Programme oder mehrere kürzere Durchgänge an. Die Show lässt sich problemlos in jeden Ablaufplan integrieren."
      }
    }
  ]
};

const structuredData = [serviceSchema, faqSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords="Kinderzauberer Marl, Kinderzauberer in Marl, Zauberer Marl, Kindergeburtstag Marl, Zaubershow Marl, NRW"
  canonical="https://liar-entertainer.com/kinderzauberer/kinderzauberer-in-marl/"
