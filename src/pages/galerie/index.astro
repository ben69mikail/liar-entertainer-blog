---

<BaseLayout
  title="Galerie | Clown Zauberer LIAR — Fotos & Videos"
  description="Galerie von Clown Zauberer LIAR ✓ Fotos & Videos von Zaubershow, Clownshow & Events in NRW ✓ Presseartikel & Referenzen ✓ 400+ begeisterte Kunden!"
  keywords="Clown Zauberer Fotos, Zaubershow Video, Clown NRW Galerie, Zauberer Presse, Clown Zauberer LIAR Referenzen"
  canonical="https://liar-entertainer.com/galerie/"
  breadcrumbs={[{ name: 'Startseite', url: '/' }, { name: 'Galerie', url: '/galerie/' }]}
>
  <section class="py-12 bg-[#f4f4f4]">
    <div class="max-w-[960px] mx-auto px-4">
      <h1 class="text-[#1f2025] font-extrabold text-3xl text-center mb-3">Fotos – Videos – Presse Referenzen</h1>
      <p class="text-[#595959] text-center mb-10">
        Impressionen aus Auftritten von Clown Zauberer LIAR in NRW
      </p>

      <GoogleReviews />

      <!-- Videos -->
      <h2 class="text-[#1f2025] font-bold text-2xl text-center mb-6">Videos</h2>
      <p class="text-[#374151] text-center leading-relaxed mb-8">
        Ein Bild sagt mehr als tausend Worte, noch mehr erzählt Ihnen ein Video. Die nachfolgenden Imagefilme vermitteln Ihnen einen guten Eindruck von meiner Arbeit mit Kindern. Natürlich haben Sie die Möglichkeit in meine kleine Fotogalerie zu stöbern. Viel Spaß!!!
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
        <div>
          <h3 class="text-[#1f2025] font-bold text-xl text-center mb-4">Neues Video</h3>
          <div class="relative w-full" style="padding-bottom: 56.25%;">
            <iframe
              src="https://www.youtube.com/embed/Cop0SqRIX4Y"
              title="Clown Zauberer für Geburtstag, Feier, Veranstaltung in NRW : die lustigste Zaubershow im Pott!"
              class="absolute inset-0 w-full h-full rounded-lg"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        </div>
        <div>
          <h3 class="text-[#1f2025] font-bold text-xl text-center mb-4">Vintage</h3>
          <div class="relative w-full" style="padding-bottom: 56.25%;">
            <iframe
              src="https://www.youtube.com/embed/2n54fC-04lo"
              title="---VINTAGE--- Clown Zauberer LIAR, die lustigste Zaubershow NRW. ---VINTAGE---"
              class="absolute inset-0 w-full h-full rounded-lg"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        </div>
      </div>

      <!-- Fotos -->
      <h2 class="text-[#1f2025] font-bold text-2xl text-center mb-6">📸 Fotos</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
        {photoImages.map((img, i) => (
          <div class="aspect-square overflow-hidden bg-gray-200 rounded-lg">
            <Image
              src={img.src}
              alt={img.alt}
              widths={[150, 300, 450]}
              sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
              class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-300"
              loading={i < 4 ? 'eager' : 'lazy'}
              width={300}
              height={300}
            />
          </div>
        ))}
      </div>

      <!-- Presse / Zeitungsartikel -->
      <h2 class="text-[#1f2025] font-bold text-2xl text-center mt-16 mb-6">📰 Presse & Zeitungsartikel</h2>
      <p class="text-[#374151] text-center leading-relaxed mb-8">
        Berichte und Artikel aus lokalen Zeitungen über Auftritte und Events von Clown Zauberer LIAR.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
        {presseImages.map((img) => (
          <div class="aspect-square overflow-hidden bg-gray-200 rounded-lg">
            <Image
              src={img.src}
              alt={img.alt}
              widths={[150, 300, 450]}
              sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
              class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-300"
              loading="lazy"
              width={300}
              height={300}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Wave Trenner -->
  <div class="relative">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none" style="height: 40px;">
      <path d="M0 60L60 50C120 40 240 20 360 15C480 10 600 20 720 25C840 30 960 30 1080 25C1200 20 1320 10 1380 5L1440 0V60H0Z" fill="#c9d7f0"/>
    </svg>
  </div>

  <!-- Referenzen -->
  <section class="bg-[#c9d7f0] py-14">
    <div class="max-w-[960px] mx-auto px-4">
      <h2 class="text-[#1f2025] font-bold text-2xl text-center mb-3">⭐ Referenzen</h2>
      <p class="text-[#374151] text-center leading-relaxed mb-10">
        Eine Auswahl an Kunden und Partnern, für die Clown Zauberer LIAR bereits aufgetreten ist.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {referenzen.map((ref) => (
          <div class="bg-white/70 rounded-lg px-4 py-3 text-center">
            <p class="font-semibold text-[#1f2025] text-sm">{ref.name}</p>
            {ref.detail && (
              <p class="text-[#6b7280] text-xs mt-1">({ref.detail})</p>
            )}
          </div>
        ))}
      </div>
      <p class="text-[#374151] text-center text-sm mt-6 italic">…und viele andere mehr!</p>
    </div>
  </section>

  <!-- Wave Trenner zurück -->
  <div class="relative">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none" style="height: 40px;">
      <path d="M0 0L60 10C120 20 240 40 360 45C480 50 600 40 720 35C840 30 960 30 1080 35C1200 40 1320 50 1380 55L1440 60V0H0Z" fill="#c9d7f0"/>
    </svg>
  </div>

  <!-- CTA -->
  <section class="bg-[#f4f4f4] py-12">
    <div class="max-w-[960px] mx-auto px-4 text-center">
      <p class="text-[#374151] mb-4">Möchten Sie Clown Zauberer LIAR für Ihr Event buchen?</p>
      <a
        href="/kontakt/"
        class="inline-flex items-center gap-2 bg-[#d7393e] hover:bg-[#b62e32] text-white font-bold px-8 py-3 rounded transition-colors"
      >
        Jetzt anfragen
      </a>
      <div class="mt-8 flex flex-wrap justify-center gap-4 text-sm">
        <a href="/kindergeburtstag/" class="text-[#d7393e] hover:underline">🎂 Kindergeburtstag-Preise</a>
        <a href="/zauberer/zaubershow/" class="text-[#d7393e] hover:underline">🎩 Zaubershow</a>
        <a href="/clown/clownshow/" class="text-[#d7393e] hover:underline">🤡 Clownshow</a>
        <a href="/ueber-mich/" class="text-[#d7393e] hover:underline">👤 Über mich</a>
        <a href="/blog/" class="text-[#d7393e] hover:underline">📝 Blog</a>
      </div>
    </div>
  </section>
</BaseLayout>
