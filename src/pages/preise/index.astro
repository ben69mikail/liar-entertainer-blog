  <!-- Fahrtkosten -->
  <section class="py-14 bg-[#f9fafb]">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-[#1f2025] font-extrabold text-2xl sm:text-3xl text-center mb-2">Fahrtkosten ab Gladbeck</h2>
