---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GoogleReviews from '../../components/GoogleReviews.astro';
import heroImg from '../../assets/images/kindergeburtstag/kindergeburtstag-hero.jpg';
import zaubershowImg from '../../assets/images/shows/zaubershow.jpg';
import ballonImg from '../../assets/images/shows/ballonmodellage.jpg';
import glitzerImg from '../../assets/images/shows/glitzer-tattoos.jpg';

const title = 'Preise & Pakete | Clown Zauberer LIAR | Kindergeburtstag ab 150€';
const description = 'Transparente Preise für Kindergeburtstag mit Clown Zauberer LIAR – Zaubershow ab 150€ – Ballontiere +20€ – Glitzer Tattoos +40€ – Keine versteckten Kosten!';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was kostet ein Clown für den Kindergeburtstag?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Zaubershow für den Kindergeburtstag kostet 150€ für 40 Minuten (bis ca. 12 Kinder). Zusätzlich buchbar: Ballonmodellage (+20€) und Glitzer Tattoos (+40€). Hinzu kommen Fahrtkosten von 0,40€ pro Kilometer (Hin- und Rückfahrt) ab Gladbeck."
      }
    },
    {
      "@type": "Question",
      "name": "Gibt es versteckte Kosten?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nein. Der genannte Preis enthält die komplette Show inklusive aller Materialien. Es kommen lediglich die Fahrtkosten hinzu, die vorab transparent berechnet werden."
      }
    },
    {
      "@type": "Question",
      "name": "Kann ich auch nur Ballonmodellage oder Glitzer Tattoos buchen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Ballonmodellage und Glitzer Tattoos sind als Ergänzung zur Zaubershow konzipiert. Für eigenständige Buchungen (z.B. auf Straßenfesten) kontaktieren Sie mich bitte für ein individuelles Angebot."
      }
    },
    {
      "@type": "Question",
      "name": "Wie bezahle ich?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Bezahlung erfolgt in der Regel bar vor Ort am Tag der Veranstaltung. Auf Wunsch ist auch Überweisung vorab möglich."
      }
    }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Clown Zauberer LIAR – Kindergeburtstag",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Clown Zauberer LIAR",
    "url": "https://liar-entertainer.com"
  },
  "areaServed": {
    "@type": "State",
    "name": "Nordrhein-Westfalen"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Kindergeburtstag-Pakete",
    "itemListElement": [
      {
        "@type": "Offer",
        "name": "Zaubershow",
        "price": "150",
        "priceCurrency": "EUR",
        "description": "40 Minuten interaktive Zaubershow für bis zu 12 Kinder, inkl. Material"
      },
      {
        "@type": "Offer",
        "name": "Zaubershow + Ballonmodellage",
        "price": "170",
        "priceCurrency": "EUR",
        "description": "Zaubershow plus Ballontiere für jedes Kind, ca. 55 Minuten"
      },
      {
        "@type": "Offer",
        "name": "Komplett-Paket",
        "price": "210",
        "priceCurrency": "EUR",
        "description": "Zaubershow + Ballonmodellage + Glitzer Tattoos, ca. 90 Minuten"
      }
    ]
  }
};
---

<BaseLayout
  title={title}
  description={description}
  keywords="Preise Clown Zauberer, Kindergeburtstag Kosten, Zaubershow Preis, Clown buchen Kosten NRW, Kinderzauberer Preise"
  canonical="https://liar-entertainer.com/preise/"
  breadcrumbs={[{ name: 'Startseite', url: '/' }, { name: 'Preise & Pakete', url: '/preise/' }]}
  structuredData={[faqSchema, serviceSchema]}
>

  <!-- Hero -->
  <section class="relative overflow-hidden" style="min-height: 440px;">
    <Image
      src={heroImg}
      alt="Preise und Pakete – Clown Zauberer LIAR für Kindergeburtstag"
      class="absolute inset-0 w-full h-full object-cover"
      style="object-position: 50% 30%"
      loading="eager"
      fetchpriority="high"
      widths={[400, 800, 1200]}
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-black/45"></div>
    <div class="relative flex items-end justify-center pb-12 pt-28" style="min-height: 440px;">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <h1 class="text-white font-extrabold text-3xl sm:text-4xl lg:text-5xl mb-4 drop-shadow-lg">Preise & Pakete – Transparent und fair</h1>
